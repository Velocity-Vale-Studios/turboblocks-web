---
import Layout from '../layouts/Layout.astro';

// DATA DRIVEN: Tutaj zarządzasz wszystkimi postami
const posts = [
    {
        title: 'WIELKA AKTUALIZACJA 2.0 JUŻ DOSTĘPNA!',
        date: '15 LUTY 2026',
        tag: 'UPDATE',
        url: '/blog/update-2-0', // Dodano URL
        desc: 'Dzisiaj wprowadziliśmy długo oczekiwane zmiany w systemie ekonomii oraz nowe biomy na mapie Survival. Sprawdź pełną listę zmian, nowy system craftingu i dowiedz się co nowego czeka na Ciebie w świecie TurboBlocks.',
        gradient: 'from-pink-500 via-purple-600 to-indigo-500',
        borderColorClass: 'border-pink-500/30',
        glowClass: 'shadow-[0_0_50px_rgba(236,72,153,0.2)] hover:shadow-[0_0_100px_rgba(236,72,153,0.4)]',
        accent: 'text-pink-400',
        btnHoverAccent: 'hover:bg-pink-500',
        textHoverAccent: 'group-hover:text-pink-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(236,72,153,0.5)]',
        borderAccent: 'border-pink-500/50',
        bgAccent: 'bg-pink-500/10',
        icon: '🚀',
        featured: true
    },
    {
        title: 'COLOR CLASH: SEZON 1',
        date: '12 LUTY 2026',
        tag: 'EVENT',
        url: '/blog/color-clash-season-1',
        desc: 'Przygotujcie pędzle i miecze! Nowy sezon Color Clash nadchodzi z zupełnie nowymi nagrodami, mapami i mechaniką przejmowania punktów.',
        gradient: 'from-cyan-500 via-blue-500 to-teal-400',
        borderColorClass: 'border-cyan-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(6,182,212,0.15)] hover:shadow-[0_0_80px_rgba(6,182,212,0.3)]',
        accent: 'text-cyan-400',
        btnHoverAccent: 'hover:bg-cyan-500',
        textHoverAccent: 'group-hover:text-cyan-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(6,182,212,0.5)]',
        borderAccent: 'border-cyan-500/50',
        bgAccent: 'bg-cyan-500/10',
        icon: '🎨',
        featured: false
    },
    {
        title: 'COMMUNITY HIGHLIGHTS #42',
        date: '10 LUTY 2026',
        tag: 'COMMUNITY',
        url: '/blog/community-42',
        desc: 'Zobaczcie najciekawsze budowle i momenty z ostatniego tygodnia przesyłane przez naszą społeczność na Discordzie.',
        gradient: 'from-orange-500 via-red-500 to-yellow-500',
        borderColorClass: 'border-orange-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(249,115,22,0.15)] hover:shadow-[0_0_80px_rgba(249,115,22,0.3)]',
        accent: 'text-orange-400',
        btnHoverAccent: 'hover:bg-orange-500',
        textHoverAccent: 'group-hover:text-orange-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(249,115,22,0.5)]',
        borderAccent: 'border-orange-500/50',
        bgAccent: 'bg-orange-500/10',
        icon: '🏆',
        featured: false
    }
];

const featuredPost = posts.find(p => p.featured);
const otherPosts = posts.filter(p => !p.featured);
---

<Layout title="Insides">
    <div class="max-w-7xl mx-auto px-8 pt-32 pb-16 md:pt-48 md:pb-32 relative">

        <div class="mb-12 md:mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-10 md:-top-20 -left-10 md:-left-20 w-64 md:w-96 h-64 md:h-96 bg-purple-500/20 blur-[100px] md:blur-[150px] -z-10"></div>
            <h2 class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.4em] md:tracking-[0.8em] text-cyan-400 mb-4">Devlog & News</h2>
            <h1 class="text-5xl md:text-7xl lg:text-9xl font-black italic text-white uppercase tracking-tighter leading-none">
                INSIDES <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400 pr-4 md:pr-8">FEED</span>
            </h1>
        </div>

        {featuredPost && (
                <div class="mb-16 md:mb-32">
                    <div class="-m-4 md:-m-12 p-4 md:p-12">
                        <article class={`group relative w-full rounded-[2.5rem] md:rounded-[4rem] border backdrop-blur-3xl transition-all duration-700 ${featuredPost.borderColorClass} ${featuredPost.glowClass} flex flex-col overflow-hidden`}>

                            <div class="absolute inset-0 pointer-events-none">
                                <div class={`absolute inset-0 bg-gradient-to-br ${featuredPost.gradient} opacity-20 group-hover:opacity-40 transition-opacity duration-700`}></div>
                                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a0a0a]/70 to-[#0a0a0a]"></div>
                                <div class="absolute -top-10 -right-10 text-[250px] md:text-[500px] opacity-10 rotate-12 group-hover:rotate-6 transition-all duration-1000 select-none">
                                    {featuredPost.icon}
                                </div>
                            </div>

                            <div class="relative p-8 md:p-20 z-10">
                                <div class="flex items-center gap-4 mb-8 md:mb-16">
                                <span class={`px-4 py-2 rounded-xl border backdrop-blur-md text-[9px] md:text-xs font-black tracking-[0.3em] uppercase ${featuredPost.bgAccent} ${featuredPost.borderAccent} ${featuredPost.accent}`}>
                                    {featuredPost.tag}
                                </span>
                                    <span class="text-[10px] md:text-xs font-bold text-white/60 uppercase tracking-widest">{featuredPost.date}</span>
                                </div>

                                <h2 class="text-4xl md:text-7xl lg:text-8xl font-black italic text-white uppercase tracking-tighter mb-8 md:mb-12 leading-[0.85] max-w-5xl">
                                    {featuredPost.title}
                                </h2>

                                <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-10">
                                    <p class="text-white/70 text-sm md:text-xl lg:text-2xl leading-relaxed max-w-3xl font-medium border-l-4 border-white/20 pl-6 md:pl-10">
                                        {featuredPost.desc}
                                    </p>

                                    <a href={featuredPost.url} class={`w-full md:w-auto shrink-0 flex items-center justify-center px-8 md:px-10 py-4 bg-white text-black font-black uppercase text-[10px] md:text-xs tracking-widest rounded-xl md:rounded-2xl transition-all duration-500 hover:scale-105 ${featuredPost.btnHoverAccent} ${featuredPost.shadowAccent} hover:text-white`}>
                                        CZYTAJ WIĘCEJ
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
            {otherPosts.map(post => (
                    <div class="h-full"> {/* Usunięto ujemne marginesy, które mogły psuć box-sizing */}
                        <article class={`group relative p-8 md:p-12 h-full rounded-[2rem] md:rounded-[3.5rem] bg-gradient-to-br from-white/5 to-white/[0.02] border backdrop-blur-3xl transition-all duration-500 ${post.borderColorClass} ${post.glowClass} flex flex-col`}>

                            <div class="absolute inset-0 rounded-[2rem] md:rounded-[3.5rem] overflow-hidden pointer-events-none -z-10">
                                <div class={`absolute -top-10 -right-10 md:-top-20 md:-right-20 w-48 md:w-80 h-48 md:h-80 bg-gradient-to-br ${post.gradient} blur-[60px] md:blur-[100px] opacity-20 group-hover:opacity-40 transition-opacity duration-500`}></div>
                            </div>

                            {/* GÓRA: Ikona i Tag obok siebie */}
                            <div class="flex flex-wrap justify-between items-start gap-4 mb-8">
                                <div class="flex items-center gap-4">
                                    <div class={`w-12 h-12 md:w-16 md:h-16 rounded-xl border ${post.borderAccent} ${post.bgAccent} flex items-center justify-center text-xl md:text-3xl shadow-lg shrink-0`}>
                                        {post.icon}
                                    </div>
                                    <span class={`px-3 py-1.5 rounded-lg border backdrop-blur-md text-[8px] md:text-[9px] font-black tracking-[0.2em] uppercase ${post.bgAccent} ${post.borderAccent} ${post.accent} whitespace-nowrap`}>
                            {post.tag}
                        </span>
                                </div>
                                <span class="text-[8px] md:text-[10px] font-bold text-white/30 uppercase tracking-widest pt-1">
                        {post.date}
                    </span>
                            </div>

                            {/* TYTUŁ */}
                            <h3 class={`text-2xl md:text-4xl font-black italic text-white uppercase tracking-tighter leading-tight mb-4 transition-colors duration-300 ${post.textHoverAccent}`}>
                                {post.title}
                            </h3>

                            {/* OPIS: KLUCZOWA ZMIANA - usunięto line-clamp-3 i dodano flex-grow */}
                            <p class="text-white/40 text-xs md:text-sm leading-relaxed mb-8 flex-grow font-medium">
                                {post.desc}
                            </p>

                            {/* PRZYCISK */}
                            <div class="mt-auto pt-4">
                                <a href={post.url} class={`inline-flex items-center gap-3 text-[9px] md:text-[11px] font-black uppercase tracking-widest text-white transition-colors ${post.textHoverAccent}`}>
                                    <span class="border-b border-white/20 pb-1 group-hover:border-current transition-colors">Czytaj artykuł</span>
                                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </a>
                            </div>
                        </article>
                    </div>
            ))}
        </div>
    </div>
</Layout>