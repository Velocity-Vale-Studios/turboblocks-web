---
import Layout from '../layouts/Layout.astro';

const posts = [
    {
        title: 'WIELKA AKTUALIZACJA 2.0 JUŻ DOSTĘPNA!',
        date: '15 LUTY 2026',
        tag: 'UPDATE',
        desc: 'Dzisiaj wprowadziliśmy długo oczekiwane zmiany w systemie ekonomii oraz nowe biomy na mapie Survival. Sprawdź pełną listę zmian, nowy system craftingu i dowiedz się co nowego czeka na Ciebie w świecie TurboBlocks.',
        gradient: 'from-pink-500 via-purple-600 to-indigo-500',
        borderColorClass: 'border-pink-500/30',
        glowClass: 'shadow-[0_0_50px_rgba(236,72,153,0.2)] hover:shadow-[0_0_100px_rgba(236,72,153,0.4)]',
        accent: 'text-pink-400',
        btnHoverAccent: 'hover:bg-pink-500',
        textHoverAccent: 'group-hover:text-pink-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(236,72,153,0.5)]',
        borderAccent: 'border-pink-500/50',
        bgAccent: 'bg-pink-500/10',
        icon: '🚀',
        featured: true
    },
    {
        title: 'COLOR CLASH: SEZON 1',
        date: '12 LUTY 2026',
        tag: 'EVENT',
        desc: 'Przygotujcie pędzle i miecze! Nowy sezon Color Clash nadchodzi z zupełnie nowymi nagrodami, mapami i mechaniką przejmowania punktów.',
        gradient: 'from-cyan-500 via-blue-500 to-teal-400',
        borderColorClass: 'border-cyan-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(6,182,212,0.15)] hover:shadow-[0_0_80px_rgba(6,182,212,0.3)]',
        accent: 'text-cyan-400',
        btnHoverAccent: 'hover:bg-cyan-500',
        textHoverAccent: 'group-hover:text-cyan-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(6,182,212,0.5)]',
        borderAccent: 'border-cyan-500/50',
        bgAccent: 'bg-cyan-500/10',
        icon: '🎨',
        featured: false
    },
    {
        title: 'COMMUNITY HIGHLIGHTS #42',
        date: '10 LUTY 2026',
        tag: 'COMMUNITY',
        desc: 'Zobaczcie najciekawsze budowle i momenty z ostatniego tygodnia przesyłane przez naszą społeczność na Discordzie.',
        gradient: 'from-orange-500 via-red-500 to-yellow-500',
        borderColorClass: 'border-orange-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(249,115,22,0.15)] hover:shadow-[0_0_80px_rgba(249,115,22,0.3)]',
        accent: 'text-orange-400',
        btnHoverAccent: 'hover:bg-orange-500',
        textHoverAccent: 'group-hover:text-orange-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(249,115,22,0.5)]',
        borderAccent: 'border-orange-500/50',
        bgAccent: 'bg-orange-500/10',
        icon: '🏆',
        featured: false
    }
];

const featuredPost = posts.find(p => p.featured);
const otherPosts = posts.filter(p => !p.featured);
---

<Layout title="Insides">
    {/* Usunięto overflow-x-hidden z głównego kontenera, aby nie ucinać poświaty (glow) */}
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-32 relative">

        {/* HEADER - Większy padding prawy (pr-8), żeby gradientu nie ucieło */}
        <div class="mb-12 md:mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-10 md:-top-20 -left-10 md:-left-20 w-64 md:w-96 h-64 md:h-96 bg-purple-500/20 blur-[100px] md:blur-[150px] -z-10"></div>
            <h2 class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.4em] md:tracking-[0.8em] text-cyan-400 mb-4">Devlog & News</h2>
            <h1 class="text-5xl md:text-7xl lg:text-9xl font-black italic text-white uppercase tracking-tighter leading-none">
                INSIDES <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400 pr-4 md:pr-8">FEED</span>
            </h1>
        </div>

        {/* FEATURED POST - Dynamiczna wysokość */}
        {featuredPost && (
                <div class="mb-16 md:mb-32 relative">
                    {/* Bufor bezpieczeństwa dla Glow (zostawiamy, żeby nie ucinało poświaty) */}
                    <div class="-m-4 md:-m-12 p-4 md:p-12">
                        <article class={`group relative w-full h-auto rounded-[2.5rem] md:rounded-[4rem] border backdrop-blur-3xl transition-all duration-700 ${featuredPost.borderColorClass} ${featuredPost.glowClass} flex flex-col`}>

                            {/* Wewnętrzne tło - ważne: h-full tutaj sprawia, że tło zawsze pokryje cały dynamiczny kontener */}
                            <div class="absolute inset-0 rounded-[2.5rem] md:rounded-[4rem] overflow-hidden pointer-events-none">
                                <div class={`absolute inset-0 bg-gradient-to-br ${featuredPost.gradient} opacity-20 group-hover:opacity-40 transition-opacity duration-700`}></div>
                                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a0a0a]/70 to-[#0a0a0a]"></div>

                                {/* Wielka ikona - teraz pozycjonowana absolutnie względem dynamicznego kontenera */}
                                <div class="absolute -top-10 -right-10 text-[250px] md:text-[500px] opacity-10 rotate-12 group-hover:rotate-6 transition-all duration-1000 select-none">
                                    {featuredPost.icon}
                                </div>
                            </div>

                            {/* Kontener treści - usunięto min-h, dodano solidne paddingi, które definiują wysokość */}
                            <div class="relative p-8 md:p-20 z-10 flex flex-col justify-end">

                                {/* Górne info (Tag & Data) */}
                                <div class="flex items-center gap-4 mb-8 md:mb-16">
                        <span class={`px-4 py-2 rounded-xl border backdrop-blur-md text-[9px] md:text-xs font-black tracking-[0.3em] uppercase ${featuredPost.bgAccent} ${featuredPost.borderAccent} ${featuredPost.accent}`}>
                            {featuredPost.tag}
                        </span>
                                    <span class="text-[10px] md:text-xs font-bold text-white/60 uppercase tracking-widest">{featuredPost.date}</span>
                                </div>

                                {/* Tytuł - h-auto sprawi, że jeśli tytuł ma 3 linie, kafel sam się powiększy */}
                                <h2 class="text-4xl md:text-7xl lg:text-8xl font-black italic text-white uppercase tracking-tighter mb-8 md:mb-12 leading-[0.85] max-w-5xl drop-shadow-2xl">
                                    {featuredPost.title}
                                </h2>

                                {/* Dolna sekcja (Opis & Button) */}
                                <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-10 md:gap-20">
                                    <p class="text-white/70 text-sm md:text-xl lg:text-2xl leading-relaxed max-w-3xl font-medium border-l-4 border-white/20 pl-6 md:pl-10">
                                        {featuredPost.desc}
                                    </p>

                                    <a href="#" class={`w-full md:w-auto shrink-0 flex items-center justify-center px-10 md:px-16 py-5 bg-white text-black font-black uppercase text-xs tracking-[0.2em] rounded-2xl hover:bg-cyan-400 hover:text-white transition-all duration-500 hover:scale-110 shadow-[0_20px_50px_rgba(255,255,255,0.2)] ${featuredPost.btnHoverAccent} ${featuredPost.shadowAccent}`}>
                                        Czytaj Więcej
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                </div>
        )}

        {/* GRID LAYOUT */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
            {otherPosts.map(post => (
                    <article class={`group relative p-6 md:p-12 rounded-[2rem] md:rounded-[3.5rem] bg-gradient-to-br from-white/5 to-white/[0.02] border backdrop-blur-3xl transition-all duration-500 ${post.borderColorClass} ${post.glowClass}`}>

                        {/* Efekt tła bez ucinania poświaty zewnętrznej */}
                        <div class="absolute inset-0 rounded-[2rem] md:rounded-[3.5rem] overflow-hidden pointer-events-none">
                            <div class="absolute top-0 right-0 w-full h-full bg-gradient-to-br from-transparent to-black/80"></div>
                            <div class={`absolute -top-10 -right-10 md:-top-20 md:-right-20 w-48 md:w-80 h-48 md:h-80 bg-gradient-to-br ${post.gradient} blur-[60px] md:blur-[100px] opacity-20 group-hover:opacity-40 transition-opacity duration-500`}></div>
                        </div>

                        <div class="relative z-10 flex flex-col h-full">
                            <div class="flex justify-between items-start mb-6 md:mb-10">
                                <div class={`w-12 h-12 md:w-20 md:h-20 rounded-xl md:rounded-[1.5rem] border ${post.borderAccent} ${post.bgAccent} flex items-center justify-center text-xl md:text-4xl shadow-lg backdrop-blur-md`}>
                                    {post.icon}
                                </div>
                                <span class={`text-[8px] md:text-[10px] font-bold text-white/30 uppercase tracking-widest py-2`}>{post.date}</span>
                            </div>

                            <div class="mb-6">
                                <span class={`text-[8px] md:text-[10px] font-black tracking-[0.2em] uppercase ${post.accent} mb-2 block`}>{post.tag}</span>
                                <h3 class="text-2xl md:text-4xl font-black italic text-white uppercase tracking-tighter leading-[0.9] group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-white/70 transition-all">
                                    {post.title}
                                </h3>
                            </div>

                            <p class="text-white/40 text-xs md:text-sm lg:text-base leading-relaxed mb-8 md:mb-12 line-clamp-3">
                                {post.desc}
                            </p>

                            <div class="mt-auto">
                                <a href="#" class={`inline-flex items-center gap-3 text-[9px] md:text-[11px] font-black uppercase tracking-widest text-white transition-colors ${post.textHoverAccent}`}>
                                    <span class="border-b border-white/20 pb-1 group-hover:border-current transition-colors">Czytaj artykuł</span>
                                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                                </a>
                            </div>
                        </div>
                    </article>
            ))}
        </div>
    </div>
</Layout>