---
import Layout from '../layouts/Layout.astro';

const posts = [
    {
        title: 'WIELKA AKTUALIZACJA 2.0 JUŻ DOSTĘPNA!',
        date: '15 LUTY 2026',
        tag: 'UPDATE',
        desc: 'Dzisiaj wprowadziliśmy długo oczekiwane zmiany w systemie ekonomii oraz nowe biomy na mapie Survival...',
        gradient: 'from-pink-500/20 to-purple-600/20',
        accent: 'text-pink-400'
    },
    {
        title: 'COLOR CLASH: NOWY SEZON STARTUJE',
        date: '12 LUTY 2026',
        tag: 'EVENT',
        desc: 'Przygotujcie pędzle i miecze! Nowy sezon Color Clash nadchodzi z zupełnie nowymi nagrodami...',
        gradient: 'from-cyan-500/20 to-blue-600/20',
        accent: 'text-cyan-400'
    }
];
---

<Layout title="Insides">
    <div class="max-w-6xl mx-auto px-8 py-24">

        <div class="mb-20">
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-pink-500 mb-2">TurboBlocks Feed</h2>
            <h1 class="text-6xl font-[1000] italic text-white uppercase tracking-tighter leading-none">
                LATEST <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400">INSIDES</span>
            </h1>
        </div>

        <div class="space-y-10">
            {posts.map(post => (
                    <article class="group relative flex flex-col md:flex-row gap-10 p-2 rounded-[3rem] bg-white/[0.02] border border-white/5 hover:border-white/20 transition-all duration-500 backdrop-blur-xl overflow-hidden">

                        {/* Thumbnail z neonową poświatą */}
                        <div class={`relative w-full md:w-80 h-64 rounded-[2.5rem] overflow-hidden bg-gradient-to-br ${post.gradient} flex items-center justify-center shrink-0`}>
                            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"></div>
                            <span class="text-6xl group-hover:scale-125 transition-transform duration-700">🎨</span>
                        </div>

                        {/* Treść wpisu */}
                        <div class="flex flex-col justify-center p-6 md:pr-12">
                            <div class="flex items-center gap-4 mb-4">
                                <span class={`text-[10px] font-black tracking-widest uppercase ${post.accent}`}>{post.tag}</span>
                                <div class="h-1 w-1 bg-white/20 rounded-full"></div>
                                <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">{post.date}</span>
                            </div>

                            <h2 class="text-3xl font-[1000] italic text-white uppercase tracking-tighter mb-4 group-hover:text-pink-400 transition-colors leading-tight">
                                {post.title}
                            </h2>

                            <p class="text-white/40 text-sm leading-relaxed mb-8 max-w-xl">
                                {post.desc}
                            </p>

                            <div class="mt-auto">
                                <a href="#" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-white group-hover:text-cyan-400 transition-all">
                                    Czytaj więcej
                                    <span class="group-hover:translate-x-2 transition-transform">&rarr;</span>
                                </a>
                            </div>
                        </div>
                        <div class={`absolute -bottom-20 -right-20 w-64 h-64 bg-gradient-to-br ${post.gradient} blur-[100px] opacity-0 group-hover:opacity-20 transition-opacity`}></div>
                    </article>
            ))}
        </div>
    </div>
</Layout>