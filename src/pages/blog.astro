---
import Layout from '../layouts/Layout.astro';

const posts = [
    {
        title: 'WIELKA AKTUALIZACJA 2.0 JUŻ DOSTĘPNA!',
        date: '15 LUTY 2026',
        tag: 'UPDATE',
        desc: 'Dzisiaj wprowadziliśmy długo oczekiwane zmiany w systemie ekonomii oraz nowe biomy na mapie Survival. Sprawdź pełną listę zmian, nowy system craftingu i dowiedz się co nowego czeka na Ciebie w świecie TurboBlocks.',
        gradient: 'from-pink-500 via-purple-600 to-indigo-500',
        borderColorClass: 'border-pink-500/30',
        glowClass: 'shadow-[0_0_50px_rgba(236,72,153,0.2)] hover:shadow-[0_0_100px_rgba(236,72,153,0.4)]',
        accent: 'text-pink-400',
        btnHoverAccent: 'hover:bg-pink-500',
        textHoverAccent: 'group-hover:text-pink-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(236,72,153,0.5)]',
        borderAccent: 'border-pink-500/50',
        bgAccent: 'bg-pink-500/10',
        icon: '🚀',
        featured: true
    },
    {
        title: 'COLOR CLASH: SEZON 1',
        date: '12 LUTY 2026',
        tag: 'EVENT',
        desc: 'Przygotujcie pędzle i miecze! Nowy sezon Color Clash nadchodzi z zupełnie nowymi nagrodami, mapami i mechaniką przejmowania punktów.',
        gradient: 'from-cyan-500 via-blue-500 to-teal-400',
        borderColorClass: 'border-cyan-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(6,182,212,0.15)] hover:shadow-[0_0_80px_rgba(6,182,212,0.3)]',
        accent: 'text-cyan-400',
        btnHoverAccent: 'hover:bg-cyan-500',
        textHoverAccent: 'group-hover:text-cyan-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(6,182,212,0.5)]',
        borderAccent: 'border-cyan-500/50',
        bgAccent: 'bg-cyan-500/10',
        icon: '🎨',
        featured: false
    },
    {
        title: 'COMMUNITY HIGHLIGHTS #42',
        date: '10 LUTY 2026',
        tag: 'COMMUNITY',
        desc: 'Zobaczcie najciekawsze budowle i momenty z ostatniego tygodnia przesyłane przez naszą społeczność na Discordzie.',
        gradient: 'from-orange-500 via-red-500 to-yellow-500',
        borderColorClass: 'border-orange-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(249,115,22,0.15)] hover:shadow-[0_0_80px_rgba(249,115,22,0.3)]',
        accent: 'text-orange-400',
        btnHoverAccent: 'hover:bg-orange-500',
        textHoverAccent: 'group-hover:text-orange-400',
        shadowAccent: 'hover:shadow-[0_0_40px_rgba(249,115,22,0.5)]',
        borderAccent: 'border-orange-500/50',
        bgAccent: 'bg-orange-500/10',
        icon: '🏆',
        featured: false
    }
];

const featuredPost = posts.find(p => p.featured);
const otherPosts = posts.filter(p => !p.featured);
---

<Layout title="Insides">
    <div class="max-w-7xl mx-auto px-8 py-32">

        {/* HEADER */}
        <div class="mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-20 -left-20 w-96 h-96 bg-purple-500/20 blur-[150px] -z-10"></div>
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">Devlog & News</h2>
            <h1 class="text-7xl md:text-9xl font-black italic text-white uppercase tracking-tighter leading-none">
                INSIDES <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400 pr-4">FEED</span>
            </h1>
        </div>

        {/* FEATURED POST */}
        {featuredPost && (
            <div class="mb-20">
                <article class={`group relative w-full min-h-[500px] rounded-[3rem] overflow-hidden border backdrop-blur-3xl transition-all duration-500 ${featuredPost.borderColorClass} ${featuredPost.glowClass}`}>

                    {/* Background Gradient Image */}
                    <div class={`absolute inset-0 bg-gradient-to-br ${featuredPost.gradient} opacity-20 group-hover:opacity-30 transition-opacity duration-700`}></div>
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a0a0a]/50 to-[#0a0a0a]"></div>

                    <div class="absolute inset-0 p-10 md:p-16 flex flex-col justify-end z-10">
                        <div class="flex items-center gap-4 mb-6">
                            <span class={`px-4 py-2 rounded-xl border backdrop-blur-md text-xs font-black tracking-[0.3em] uppercase ${featuredPost.bgAccent} ${featuredPost.borderAccent} ${featuredPost.accent}`}>
                                {featuredPost.tag}
                            </span>
                            <span class="text-xs font-bold text-white/60 uppercase tracking-widest">{featuredPost.date}</span>
                        </div>

                        <h2 class="text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-6 leading-none max-w-4xl drop-shadow-2xl">
                            {featuredPost.title}
                        </h2>

                        <div class="flex flex-col md:flex-row items-end justify-between gap-8">
                            <p class="text-white/70 text-lg md:text-xl leading-relaxed max-w-2xl font-medium border-l-4 border-white/20 pl-6">
                                {featuredPost.desc}
                            </p>

                            <a href="#" class={`shrink-0 flex items-center justify-center px-10 py-4 bg-white text-black font-black uppercase text-xs tracking-widest rounded-2xl hover:text-white transition-all duration-300 hover:scale-105 shadow-[0_0_20px_rgba(255,255,255,0.2)] ${featuredPost.btnHoverAccent} ${featuredPost.shadowAccent}`}>
                                Czytaj Więcej
                            </a>
                        </div>
                    </div>

                    {/* Big Icon Background */}
                    <div class="absolute -top-10 -right-10 text-[300px] opacity-10 rotate-12 group-hover:rotate-6 transition-all duration-1000 select-none pointer-events-none">
                        {featuredPost.icon}
                    </div>
                </article>
            </div>
        )}

        {/* GRID LAYOUT */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {otherPosts.map(post => (
                <article class={`group relative p-10 rounded-[3rem] bg-gradient-to-br from-white/5 to-white/[0.02] border backdrop-blur-3xl transition-all duration-500 ${post.borderColorClass} ${post.glowClass}`}>

                    <div class="absolute top-0 right-0 w-full h-full bg-gradient-to-br from-transparent to-black/80 rounded-[3rem]"></div>
                    <div class={`absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br ${post.gradient} blur-[80px] opacity-20 group-hover:opacity-40 transition-opacity duration-500`}></div>

                    <div class="relative z-10 flex flex-col h-full">
                        <div class="flex justify-between items-start mb-8">
                            <div class={`w-16 h-16 rounded-2xl border ${post.borderAccent} ${post.bgAccent} flex items-center justify-center text-3xl shadow-lg backdrop-blur-md`}>
                                {post.icon}
                            </div>
                            <span class={`text-[10px] font-bold text-white/30 uppercase tracking-widest py-2`}>{post.date}</span>
                        </div>

                        <div class="mb-4">
                            <span class={`text-[10px] font-black tracking-[0.2em] uppercase ${post.accent} mb-2 block`}>{post.tag}</span>
                            <h3 class="text-3xl font-black italic text-white uppercase tracking-tighter leading-none group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-white/70 transition-all">
                                {post.title}
                            </h3>
                        </div>

                        <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
                            {post.desc}
                        </p>

                        <div class="mt-auto">
                            <a href="#" class={`inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-white transition-colors ${post.textHoverAccent}`}>
                                <span class="border-b border-white/20 pb-1 group-hover:border-current transition-colors">Czytaj artykuł</span>
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                            </a>
                        </div>
                    </div>
                </article>
            ))}
        </div>

    </div>
</Layout>