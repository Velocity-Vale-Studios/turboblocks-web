---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const blogEntries = await getCollection('blog');
    return blogEntries.map(entry => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;

const { Content } = await entry.render();
const post = entry.data;
---

<style is:global>
    /* --- TOC PILLS --- */
    .toc-pill {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        width: 100%;
        padding-left: 1.25rem;
        padding-right: 1.25rem;
        height: 2.75rem;
        -webkit-backdrop-filter: blur(12px);
        backdrop-filter: blur(12px);
        border-radius: 1rem;
        font-weight: 900;
        font-style: italic;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: all 0.3s ease;
        overflow: hidden;
        cursor: pointer;
        user-select: none;
        margin-bottom: 0.75rem;

        background: color-mix(in srgb, var(--post-accent-color), transparent 92%);
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--post-accent-color), transparent 75%);
        color: var(--post-accent-color);
    }

    .toc-pill:hover,
    .toc-pill.active {
        background: color-mix(in srgb, var(--post-accent-color), transparent 85%);
        box-shadow:
                inset 0 0 0 1px color-mix(in srgb, var(--post-accent-color), transparent 40%),
                0 0 20px color-mix(in srgb, var(--post-accent-color), transparent 85%);
        color: white;
        text-shadow: 0 0 10px var(--post-accent-color);
        transform: scale(1.02);
    }

    .toc-pill::before {
        content: "//";
        margin-right: 0.75rem;
        opacity: 0.3;
        font-size: 8px;
    }

    .toc-pill[data-level="3"] {
        height: 2.25rem;
        font-size: 8px;
        opacity: 0.5;
    }

    .toc-pill[data-level="3"]::before {
        content: "—";
    }

    /* --- PROSE OVERRIDES --- */
    .blog-prose h2 {
        font-size: 1.5rem;
        font-weight: 900;
        font-style: italic;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        color: white;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        line-height: 1.25;
    }
    @media (min-width: 768px) {
        .blog-prose h2 { font-size: 1.875rem; }
    }

    .blog-prose h3 {
        font-size: 1.25rem;
        font-weight: 900;
        font-style: italic;
        text-transform: uppercase;
        letter-spacing: -0.025em;
        color: rgba(255, 255, 255, 0.9);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        line-height: 1.25;
    }
    @media (min-width: 768px) {
        .blog-prose h3 { font-size: 1.5rem; }
    }

    .blog-prose p {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1rem;
        line-height: 1.75;
        margin-bottom: 1.5rem;
    }
    @media (min-width: 768px) {
        .blog-prose p { font-size: 1.125rem; }
    }

    .blog-prose strong {
        color: white;
        font-weight: 900;
    }

    .blog-prose ul, .blog-prose ol {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1rem;
        line-height: 1.75;
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }
    @media (min-width: 768px) {
        .blog-prose ul, .blog-prose ol { font-size: 1.125rem; }
    }

    .blog-prose li {
        margin-bottom: 0.5rem;
    }

    .blog-prose blockquote {
        border-left: 4px solid rgba(255, 255, 255, 0.1);
        padding-left: 1.5rem;
        font-style: italic;
        color: rgba(255, 255, 255, 0.5);
        margin-top: 2rem;
        margin-bottom: 2rem;
    }
</style>

<Layout title={post.title}>
    <div
        class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 pt-28 sm:pt-32 pb-16 md:pb-32 relative min-h-screen"
        style={`--post-accent-color: ${
            post.accent.includes('pink') ? '#f472b6' :
            post.accent.includes('cyan') ? '#22d3ee' :
            post.accent.includes('orange') ? '#fbbf24' : '#ffffff'
        };`}
    >
        {/* Ambient glow — w oddzielnym overflow-hidden żeby nie psuć navbara */}
        <div class="absolute inset-0 -z-10 pointer-events-none overflow-hidden">
            <div class={`absolute top-[5%] left-0 w-[400px] h-[400px] md:w-[500px] md:h-[500px] bg-gradient-to-br ${post.gradient} blur-[150px] opacity-[0.12]`}></div>
            <div class={`absolute bottom-[10%] right-0 w-[300px] h-[300px] bg-gradient-to-br ${post.gradient} blur-[120px] opacity-[0.08]`}></div>
        </div>

        {/* ===== HEADER ===== */}
        <section class={`p-6 sm:p-8 md:p-16 rounded-[2rem] md:rounded-[3rem] border backdrop-blur-3xl bg-gradient-to-br from-white/5 to-white/[0.02] mb-8 md:mb-12 relative overflow-hidden ${post.borderColorClass} ${post.glowClass}`}>
            {/* Linia gradientowa u góry */}
            <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>

            <div class="flex items-center gap-3 sm:gap-4 mb-6 md:mb-8">
                <span class={`px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl border text-[8px] sm:text-[9px] font-black uppercase tracking-widest ${post.bgAccent} ${post.borderAccent} ${post.accent}`}>
                    {post.tag}
                </span>
                <span class="text-[9px] sm:text-[10px] font-bold text-white/30 uppercase tracking-[0.3em]">{post.date}</span>
            </div>
            <h1 class="text-3xl sm:text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter leading-[0.85] mb-6 md:mb-8">
                {post.title}
            </h1>
            <p class="text-white/60 text-sm sm:text-base md:text-xl leading-relaxed border-l-4 border-white/10 pl-4 md:pl-6 italic max-w-4xl">
                {post.desc}
            </p>
        </section>

        {/* ===== MOBILE TOC (widoczny tylko <lg) ===== */}
        <section id="mobile-toc-wrapper" class="lg:hidden mb-8 hidden">
            <div class={`p-5 rounded-[2rem] border backdrop-blur-3xl bg-gradient-to-br from-white/5 to-white/[0.02] ${post.borderColorClass}`}>
                <button id="mobile-toc-toggle" class="flex items-center justify-between w-full">
                    <span class={`text-[10px] font-black uppercase tracking-[0.3em] italic ${post.accent}`}>Nawigacja //</span>
                    <svg id="toc-chevron" class="w-4 h-4 text-white/40 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <nav id="mobile-toc" class="flex flex-col mt-4 hidden">
                </nav>
            </div>
        </section>

        <div class="flex flex-col lg:flex-row gap-8 md:gap-12 items-start">

            {/* ===== DESKTOP SIDEBAR ===== */}
            <aside class="hidden lg:block w-[280px] shrink-0 sticky top-32 space-y-6">
                <div class={`p-6 rounded-[2rem] bg-gradient-to-br from-white/5 to-white/[0.02] border backdrop-blur-3xl ${post.borderColorClass} ${post.glowClass} relative overflow-hidden`}>
                    <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent"></div>
                    <h4 class={`text-[10px] font-black uppercase tracking-[0.3em] mb-6 italic border-b border-white/5 pb-4 ${post.accent}`}>
                        Nawigacja //
                    </h4>
                    <nav id="desktop-toc" class="flex flex-col">
                    </nav>
                </div>

                {/* Discord CTA */}
                <a href="https://discord.gg/turboblocks" target="_blank"
                   class="group relative block w-full rounded-[2rem] bg-gradient-to-br from-white/5 to-white/[0.02] border border-white/10 p-6 backdrop-blur-3xl transition-all duration-500 hover:border-indigo-500/50 overflow-hidden">
                    <div class="absolute -right-4 -top-4 w-24 h-24 bg-indigo-500/10 blur-3xl group-hover:bg-indigo-500/20 transition-colors"></div>
                    <div class="relative flex items-center gap-4">
                        <div class="w-12 h-12 shrink-0 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center shadow-[0_0_20px_rgba(88,101,242,0.15)] group-hover:scale-110 transition-all duration-500">
                            <svg class="w-6 h-6 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 11.721 11.721 0 0 0-.617-1.25.077.077 0 0 0-.079-.037 19.736 19.736 0 0 0-4.885 1.515.069.069 0 0 0-.032.027C.533 9.048-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994.054-.108.015-.23-.087-.272a13.235 13.235 0 0 1-1.873-.894.077.077 0 0 1-.008-.128c.125-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.874.894.077.077 0 0 0-.086.272c.351.699.765 1.362 1.227 1.994a.078.078 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.419-2.157 2.419z"/>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-[8px] font-black text-pink-500 uppercase tracking-[0.2em] mb-1 italic">Masz pytania?</p>
                            <h3 class="text-lg font-black italic text-white uppercase tracking-tighter leading-none group-hover:translate-x-1 transition-transform duration-300">
                                Join <span class="text-indigo-400">Discord</span>
                            </h3>
                        </div>
                    </div>
                </a>
            </aside>

            {/* ===== ARTICLE CONTENT ===== */}
            <div class="flex-1 min-w-0 space-y-6 md:space-y-8">
                <section class="p-6 sm:p-8 md:p-12 rounded-[2rem] md:rounded-[3rem] border border-white/10 bg-gradient-to-br from-white/[0.03] to-white/[0.01] backdrop-blur-3xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
                    <div class="blog-prose max-w-none">
                        <Content />
                    </div>
                </section>

                {/* Stopka artykułu */}
                <section class="p-5 sm:p-6 md:p-8 rounded-[2rem] border border-white/5 bg-gradient-to-br from-white/[0.03] to-white/[0.01] flex flex-col sm:flex-row justify-between items-center gap-4 sm:gap-6">
                    <div class="flex items-center gap-3 sm:gap-4">
                        <div class={`w-10 h-10 sm:w-12 sm:h-12 rounded-xl border ${post.borderAccent} ${post.bgAccent} flex items-center justify-center text-xl sm:text-2xl shadow-lg`}>
                            {post.icon}
                        </div>
                        <div>
                            <p class="text-white font-black uppercase text-[10px] sm:text-xs italic">Koniec transmisji //</p>
                            <p class="text-white/30 text-[8px] sm:text-[9px] uppercase font-bold tracking-widest">TurboBlocks Studio Team</p>
                        </div>
                    </div>
                    <a href="/blog" class="text-[9px] sm:text-[10px] font-black text-white/30 uppercase tracking-[0.3em] italic hover:text-white transition-colors duration-300">
                        ← Wróć do Insides
                    </a>
                </section>
            </div>
        </div>
    </div>
</Layout>

<script>
    function buildTOC() {
        const content = document.querySelector('.blog-prose');
        const desktopToc = document.getElementById('desktop-toc');
        const mobileToc = document.getElementById('mobile-toc');
        const mobileTocWrapper = document.getElementById('mobile-toc-wrapper');
        const headings = content?.querySelectorAll('h2, h3') as NodeListOf<HTMLElement> | undefined;

        if (!headings || headings.length === 0) return;

        // Pokaż mobilny wrapper
        if (mobileTocWrapper) mobileTocWrapper.classList.remove('hidden');

        headings.forEach((heading, index) => {
            heading.id = `section-${index}`;
            const level = heading.tagName === 'H3' ? '3' : '2';

            const pillHTML = `<div class="toc-pill" data-level="${level}" data-target="section-${index}"><span>${heading.innerText}</span></div>`;

            if (desktopToc) desktopToc.insertAdjacentHTML('beforeend', pillHTML);
            if (mobileToc) mobileToc.insertAdjacentHTML('beforeend', pillHTML);
        });

        // Click handler
        document.querySelectorAll('.toc-pill').forEach(pill => {
            pill.addEventListener('click', () => {
                const targetId = pill.getAttribute('data-target');
                const target = document.getElementById(targetId);
                if (!target) return;
                const y = target.getBoundingClientRect().top + window.pageYOffset - 120;
                window.scrollTo({ top: y, behavior: 'smooth' });
            });
        });

        // Mobile toggle
        const toggle = document.getElementById('mobile-toc-toggle');
        const chevron = document.getElementById('toc-chevron');
        if (toggle && mobileToc) {
            toggle.addEventListener('click', () => {
                mobileToc.classList.toggle('hidden');
                chevron?.classList.toggle('rotate-180');
            });
        }
    }

    buildTOC();
</script>