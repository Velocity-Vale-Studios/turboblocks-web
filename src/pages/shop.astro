---
import Layout from '../layouts/Layout.astro';
import CartOverlay from '../components/CartOverlay.astro';

const allFullCollections = {
    winter: {
        name: "Winter Festive", status: "LIMITED EVENT", accent: "text-blue-400",
        items: [
            { name: "Krampus Horns", type: "Headgear", price: "2500 TC", icon: "😈", rarity: "Legendary", desc: "Najrzadszy artefakt wydarzenia.", featured: true },
            { name: "Snow Frost Brush", type: "Weapon Skin", price: "600 TC", icon: "🖌️", rarity: "Epic", desc: "Malowanie w stylu szronu.", featured: true },
            { name: "Candy Burst", type: "Death Anim", price: "850 TC", icon: "🍭", rarity: "Rare", desc: "Słodka eksplozja.", featured: true },
            { name: "Frost Reform", type: "Respawn Anim", price: "750 TC", icon: "❄️", rarity: "Epic", desc: "Animacja odrodzenia.", featured: true }
        ]
    },
    solar: {
        name: "Solar Flare", status: "CLASSIC SELECTION", accent: "text-orange-500",
        items: [
            { name: "Sun Backpack", type: "Backpack", price: "1800 TC", icon: "☀️", rarity: "Legendary", desc: "Plecak słoneczny.", featured: true },
            { name: "Flare Stroke", type: "Weapon Skin", price: "650 TC", icon: "🔥", rarity: "Epic", desc: "Ognista smuga.", featured: true },
            { name: "Solar Reform", type: "Respawn Anim", price: "700 TC", icon: "✨", rarity: "Rare", desc: "Złocisty efekt.", featured: true },
            { name: "Sun Visor", type: "Headgear", price: "200 TC", icon: "🕶️", rarity: "Common", desc: "Klasyczne gogle.", featured: true }
        ]
    }
};
---

<Layout title="TurboShop - Terminal">
    <CartOverlay />
    <main class="max-w-7xl mx-auto px-8 pt-[140px] pb-24">
        <header class="mb-32">
            <h1 class="text-7xl md:text-9xl font-[1000] italic text-white uppercase tracking-tighter leading-none mb-8">
                TURBO<span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-cyan-400">SHOP</span>
            </h1>
        </header>

        {Object.values(allFullCollections).map((col, index) => (
                <section class="mb-48 text-left">
                    <div class="flex items-end justify-between mb-16 border-b border-white/5 pb-8">
                        <div>
                        <span class={`flex items-center gap-2 text-[11px] font-[1000] uppercase tracking-[0.5em] ${col.accent}`}>
                            {index === 0 && <span class="w-2 h-2 bg-current rounded-full animate-ping"></span>}
                            {col.status || "COLLECTION"}
                        </span>
                            <h2 class="text-6xl font-[1000] italic text-white uppercase tracking-tighter mt-2">{col.name}</h2>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-16">
                        {col.items.map(item => {
                            const rarityStyles = {
                                Common: "border-white/10",
                                Rare: "border-blue-500/30 shadow-[0_0_20px_rgba(59,130,246,0.15)]",
                                Epic: "border-purple-500/40 shadow-[0_0_25px_rgba(168,85,247,0.2)]",
                                Legendary: "border-orange-500/50 shadow-[0_0_35px_rgba(249,115,22,0.3)] text-yellow-400"
                            }[item.rarity];

                            const badgeStyles = {
                                Common: "text-white/40 border-white/10",
                                Rare: "text-blue-400 border-blue-500/30",
                                Epic: "text-purple-400 border-purple-500/30",
                                Legendary: "text-yellow-400 border-orange-500/40 animate-pulse"
                            }[item.rarity];

                            return (
                                    <div class={`group relative p-[1px] rounded-[2.8rem] transition-all duration-700 hover:scale-[1.03] bg-[#050505] border ${rarityStyles}`}>
                                        <div class="p-9 h-full flex flex-col relative overflow-hidden bg-[#050505] rounded-[2.7rem]">
                                            <div class="flex justify-between items-start mb-8 text-6xl">
                                                {item.icon}
                                                <span class={`text-[9px] font-[1000] uppercase tracking-[0.2em] px-2.5 py-1.5 rounded-xl border ${badgeStyles}`}>
                                            {item.rarity}
                                        </span>
                                            </div>
                                            <span class="text-[8px] font-black text-white/20 uppercase tracking-[0.3em] mb-2">{item.type}</span>
                                            <h3 class="text-2xl font-[1000] text-white uppercase italic tracking-tighter mb-3 leading-none">{item.name}</h3>
                                            <p class="text-white/30 text-[11px] italic mb-10 leading-relaxed">{item.desc}</p>
                                            <div class="mt-auto pt-8 border-t border-white/5 flex justify-between items-center">
                                                <div class="flex flex-col">
                                                    <span class="text-[8px] font-black text-white/20 uppercase mb-1 leading-none">Cena</span>
                                                    <span class={`font-[1000] italic text-2xl ${col.accent}`}>{item.price}</span>
                                                </div>
                                                <button
                                                        onclick={`addToCart({name: "${item.name}", price: "${item.price}", icon: "${item.icon}"})`}
                                                        class="px-6 py-3 bg-white text-black rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-cyan-400 transition-all active:scale-95"
                                                >
                                                    NABYWAJ
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                            );
                        })}
                    </div>

                    <div class="flex justify-center">
                        <a href="/shop/catalog" class="group flex items-center gap-6 px-10 py-5 bg-white/[0.02] border border-white/5 rounded-3xl hover:bg-white hover:text-black transition-all">
                            <span class="text-[10px] font-black uppercase tracking-[0.3em]">PRZEGLĄDAJ KATALOG ELEMENTÓW</span>
                            <span class={`text-xl group-hover:translate-x-2 transition-transform ${col.accent}`}>→</span>
                        </a>
                    </div>
                </section>
        ))}
    </main>
</Layout>