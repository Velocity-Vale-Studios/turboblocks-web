---
import Layout from '../layouts/Layout.astro';

// --- DANE (BEZ ZMIAN) ---
const featuredCollection = {
    name: "Winter Festive",
    status: "LIMITED EVENT",
    desc: "Zimowy zestaw przedmiotów dostępny tylko przez ograniczony czas. Zdobądź legendarne rogi Krampusa i mroźne efekty.",
    gradient: "from-blue-600 via-indigo-500 to-cyan-400",
    borderColorClass: "border-blue-500/30",
    glowClass: "shadow-[0_0_60px_rgba(59,130,246,0.25)] hover:shadow-[0_0_100px_rgba(59,130,246,0.4)]",
    accent: "text-blue-400",
    items: [
        { name: "Krampus Horns", type: "Headgear", price: "2500 TC", icon: "😈", rarity: "Legendary", desc: "Najrzadszy artefakt wydarzenia.", theme: "blue" },
        { name: "Snow Frost Brush", type: "Weapon Skin", price: "600 TC", icon: "🖌️", rarity: "Epic", desc: "Malowanie w stylu szronu.", theme: "cyan" },
        { name: "Candy Burst", type: "Death Anim", price: "850 TC", icon: "🍭", rarity: "Rare", desc: "Słodka eksplozja.", theme: "pink" },
        { name: "Frost Reform", type: "Respawn Anim", price: "750 TC", icon: "❄️", rarity: "Epic", desc: "Animacja odrodzenia.", theme: "white" },
        { name: "Santa Hat", type: "Headgear", price: "Free", icon: "🎅", rarity: "Common", desc: "Klasyczna czapka Mikołaja.", theme: "red" },
        { name: "Frost Goggles", type: "Accessories", price: "300 TC", icon: "🥽", rarity: "Common", desc: "Gogle odporne na zamrażanie.", theme: "cyan" },
        { name: "Winter Scarf", type: "Accessories", price: "250 TC", icon: "🧣", rarity: "Common", desc: "Ciepły szalik na zimne dni.", theme: "blue" },
        { name: "Snow Backpack", type: "Backpack", price: "450 TC", icon: "🎒", rarity: "Rare", desc: "Plecak wypełniony śniegiem.", theme: "white" },
        { name: "Icy Sweep Roller", type: "Weapon Skin", price: "550 TC", icon: "🚜", rarity: "Rare", desc: "Wałek zostawiający lód.", theme: "cyan" },
        { name: "Step Freeze Boots", type: "Boots", price: "500 TC", icon: "👟", rarity: "Rare", desc: "Buty zamrażające podłoże.", theme: "blue" },
        { name: "Snow Burst Grenade", type: "Gadget", price: "400 TC", icon: "❄️", rarity: "Common", desc: "Granat śnieżny.", theme: "white" },
        { name: "Snow Drift Trail", type: "Player Trail", price: "350 TC", icon: "💨", rarity: "Common", desc: "Ślad śnieżny za graczem.", theme: "white" },
        { name: "Candy Glow Trail", type: "Player Trail", price: "400 TC", icon: "🍬", rarity: "Common", desc: "Słodka ścieżka świetlna.", theme: "pink" },
        { name: "Winter Gloves", type: "Accessories", price: "150 TC", icon: "🧤", rarity: "Common", desc: "Rękawice zimowe.", theme: "blue" }
    ]
};

const classicCollection = {
    name: "Solar Flare",
    status: "CLASSIC SELECTION",
    gradient: "from-orange-500 via-red-500 to-yellow-500",
    borderColorClass: "border-orange-500/30",
    glowClass: "shadow-[0_0_60px_rgba(249,115,22,0.25)] hover:shadow-[0_0_100px_rgba(249,115,22,0.4)]",
    accent: "text-orange-500",
    items: [
        { name: "Sun Backpack", type: "Backpack", price: "1800 TC", icon: "☀️", rarity: "Legendary", desc: "Plecak słoneczny.", theme: "orange" },
        { name: "Flare Stroke", type: "Weapon Skin", price: "650 TC", icon: "🔥", rarity: "Epic", desc: "Ognista smuga.", theme: "red" },
        { name: "Solar Reform", type: "Respawn Anim", price: "700 TC", icon: "✨", rarity: "Rare", desc: "Złocisty efekt.", theme: "yellow" },
        { name: "Sun Visor", type: "Headgear", price: "200 TC", icon: "🕶️", rarity: "Common", desc: "Klasyczne gogle.", theme: "orange" },
        { name: "Solar Trail", type: "Player Trail", price: "300 TC", icon: "☄️", rarity: "Rare", desc: "Ognisty ślad komety.", theme: "orange" },
        { name: "Flare Steps", type: "Boots", price: "400 TC", icon: "👟", rarity: "Rare", desc: "Buty zostawiające żar.", theme: "red" },
        { name: "Blaze Bomb", type: "Gadget", price: "450 TC", icon: "💣", rarity: "Epic", desc: "Bomba zapalająca.", theme: "orange" },
        { name: "Solar Gloves", type: "Accessories", price: "150 TC", icon: "🧤", rarity: "Common", desc: "Rękawice odporne na żar.", theme: "orange" },
        { name: "Sunshot Cannon", type: "Weapon Skin", price: "600 TC", icon: "🔫", rarity: "Epic", desc: "Działo słoneczne.", theme: "yellow" },
        { name: "Solar Sweep", type: "Weapon Skin", price: "500 TC", icon: "🚜", rarity: "Rare", desc: "Pojazd solarny.", theme: "orange" }
    ]
};

const getRarityStyles = (rarity: string) => {
    switch(rarity) {
        case 'Legendary': return 'border-yellow-500/50 shadow-[0_0_30px_rgba(234,179,8,0.2)] text-yellow-400';
        case 'Epic': return 'border-purple-500/40 shadow-[0_0_20px_rgba(168,85,247,0.15)] text-purple-400';
        case 'Rare': return 'border-blue-500/30 shadow-[0_0_15px_rgba(59,130,246,0.1)] text-blue-400';
        default: return 'border-white/10 text-white/60';
    }
};

const chunkItems = (items: any[]) => {
    const chunks = [];
    for (let i = 0; i < items.length; i += 4) {
        const chunk = items.slice(i, i + 4);
        while (chunk.length < 4) {
            chunk.push(null);
        }
        chunks.push(chunk);
    }
    return chunks;
};

const featuredChunks = chunkItems(featuredCollection.items);
const classicChunks = chunkItems(classicCollection.items);
---

<Layout title="TurboShop - Terminal">
    <main class="max-w-7xl mx-auto px-4 md:px-8 py-16 md:py-32">

        <div class="mb-12 md:mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-20 -left-20 w-96 h-96 bg-pink-500/20 blur-[150px] -z-10"></div>
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">Store Access</h2>
            <h1 class="text-4xl md:text-7xl lg:text-9xl font-black italic text-white uppercase tracking-tighter leading-none md:pr-12">
                TURBO <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-400 pr-4">SHOP</span>
            </h1>
        </div>

        {/* SECTION 1: FEATURED */}
        <section class="mb-16 md:mb-32">
            <div class={`relative rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-12 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 transition-all duration-700 ${featuredCollection.borderColorClass} ${featuredCollection.glowClass} group`}>
                <div class={`absolute inset-0 bg-gradient-to-br ${featuredCollection.gradient} opacity-10 group-hover:opacity-20 transition-opacity duration-700`}></div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-16 gap-8 text-center md:text-left">
                        <div class="w-full md:w-auto">
                            <span class="px-4 py-1.5 bg-blue-500/20 border border-blue-500/30 rounded-xl text-blue-400 text-xs font-black uppercase tracking-widest shadow-[0_0_15px_rgba(59,130,246,0.3)] animate-pulse inline-block mb-4">
                                {featuredCollection.status}
                            </span>
                            <h2 class="text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-4">{featuredCollection.name}</h2>
                            <p class="text-white/50 max-w-xl text-sm md:text-lg font-medium">{featuredCollection.desc}</p>
                        </div>
                    </div>

                    <div class="carousel-mask relative py-4 md:py-12 -mx-4 md:-mx-8">
                        <div id="featured-track" class="shop-track flex w-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform">
                            {featuredChunks.map((chunk) => (
                                    <div class="w-full flex-shrink-0 px-4 md:px-8 grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6 content-start">
                                        {chunk.map(item => (
                                            item ? (
                                                    <div class={`group/item relative bg-black/40 border backdrop-blur-md rounded-[2rem] md:rounded-[2.5rem] p-4 md:p-8 transition-all duration-500 ${getRarityStyles(item.rarity)} hover:bg-white/5 cursor-pointer item-card flex flex-col h-full`}
                                                         data-item={JSON.stringify(item)}>

                                                        {/* IKONA + RARITY BADGE */}
                                                        <div class="flex justify-between items-start mb-4 md:mb-6 w-full">
                                                            <div class="text-4xl md:text-5xl group-hover/item:scale-110 transition-transform">{item.icon}</div>
                                                            <span class="text-[10px] font-black uppercase tracking-widest border border-current px-2 py-1 rounded-lg opacity-80 shadow-sm">
                                                            {item.rarity}
                                                        </span>
                                                        </div>

                                                        <h3 class="text-xs md:text-xl font-black italic text-white uppercase tracking-tighter mb-1 line-clamp-1 text-center md:text-left">{item.name}</h3>
                                                        <div class="mt-auto w-full flex flex-col md:flex-row justify-between items-center pt-4 border-t border-white/5 gap-3">
                                                            <span class="font-black text-white text-xs md:text-base">{item.price}</span>
                                                            <button type="button" class="w-full md:w-10 h-8 md:h-10 bg-white text-black rounded-xl font-black flex items-center justify-center hover:scale-105 transition-transform">+</button>
                                                        </div>
                                                    </div>
                                            ) : (
                                                    <div class="invisible h-full"></div>
                                            )
                                        ))}
                                    </div>
                            ))}
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 mt-8">
                        <button type="button" class="carousel-prev-featured w-10 h-10 flex items-center justify-center text-blue-400 hover:scale-125 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                        </button>
                        <div class="flex items-center gap-2" id="slider-dots-featured">
                            {featuredChunks.map((_, index) => (
                                    <button class="dot-bullet bg-white/10" data-index={index}></button>
                            ))}
                        </div>
                        <button type="button" class="carousel-next-featured w-10 h-10 flex items-center justify-center text-blue-400 hover:scale-125 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>

        {/* SECTION 2: CLASSIC */}
        <section class="mb-16 md:mb-32">
            <div class={`relative rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-12 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 transition-all duration-700 ${classicCollection.borderColorClass} ${classicCollection.glowClass} group`}>
                <div class={`absolute inset-0 bg-gradient-to-br ${classicCollection.gradient} opacity-10 group-hover:opacity-20 transition-opacity duration-700`}></div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-16 gap-8 text-center md:text-left">
                        <div class="w-full">
                            <span class="px-4 py-1.5 bg-orange-500/20 border border-orange-500/30 rounded-xl text-orange-400 text-xs font-black uppercase tracking-widest shadow-[0_0_15px_rgba(249,115,22,0.3)] inline-block mb-4">
                                {classicCollection.status}
                            </span>
                            <h2 class="text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-4">{classicCollection.name}</h2>
                        </div>
                    </div>

                    <div class="carousel-mask relative py-4 md:py-12 -mx-4 md:-mx-8">
                        <div id="classic-track" class="shop-track flex w-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform">
                            {classicChunks.map((chunk) => (
                                    <div class="w-full flex-shrink-0 px-4 md:px-8 grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-8 content-start">
                                        {chunk.map(item => (
                                            item ? (
                                                    <div class={`group/item relative h-full flex flex-col p-4 md:p-8 rounded-[2rem] md:rounded-[2.5rem] bg-black/40 border backdrop-blur-md transition-all duration-500 ${getRarityStyles(item.rarity)} hover:bg-white/5 cursor-pointer item-card`}
                                                         data-item={JSON.stringify(item)}>

                                                        {/* IKONA + RARITY BADGE */}
                                                        <div class="flex justify-between items-start mb-4 md:mb-6 w-full">
                                                            <div class="text-4xl md:text-5xl group-hover/item:scale-110 transition-transform">{item.icon}</div>
                                                            <span class="text-[10px] font-black uppercase tracking-widest border border-current px-2 py-1 rounded-lg opacity-80 shadow-sm">
                                                            {item.rarity}
                                                        </span>
                                                        </div>

                                                        <h3 class="text-xs md:text-xl font-black italic text-white uppercase tracking-tighter mb-1 line-clamp-1 text-center md:text-left">{item.name}</h3>
                                                        <div class="mt-auto w-full flex flex-col md:flex-row justify-between items-center pt-4 border-t border-white/5 gap-3">
                                                            <span class="font-black text-white text-xs md:text-base">{item.price}</span>
                                                            <button type="button" class="w-full md:w-10 h-8 md:h-10 bg-white text-black rounded-xl font-black flex items-center justify-center hover:scale-105 transition-transform">+</button>
                                                        </div>
                                                    </div>
                                            ) : (
                                                    <div class="invisible h-full"></div>
                                            )
                                        ))}
                                    </div>
                            ))}
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 mt-8">
                        <button type="button" class="carousel-prev-classic w-10 h-10 flex items-center justify-center text-orange-400 hover:scale-125 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                        </button>
                        <div class="flex items-center gap-2" id="slider-dots">
                            {classicChunks.map((_, index) => (
                                    <button class="dot-bullet bg-white/10" data-index={index}></button>
                            ))}
                        </div>
                        <button type="button" class="carousel-next-classic w-10 h-10 flex items-center justify-center text-orange-400 hover:scale-125 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    {/* --- MODAL (BEZ ZMIAN W HTML) --- */}
    <div id="shop-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
        <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-xl transition-opacity opacity-0 duration-300"></div>
        <div id="modal-content" class="relative w-full max-w-lg transform scale-95 opacity-0 transition-all duration-300">
            <div class="relative overflow-hidden rounded-[3rem] border border-white/10 bg-[#0a0a0a] p-1">
                <div class="absolute inset-0 bg-gradient-to-br from-white/5 via-transparent to-transparent opacity-50"></div>
                <div class="relative bg-black/60 rounded-[2.8rem] p-8 md:p-12 flex flex-col items-center text-center backdrop-blur-md">
                    <button id="modal-close" class="absolute top-6 right-6 p-2 rounded-full bg-white/5 hover:bg-white/10 text-white/50 hover:text-white transition-colors">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                    <div id="modal-icon" class="text-7xl mb-6 transform hover:scale-110 transition-transform duration-500 cursor-default">🎁</div>
                    <span id="modal-rarity" class="px-4 py-1.5 rounded-xl text-xs font-black uppercase tracking-widest border border-white/10 bg-white/5 mb-6">Common</span>
                    <h3 id="modal-title" class="text-3xl md:text-5xl font-black italic text-white uppercase tracking-tighter mb-4 leading-none">Item Name</h3>
                    <p id="modal-desc" class="text-white/60 mb-8 max-w-sm">Opis przedmiotu...</p>
                    <div class="w-full pt-8 border-t border-white/10 flex flex-col gap-4">
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-white/40 font-medium uppercase text-xs tracking-widest">Price</span>
                            <span id="modal-price" class="text-2xl font-black text-white">0 TC</span>
                        </div>
                        <button class="w-full py-4 bg-white text-black rounded-2xl font-black uppercase tracking-wider hover:scale-[1.02] active:scale-[0.98] transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)]">
                            Purchase Now
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .carousel-mask {
            overflow: hidden;
            -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
        }
        .dot-bullet {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
        }
        .modal-open { overflow: hidden; }
        .modal-visible #modal-backdrop { opacity: 1; }
        .modal-visible #modal-content { transform: scale(100%); opacity: 1; }
    </style>

    <script is:inline>
        function createCarousel(config) {
            const track = document.getElementById(config.trackId);
            const dotsContainer = document.getElementById(config.dotsId);
            const prevBtn = document.querySelector(config.prevBtn);
            const nextBtn = document.querySelector(config.nextBtn);

            if (!track) return;

            let current = 0;
            const total = track.children.length;
            let isAnimating = false;

            const update = () => {
                track.style.transform = `translateX(-${current * 100}%)`;
                if (dotsContainer) {
                    Array.from(dotsContainer.children).forEach((dot, i) => {
                        config.activeCls.split(' ').forEach(c => dot.classList.remove(c));
                        dot.classList.remove('bg-white/10');

                        if (i === current) {
                            config.activeCls.split(' ').forEach(c => dot.classList.add(c));
                        } else {
                            dot.classList.add('bg-white/10');
                        }
                    });
                }
            };

            const slide = (direction) => {
                if (isAnimating) return;
                isAnimating = true;

                if (direction === 'next') {
                    current = (current + 1) % total;
                } else {
                    current = (current - 1 + total) % total;
                }

                update();

                setTimeout(() => {
                    isAnimating = false;
                }, 500);
            };

            if (nextBtn) nextBtn.addEventListener('click', (e) => { e.preventDefault(); slide('next'); });
            if (prevBtn) prevBtn.addEventListener('click', (e) => { e.preventDefault(); slide('prev'); });
            if (dotsContainer) {
                dotsContainer.addEventListener('click', (e) => {
                    const dot = e.target.closest('.dot-bullet');
                    if (dot && !isAnimating) {
                        const index = parseInt(dot.dataset.index);
                        if (index !== current) { current = index; update(); }
                    }
                });
            }
            update();
        }

        function initModal() {
            const modal = document.getElementById('shop-modal');
            const backdrop = document.getElementById('modal-backdrop');
            const closeBtn = document.getElementById('modal-close');

            const elIcon = document.getElementById('modal-icon');
            const elTitle = document.getElementById('modal-title');
            const elDesc = document.getElementById('modal-desc');
            const elPrice = document.getElementById('modal-price');
            const elRarity = document.getElementById('modal-rarity');

            const getRarityColor = (rarity) => {
                switch(rarity) {
                    case 'Legendary': return 'text-yellow-400 border-yellow-500/30 bg-yellow-500/10 shadow-[0_0_15px_rgba(234,179,8,0.2)]';
                    case 'Epic': return 'text-purple-400 border-purple-500/30 bg-purple-500/10 shadow-[0_0_15px_rgba(168,85,247,0.2)]';
                    case 'Rare': return 'text-blue-400 border-blue-500/30 bg-blue-500/10 shadow-[0_0_15px_rgba(59,130,246,0.2)]';
                    default: return 'text-white/60 border-white/10 bg-white/5';
                }
            };

            const openModal = (data) => {
                elIcon.textContent = data.icon;
                elTitle.textContent = data.name;
                elDesc.textContent = data.desc;
                elPrice.textContent = data.price;
                elRarity.textContent = data.rarity;

                elRarity.className = `px-4 py-1.5 rounded-xl text-xs font-black uppercase tracking-widest border mb-6 inline-block ${getRarityColor(data.rarity)}`;

                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.classList.add('modal-open');

                setTimeout(() => modal.classList.add('modal-visible'), 10);
            };

            const closeModal = () => {
                modal.classList.remove('modal-visible');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    document.body.classList.remove('modal-open');
                }, 300);
            };

            document.addEventListener('click', (e) => {
                const card = e.target.closest('.item-card');
                if (card && card.dataset.item) {
                    try {
                        const data = JSON.parse(card.dataset.item);
                        openModal(data);
                    } catch (err) {
                        console.error('Błąd danych JSON:', err);
                    }
                }
            });

            closeBtn.addEventListener('click', closeModal);
            backdrop.addEventListener('click', closeModal);
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
        }

        document.addEventListener('DOMContentLoaded', () => {
            createCarousel({
                trackId: 'featured-track',
                dotsId: 'slider-dots-featured',
                prevBtn: '.carousel-prev-featured',
                nextBtn: '.carousel-next-featured',
                activeCls: 'bg-blue-400 shadow-[0_0_10px_rgba(59,130,246,0.5)] scale-125'
            });

            createCarousel({
                trackId: 'classic-track',
                dotsId: 'slider-dots',
                prevBtn: '.carousel-prev-classic',
                nextBtn: '.carousel-next-classic',
                activeCls: 'bg-orange-500 shadow-[0_0_15px_rgba(249,115,22,0.8)] scale-125'
            });

            initModal();
        });
    </script>
</Layout>