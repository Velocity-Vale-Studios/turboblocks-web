---
import Layout from '../layouts/Layout.astro';
import ShopSafelist from '../components/shop/ShopSafelist.astro';
import { shopCollections } from '../data/shop';

// ═══════════════════════════════════════════════════════════════
// 🔧 SHOP CONFIG — zmień ID żeby podmienić kolekcje na stronie
// ═══════════════════════════════════════════════════════════════
const FEATURED_COLLECTION_ID = "chromatic-riot";      // sekcja Featured (górna, z opisem)
const CLASSIC_COLLECTION_ID  = "neon-genesis";          // sekcja Classic  (dolna, bez opisu)
// ═══════════════════════════════════════════════════════════════
// Dostępne ID (11 kolekcji):
//   "winter-festive", "solar-flare", "neon-genesis", "chromatic-riot",
//   "cryo-neon", "magma-flow", "prism-shift", "system-override",
//   "kinetic-surge", "neon-hazard", "astral-void"
// ═══════════════════════════════════════════════════════════════

const findCollection = (id: string) => shopCollections.find(c => c.id === id)!;

const featuredCollection = findCollection(FEATURED_COLLECTION_ID);
const classicCollection  = findCollection(CLASSIC_COLLECTION_ID);

const getRarityStyles = (rarity: string) => {
    switch(rarity) {
        case 'Legendary': return 'border-yellow-500/50 shadow-[0_0_30px_rgba(234,179,8,0.2)] text-yellow-400';
        case 'Epic': return 'border-purple-500/40 shadow-[0_0_20px_rgba(168,85,247,0.15)] text-purple-400';
        case 'Rare': return 'border-blue-500/30 shadow-[0_0_15px_rgba(59,130,246,0.1)] text-blue-400';
        case 'Uncommon': return 'border-green-500/20 shadow-[0_0_10px_rgba(34,197,94,0.1)] text-green-400';
        default: return 'border-white/10 text-white/60';
    }
};

const chunkItems = (items: any[]) => {
    const chunks = [];
    for (let i = 0; i < items.length; i += 4) {
        const chunk = items.slice(i, i + 4);
        while (chunk.length < 4) chunk.push(null);
        chunks.push(chunk);
    }
    return chunks;
};

const featuredChunks = chunkItems(featuredCollection.items);
const classicChunks  = chunkItems(classicCollection.items);
---

<Layout title="TurboShop">
    <ShopSafelist />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 pt-28 sm:pt-32 pb-24 md:pb-48 relative">

        {/* Ambient glow */}
        <div class="fixed inset-0 -z-10 pointer-events-none">
            <div class="absolute top-[10%] left-0 w-[500px] h-[500px] bg-gradient-to-br from-pink-500/15 via-purple-500/10 to-transparent blur-[160px]"></div>
            <div class="absolute bottom-[20%] right-0 w-[400px] h-[400px] bg-gradient-to-br from-cyan-500/10 via-blue-500/5 to-transparent blur-[140px]"></div>
        </div>

        {/* Header */}
        <div class="mb-12 md:mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="inline-block px-4 py-1.5 bg-cyan-400/10 border border-cyan-400/20 rounded-full mb-4">
                <span class="text-[10px] font-black uppercase tracking-[0.4em] text-cyan-400 block leading-none">Store Access</span>
            </div>
            <h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-black italic text-white uppercase tracking-tighter leading-none">
                TURBO <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-400 pr-4 md:pr-8">SHOP</span>
            </h1>
        </div>

        {/* FEATURED COLLECTION */}
        <section class="mb-16 md:mb-32">
            <div class={`relative rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-12 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 transition-all duration-700 ${featuredCollection.borderColorClass} ${featuredCollection.glowClass} group`}>
                <div class={`absolute inset-0 bg-gradient-to-br ${featuredCollection.gradient} opacity-10 group-hover:opacity-20 transition-opacity duration-700`}></div>
                <div class={`absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent ${featuredCollection.lineColor} to-transparent`}></div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-16 gap-6 text-center md:text-left">
                        <div>
                            <span class={`px-4 py-1.5 ${featuredCollection.badgeBg} border ${featuredCollection.badgeBorder} rounded-xl ${featuredCollection.badgeText} text-[10px] md:text-xs font-black uppercase tracking-widest ${featuredCollection.badgeShadow} ${featuredCollection.badgeAnimate ? 'animate-pulse' : ''} inline-block mb-4`}>
                                {featuredCollection.status}
                            </span>
                            <h2 class="text-3xl sm:text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-4">{featuredCollection.name}</h2>
                            {featuredCollection.desc && (
                                <p class="text-white/50 max-w-xl text-sm md:text-lg font-medium">{featuredCollection.desc}</p>
                            )}
                        </div>
                    </div>

                    <div class="carousel-mask relative py-4 md:py-12 -mx-4 md:-mx-8">
                        <div id="track-featured" class="shop-track flex w-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform" data-carousel-track data-active-color={featuredCollection.activeCarouselColor}>
                            {featuredChunks.map((chunk: any[]) => (
                                <div class="w-full flex-shrink-0 px-4 md:px-8 grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6 content-start">
                                    {chunk.map((item: any) => (
                                        item ? (
                                            <div class={`group/item relative bg-black/40 border backdrop-blur-md rounded-[1.5rem] md:rounded-[2.5rem] p-4 md:p-8 transition-all duration-500 ${getRarityStyles(item.rarity)} hover:bg-white/5 cursor-pointer item-card flex flex-col h-full`}
                                                 data-item={JSON.stringify(item)}>
                                                <div class="flex justify-between items-start mb-4 md:mb-6 w-full">
                                                    <div class="text-3xl md:text-5xl group-hover/item:scale-110 transition-transform">{item.icon}</div>
                                                    <span class="text-[8px] md:text-[10px] font-black uppercase tracking-widest border border-current px-2 py-1 rounded-lg opacity-80">{item.rarity}</span>
                                                </div>
                                                <h3 class="text-[11px] md:text-xl font-black italic text-white uppercase tracking-tighter mb-1 line-clamp-1">{item.name}</h3>
                                                <div class="mt-auto w-full flex flex-col md:flex-row justify-between items-center pt-4 border-t border-white/5 gap-2 md:gap-3">
                                                    <span class="font-black text-white text-xs md:text-base">{item.price}</span>
                                                    <button type="button" class="add-to-cart-btn w-full md:w-10 h-8 md:h-10 bg-white text-black rounded-xl font-black flex items-center justify-center hover:scale-105 active:scale-95 transition-transform text-sm">+</button>
                                                </div>
                                            </div>
                                        ) : (
                                            <div class="invisible h-full"></div>
                                        )
                                    ))}
                                </div>
                            ))}
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 mt-6 md:mt-8">
                        <button type="button" data-carousel-prev="featured" class={`w-10 h-10 flex items-center justify-center ${featuredCollection.accent} hover:scale-125 transition-all`}>
                            <svg fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
                        </button>
                        <div class="flex items-center gap-2" data-carousel-dots="featured">
                            {featuredChunks.map((_: any, index: number) => (
                                <button class="dot-bullet" data-index={index}></button>
                            ))}
                        </div>
                        <button type="button" data-carousel-next="featured" class={`w-10 h-10 flex items-center justify-center ${featuredCollection.accent} hover:scale-125 transition-all`}>
                            <svg fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>

        {/* CLASSIC COLLECTION */}
        <section class="mb-16 md:mb-32">
            <div class={`relative rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-12 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 transition-all duration-700 ${classicCollection.borderColorClass} ${classicCollection.glowClass} group`}>
                <div class={`absolute inset-0 bg-gradient-to-br ${classicCollection.gradient} opacity-10 group-hover:opacity-20 transition-opacity duration-700`}></div>
                <div class={`absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent ${classicCollection.lineColor} to-transparent`}></div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-16 gap-6 text-center md:text-left">
                        <div>
                            <span class={`px-4 py-1.5 ${classicCollection.badgeBg} border ${classicCollection.badgeBorder} rounded-xl ${classicCollection.badgeText} text-[10px] md:text-xs font-black uppercase tracking-widest ${classicCollection.badgeShadow} inline-block mb-4`}>
                                {classicCollection.status}
                            </span>
                            <h2 class="text-3xl sm:text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-4">{classicCollection.name}</h2>
                        </div>
                    </div>

                    <div class="carousel-mask relative py-4 md:py-12 -mx-4 md:-mx-8">
                        <div id="track-classic" class="shop-track flex w-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform" data-carousel-track data-active-color={classicCollection.activeCarouselColor}>
                            {classicChunks.map((chunk: any[]) => (
                                <div class="w-full flex-shrink-0 px-4 md:px-8 grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6 content-start">
                                    {chunk.map((item: any) => (
                                        item ? (
                                            <div class={`group/item relative bg-black/40 border backdrop-blur-md rounded-[1.5rem] md:rounded-[2.5rem] p-4 md:p-8 transition-all duration-500 ${getRarityStyles(item.rarity)} hover:bg-white/5 cursor-pointer item-card flex flex-col h-full`}
                                                 data-item={JSON.stringify(item)}>
                                                <div class="flex justify-between items-start mb-4 md:mb-6 w-full">
                                                    <div class="text-3xl md:text-5xl group-hover/item:scale-110 transition-transform">{item.icon}</div>
                                                    <span class="text-[8px] md:text-[10px] font-black uppercase tracking-widest border border-current px-2 py-1 rounded-lg opacity-80">{item.rarity}</span>
                                                </div>
                                                <h3 class="text-[11px] md:text-xl font-black italic text-white uppercase tracking-tighter mb-1 line-clamp-1">{item.name}</h3>
                                                <div class="mt-auto w-full flex flex-col md:flex-row justify-between items-center pt-4 border-t border-white/5 gap-2 md:gap-3">
                                                    <span class="font-black text-white text-xs md:text-base">{item.price}</span>
                                                    <button type="button" class="add-to-cart-btn w-full md:w-10 h-8 md:h-10 bg-white text-black rounded-xl font-black flex items-center justify-center hover:scale-105 active:scale-95 transition-transform text-sm">+</button>
                                                </div>
                                            </div>
                                        ) : (
                                            <div class="invisible h-full"></div>
                                        )
                                    ))}
                                </div>
                            ))}
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 mt-6 md:mt-8">
                        <button type="button" data-carousel-prev="classic" class={`w-10 h-10 flex items-center justify-center ${classicCollection.accent} hover:scale-125 transition-all`}>
                            <svg fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
                        </button>
                        <div class="flex items-center gap-2" data-carousel-dots="classic">
                            {classicChunks.map((_: any, index: number) => (
                                <button class="dot-bullet" data-index={index}></button>
                            ))}
                        </div>
                        <button type="button" data-carousel-next="classic" class={`w-10 h-10 flex items-center justify-center ${classicCollection.accent} hover:scale-125 transition-all`}>
                            <svg fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </div>

    {/* ITEM DETAIL MODAL */}
    <div id="shop-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
        <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-xl transition-opacity opacity-0 duration-300"></div>

        <div id="modal-content" class="relative w-full max-w-md transform scale-95 opacity-0 transition-all duration-500 ease-out">
            {/* Ambient glow behind card */}
            <div id="modal-ambient" class="absolute -inset-8 bg-purple-500/15 blur-[80px] rounded-full pointer-events-none transition-all duration-700"></div>

            <div id="modal-card" class="relative bg-gradient-to-br from-white/[0.07] to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2.5rem] shadow-[0_0_80px_rgba(0,0,0,0.6)] overflow-hidden">
                {/* Gradient line top */}
                <div id="modal-gradient-line" class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-purple-500/40 to-transparent"></div>

                {/* Close button */}
                <button id="modal-close" class="absolute top-5 right-5 z-20 w-9 h-9 flex items-center justify-center bg-white/5 border border-white/10 text-white/40 rounded-xl hover:bg-white/10 hover:text-white hover:rotate-90 transition-all duration-300">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>

                {/* Hero zone — icon + rarity glow */}
                <div class="relative flex flex-col items-center pt-10 pb-6 px-8">
                    <div id="modal-icon-glow" class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-48 bg-purple-500/20 blur-[60px] rounded-full pointer-events-none transition-all duration-700"></div>
                    <div id="modal-icon" class="relative text-7xl mb-5 hover:scale-110 transition-transform duration-500 cursor-default drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">🎁</div>
                    <span id="modal-rarity" class="px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-[0.2em] border border-white/10 bg-white/5 mb-4 inline-block">Common</span>
                    <h3 id="modal-title" class="text-3xl md:text-4xl font-black italic text-white uppercase tracking-tighter leading-none text-center mb-1">Item</h3>
                    <p id="modal-type" class="text-[9px] font-black text-white/25 uppercase tracking-[0.3em]">Type</p>
                </div>

                {/* Description + Price */}
                <div class="px-8 pb-8">
                    <p id="modal-desc" class="text-white/50 text-sm italic leading-relaxed text-center mb-8 border-l-4 border-white/10 pl-4 text-left">Opis...</p>

                    <div class="flex justify-between items-center mb-5 px-1">
                        <span class="text-[9px] font-black text-white/30 uppercase tracking-[0.2em]">Price</span>
                        <span id="modal-price" class="text-2xl font-black italic text-transparent bg-clip-text bg-gradient-to-r from-white to-pink-200 tracking-tighter">0 TC</span>
                    </div>

                    <button id="modal-add-btn" class="relative overflow-hidden w-full py-4 bg-white text-black rounded-2xl font-black uppercase text-[10px] tracking-[0.2em] shadow-[0_0_30px_rgba(255,255,255,0.15)] hover:shadow-[0_0_60px_rgba(236,72,153,0.4)] transition-all duration-300 active:scale-[0.97] flex items-center justify-center gap-3 group/add">
                        <span class="relative z-10 group-hover/add:text-pink-600 transition-colors">Add to Cart</span>
                        <span class="relative z-10 text-lg group-hover/add:text-pink-600 group-hover/add:translate-x-1 transition-all">+</span>
                        <div class="absolute inset-0 bg-gradient-to-r from-purple-100 to-pink-100 scale-x-0 group-hover/add:scale-x-100 transition-transform duration-300 origin-left"></div>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <style>
        .carousel-mask {
            overflow: hidden;
            -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
        }
        .dot-bullet {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            background: rgba(255,255,255,0.1);
        }
        .shop-modal-open { overflow: hidden; }
        .shop-modal-visible #modal-backdrop { opacity: 1; }
        .shop-modal-visible #modal-content { transform: scale(1); opacity: 1; }
        #modal-content { transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.4s ease; }
    </style>

    <script is:inline>
        function createCarousel(track) {
            const id = track.id.replace('track-', '');
            const activeColor = track.dataset.activeColor || 'white';
            const dotsContainer = document.querySelector('[data-carousel-dots="' + id + '"]');
            const prevBtn = document.querySelector('[data-carousel-prev="' + id + '"]');
            const nextBtn = document.querySelector('[data-carousel-next="' + id + '"]');

            let current = 0;
            const total = track.children.length;
            let isAnimating = false;

            const update = () => {
                track.style.transform = 'translateX(-' + (current * 100) + '%)';
                if (dotsContainer) {
                    Array.from(dotsContainer.children).forEach((dot, i) => {
                        dot.style.background = '';
                        dot.style.boxShadow = '';
                        dot.style.transform = '';
                        if (i === current) {
                            dot.style.background = activeColor;
                            dot.style.boxShadow = '0 0 10px ' + activeColor;
                            dot.style.transform = 'scale(1.25)';
                        } else {
                            dot.style.background = 'rgba(255,255,255,0.1)';
                        }
                    });
                }
            };

            const slide = (dir) => {
                if (isAnimating) return;
                isAnimating = true;
                current = dir === 'next' ? (current + 1) % total : (current - 1 + total) % total;
                update();
                setTimeout(() => isAnimating = false, 500);
            };

            if (nextBtn) nextBtn.addEventListener('click', (e) => { e.preventDefault(); slide('next'); });
            if (prevBtn) prevBtn.addEventListener('click', (e) => { e.preventDefault(); slide('prev'); });
            if (dotsContainer) {
                dotsContainer.addEventListener('click', (e) => {
                    const dot = e.target.closest('.dot-bullet');
                    if (dot && !isAnimating) {
                        const index = parseInt(dot.dataset.index);
                        if (index !== current) { current = index; update(); }
                    }
                });
            }
            update();
        }

        function initShopModal() {
            const modal = document.getElementById('shop-modal');
            const backdrop = document.getElementById('modal-backdrop');
            const closeBtn = document.getElementById('modal-close');
            const addBtn = document.getElementById('modal-add-btn');
            let currentItem = null;

            const rarityStyles = (r) => {
                switch(r) {
                    case 'Legendary': return { badge: 'text-yellow-400 border-yellow-500/30 bg-yellow-500/10', glow: 'rgba(234,179,8,0.2)', border: 'border-yellow-500/30', line: 'via-yellow-500/50' };
                    case 'Epic': return { badge: 'text-purple-400 border-purple-500/30 bg-purple-500/10', glow: 'rgba(168,85,247,0.2)', border: 'border-purple-500/30', line: 'via-purple-500/50' };
                    case 'Rare': return { badge: 'text-blue-400 border-blue-500/30 bg-blue-500/10', glow: 'rgba(59,130,246,0.2)', border: 'border-blue-500/30', line: 'via-blue-500/50' };
                    case 'Uncommon': return { badge: 'text-green-400 border-green-500/30 bg-green-500/10', glow: 'rgba(34,197,94,0.2)', border: 'border-green-500/30', line: 'via-green-500/50' };
                    default: return { badge: 'text-white/60 border-white/10 bg-white/5', glow: 'rgba(255,255,255,0.05)', border: 'border-white/10', line: 'via-white/20' };
                }
            };

            const openModal = (data) => {
                currentItem = data;
                const s = rarityStyles(data.rarity);

                document.getElementById('modal-icon').textContent = data.icon;
                document.getElementById('modal-title').textContent = data.name;
                document.getElementById('modal-type').textContent = data.type;
                document.getElementById('modal-desc').textContent = data.desc;
                document.getElementById('modal-price').textContent = data.price;

                // Rarity badge
                const r = document.getElementById('modal-rarity');
                r.textContent = data.rarity;
                r.className = 'px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-[0.2em] border mb-4 inline-block ' + s.badge;

                // Ambient glow color
                const ambient = document.getElementById('modal-ambient');
                if (ambient) ambient.style.background = s.glow;
                const iconGlow = document.getElementById('modal-icon-glow');
                if (iconGlow) iconGlow.style.background = s.glow;

                // Card border
                const card = document.getElementById('modal-card');
                if (card) {
                    card.className = card.className.replace(/border-\w+-\d+\/\d+/g, 'border-white/10');
                    card.classList.add(s.border);
                }

                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.classList.add('shop-modal-open');
                setTimeout(() => modal.classList.add('shop-modal-visible'), 10);
            };

            const closeModal = () => {
                modal.classList.remove('shop-modal-visible');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    document.body.classList.remove('shop-modal-open');
                }, 300);
            };

            // Click on item card (but not on + button)
            document.addEventListener('click', (e) => {
                if (e.target.closest('.add-to-cart-btn')) return;
                const card = e.target.closest('.item-card');
                if (card && card.dataset.item) {
                    try { openModal(JSON.parse(card.dataset.item)); } catch(err) {}
                }
            });

            // + button adds directly
            document.addEventListener('click', (e) => {
                const btn = e.target.closest('.add-to-cart-btn');
                if (!btn) return;
                const card = btn.closest('.item-card');
                if (card && card.dataset.item) {
                    try {
                        const item = JSON.parse(card.dataset.item);
                        window.dispatchEvent(new CustomEvent('shop:add', { detail: item }));
                    } catch(err) {}
                }
            });

            // Modal add btn
            if (addBtn) {
                addBtn.addEventListener('click', () => {
                    if (currentItem) {
                        window.dispatchEvent(new CustomEvent('shop:add', { detail: currentItem }));
                        closeModal();
                    }
                });
            }

            if (closeBtn) closeBtn.addEventListener('click', closeModal);
            if (backdrop) backdrop.addEventListener('click', closeModal);
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Auto-discover and init all carousels
            document.querySelectorAll('[data-carousel-track]').forEach(track => {
                createCarousel(track);
            });
            initShopModal();
        });
    </script>
</Layout>

