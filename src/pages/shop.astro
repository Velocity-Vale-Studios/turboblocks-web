---
import Layout from '../layouts/Layout.astro';

// ... (Twój kod featuredCollection i classicCollection pozostaje bez zmian)
const featuredCollection = {
    name: "Winter Festive",
    status: "LIMITED EVENT",
    desc: "Zimowy zestaw przedmiotów dostępny tylko przez ograniczony czas. Zdobądź legendarne rogi Krampusa i mroźne efekty.",
    gradient: "from-blue-600 via-indigo-500 to-cyan-400",
    borderColorClass: "border-blue-500/30",
    glowClass: "shadow-[0_0_60px_rgba(59,130,246,0.25)] hover:shadow-[0_0_100px_rgba(59,130,246,0.4)]",
    accent: "text-blue-400",
    items: [
        { name: "Krampus Horns", type: "Headgear", price: "2500 TC", icon: "😈", rarity: "Legendary", desc: "Najrzadszy artefakt wydarzenia.", theme: "blue" },
        { name: "Snow Frost Brush", type: "Weapon Skin", price: "600 TC", icon: "🖌️", rarity: "Epic", desc: "Malowanie w stylu szronu.", theme: "cyan" },
        { name: "Candy Burst", type: "Death Anim", price: "850 TC", icon: "🍭", rarity: "Rare", desc: "Słodka eksplozja.", theme: "pink" },
        { name: "Frost Reform", type: "Respawn Anim", price: "750 TC", icon: "❄️", rarity: "Epic", desc: "Animacja odrodzenia.", theme: "white" },
        { name: "Santa Hat", type: "Headgear", price: "Free", icon: "🎅", rarity: "Common", desc: "Klasyczna czapka Mikołaja.", theme: "red" },
        { name: "Frost Goggles", type: "Accessories", price: "300 TC", icon: "🥽", rarity: "Common", desc: "Gogle odporne na zamrażanie.", theme: "cyan" },
        { name: "Winter Scarf", type: "Accessories", price: "250 TC", icon: "🧣", rarity: "Common", desc: "Ciepły szalik na zimne dni.", theme: "blue" },
        { name: "Snow Backpack", type: "Backpack", price: "450 TC", icon: "🎒", rarity: "Rare", desc: "Plecak wypełniony śniegiem.", theme: "white" },
        { name: "Icy Sweep Roller", type: "Weapon Skin", price: "550 TC", icon: "🚜", rarity: "Rare", desc: "Wałek zostawiający lód.", theme: "cyan" },
        { name: "Step Freeze Boots", type: "Boots", price: "500 TC", icon: "👟", rarity: "Rare", desc: "Buty zamrażające podłoże.", theme: "blue" },
        { name: "Snow Burst Grenade", type: "Gadget", price: "400 TC", icon: "❄️", rarity: "Common", desc: "Granat śnieżny.", theme: "white" },
        { name: "Snow Drift Trail", type: "Player Trail", price: "350 TC", icon: "💨", rarity: "Common", desc: "Ślad śnieżny za graczem.", theme: "white" },
        { name: "Candy Glow Trail", type: "Player Trail", price: "400 TC", icon: "🍬", rarity: "Common", desc: "Słodka ścieżka świetlna.", theme: "pink" },
        { name: "Winter Gloves", type: "Accessories", price: "150 TC", icon: "🧤", rarity: "Common", desc: "Rękawice zimowe.", theme: "blue" }
    ]
};

const classicCollection = {
    name: "Solar Flare",
    status: "CLASSIC SELECTION",
    gradient: "from-orange-500 via-red-500 to-yellow-500",
    accent: "text-orange-500",
    items: [
        { name: "Sun Backpack", type: "Backpack", price: "1800 TC", icon: "☀️", rarity: "Legendary", desc: "Plecak słoneczny.", theme: "orange" },
        { name: "Flare Stroke", type: "Weapon Skin", price: "650 TC", icon: "🔥", rarity: "Epic", desc: "Ognista smuga.", theme: "red" },
        { name: "Solar Reform", type: "Respawn Anim", price: "700 TC", icon: "✨", rarity: "Rare", desc: "Złocisty efekt.", theme: "yellow" },
        { name: "Sun Visor", type: "Headgear", price: "200 TC", icon: "🕶️", rarity: "Common", desc: "Klasyczne gogle.", theme: "orange" },
        { name: "Solar Trail", type: "Player Trail", price: "300 TC", icon: "☄️", rarity: "Rare", desc: "Ognisty ślad komety.", theme: "orange" },
        { name: "Flare Steps", type: "Boots", price: "400 TC", icon: "👟", rarity: "Rare", desc: "Buty zostawiające żar.", theme: "red" },
        { name: "Blaze Bomb", type: "Gadget", price: "450 TC", icon: "💣", rarity: "Epic", desc: "Bomba zapalająca.", theme: "orange" },
        { name: "Solar Gloves", type: "Accessories", price: "150 TC", icon: "🧤", rarity: "Common", desc: "Rękawice odporne na żar.", theme: "orange" },
        { name: "Sunshot Cannon", type: "Weapon Skin", price: "600 TC", icon: "🔫", rarity: "Epic", desc: "Działo słoneczne.", theme: "yellow" },
        { name: "Solar Sweep", type: "Weapon Skin", price: "500 TC", icon: "🚜", rarity: "Rare", desc: "Pojazd solarny.", theme: "orange" }
    ]
};

const getRarityStyles = (rarity: string) => {
    switch(rarity) {
        case 'Legendary': return 'border-yellow-500/50 shadow-[0_0_30px_rgba(234,179,8,0.2)] text-yellow-400';
        case 'Epic': return 'border-purple-500/40 shadow-[0_0_20px_rgba(168,85,247,0.15)] text-purple-400';
        case 'Rare': return 'border-blue-500/30 shadow-[0_0_15px_rgba(59,130,246,0.1)] text-blue-400';
        default: return 'border-white/10 text-white/60';
    }
};

const chunkItems = (items: any[]) => {
    return items.reduce((resultArray: any[], item: any, index: number) => {
        const chunkIndex = Math.floor(index / 4);
        if(!resultArray[chunkIndex]) { resultArray[chunkIndex] = [] }
        resultArray[chunkIndex].push(item);
        return resultArray;
    }, []);
};

const featuredChunks = chunkItems(featuredCollection.items);
const classicChunks = chunkItems(classicCollection.items);
---

<Layout title="TurboShop - Terminal">
    <main class="max-w-7xl mx-auto px-4 md:px-8 py-16 md:py-32">

        {/* HEADER */}
        <div class="mb-12 md:mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-20 -left-20 w-96 h-96 bg-pink-500/20 blur-[150px] -z-10"></div>
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">Store Access</h2>
            <h1 class="text-4xl md:text-7xl lg:text-9xl font-black italic text-white uppercase tracking-tighter leading-none md:pr-12">
                TURBO <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-400 pr-4">SHOP</span>
            </h1>
        </div>

        <section class="mb-16 md:mb-32">
            <div class={`relative rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-12 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 transition-all duration-700 ${featuredCollection.borderColorClass} ${featuredCollection.glowClass} group`}>
                <div class={`absolute inset-0 bg-gradient-to-br ${featuredCollection.gradient} opacity-10 group-hover:opacity-20 transition-opacity duration-700`}></div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-16 gap-8 text-center md:text-left">
                        <div class="w-full md:w-auto text-center md:text-left">
                            <div class="flex justify-center md:justify-start items-center gap-4 mb-4">
                        <span class="px-4 py-1.5 bg-blue-500/20 border border-blue-500/30 rounded-xl text-blue-400 text-xs font-black uppercase tracking-widest shadow-[0_0_15px_rgba(59,130,246,0.3)] animate-pulse">
                            {featuredCollection.status}
                        </span>
                            </div>
                            <h2 class="text-4xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-4">{featuredCollection.name}</h2>
                            <p class="text-white/50 max-w-xl text-sm md:text-lg font-medium">{featuredCollection.desc}</p>
                        </div>
                    </div>

                    <div class="relative overflow-hidden py-4 md:py-12 -mx-4 md:-mx-8">
                        <div id="featured-track" class="flex w-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform">
                            {featuredChunks.map((chunk) => (
                                    <div class="w-full flex-shrink-0 px-4 md:px-8 grid grid-cols-2 lg:grid-cols-4 grid-rows-2 lg:grid-rows-1 gap-3 md:gap-6 transform-gpu content-start">
                                        {chunk.map(item => (
                                                <div
                                                        class={`group/item relative bg-black/40 border backdrop-blur-md rounded-[2rem] md:rounded-[2.5rem] p-4 md:p-8 hover:-translate-y-2 transition-all duration-500 ${getRarityStyles(item.rarity)} hover:bg-white/5 cursor-pointer item-card flex flex-col items-center text-center md:items-start md:text-left h-full`}
                                                        data-item={JSON.stringify(item)}
                                                >
                                                    <div class="flex justify-between items-start mb-4 md:mb-6 w-full">
                                                        <div class="text-4xl md:text-5xl filter drop-shadow-lg group-hover/item:scale-110 transition-transform duration-300 pointer-events-none mx-auto md:mx-0">{item.icon}</div>
                                                        <span class={`hidden md:block text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-lg border bg-black/50 pointer-events-none ${getRarityStyles(item.rarity)}`}>{item.rarity}</span>
                                                    </div>
                                                    <h3 class="text-xs md:text-xl font-black italic text-white uppercase tracking-tighter mb-1 md:mb-2 leading-none pointer-events-none line-clamp-1">{item.name}</h3>
                                                    <p class="hidden md:block text-white/30 text-xs font-medium mb-6 line-clamp-2 pointer-events-none">{item.desc}</p>
                                                    <div class="mt-auto w-full flex flex-col md:flex-row justify-between items-center pt-4 md:pt-6 border-t border-white/5 gap-3 md:gap-0">
                                                        <span class="font-black text-white text-xs md:text-base pointer-events-none">{item.price}</span>
                                                        <button
                                                                class="add-to-cart-btn w-full md:w-10 h-8 md:h-10 bg-white text-black rounded-xl flex items-center justify-center hover:bg-blue-400 hover:text-white transition-all shadow-lg hover:scale-105 z-20 relative text-xs md:text-base font-black"
                                                                data-item={JSON.stringify(item)}
                                                        >
                                                            +
                                                        </button>
                                                    </div>
                                                </div>
                                        ))}
                                    </div>
                            ))}
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 mt-8">
                        <button onclick="changeSlideFeatured(-1)" class="w-10 h-10 flex items-center justify-center text-blue-400 hover:text-white hover:scale-125 transition-all duration-300 drop-shadow-[0_0_10px_rgba(59,130,246,0.5)]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                        </button>
                        <div class="flex items-center gap-2" id="slider-dots-featured">
                            {featuredChunks.map((_, index) => (
                                    <button class={`w-3 h-3 rounded-full transition-all duration-300 cursor-pointer ${index === 0 ? "bg-blue-400 shadow-[0_0_10px_rgba(59,130,246,0.5)] scale-125" : "bg-white/10 hover:bg-white/30"}`} onclick={`scrollToSlideFeatured(${index})`}></button>
                            ))}
                        </div>
                        <button onclick="changeSlideFeatured(1)" class="w-10 h-10 flex items-center justify-center text-blue-400 hover:text-white hover:scale-125 transition-all duration-300 drop-shadow-[0_0_10px_rgba(59,130,246,0.5)]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-16 md:mb-32">
            <div class={`relative rounded-[2rem] md:rounded-[3.5rem] p-6 md:p-12 bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-orange-500/20 shadow-[0_0_60px_rgba(249,115,22,0.1)] group transition-all duration-700 hover:border-orange-500/40`}>
                <div class="absolute inset-0 rounded-[3.5rem] overflow-hidden pointer-events-none">
                    <div class="absolute -top-1/2 -left-1/4 w-[150%] h-[150%] bg-gradient-to-br from-orange-500/10 via-red-500/5 to-transparent blur-[100px] rounded-full group-hover:opacity-100 opacity-60 transition-opacity duration-1000"></div>
                </div>

                <div class="relative z-10">
                    <div class="flex flex-col lg:flex-row justify-between items-center md:items-end mb-8 md:mb-16 pb-8 border-b border-white/5 text-center md:text-left">
                        <div class="w-full">
                            <div class="flex justify-center md:justify-start items-center gap-4 mb-4">
                        <span class="px-4 py-1.5 bg-orange-500/10 border border-orange-500/30 rounded-xl text-orange-400 text-xs font-black uppercase tracking-widest shadow-[0_0_15px_rgba(249,115,22,0.2)]">
                            {classicCollection.status}
                        </span>
                            </div>
                            <h2 class="text-4xl md:text-6xl font-black italic text-white uppercase tracking-tighter mb-2">{classicCollection.name}</h2>
                            <p class="text-white/40 text-sm md:text-lg font-medium">Klasyczne przedmioty, które nigdy nie wychodzą z mody.</p>
                        </div>
                    </div>

                    <div class="relative overflow-hidden py-4 md:py-12 -mx-4 md:-mx-8">
                        <div id="classic-track" class="flex w-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform">
                            {classicChunks.map((chunk) => (
                                    <div class="w-full flex-shrink-0 px-4 md:px-8 grid grid-cols-2 lg:grid-cols-4 grid-rows-2 lg:grid-rows-1 gap-3 md:gap-8 transform-gpu content-start">
                                        {chunk.map(item => (
                                                <div
                                                        class={`group/item relative h-full flex flex-col p-4 md:p-8 rounded-[2rem] md:rounded-[2.5rem] bg-black/40 border backdrop-blur-md transition-all duration-500 hover:-translate-y-2 hover:bg-white/5 cursor-pointer item-card items-center text-center md:items-start md:text-left ${getRarityStyles(item.rarity)}`}
                                                        data-item={JSON.stringify(item)}
                                                >
                                                    <div class="flex justify-between items-start mb-4 md:mb-6 w-full">
                                                        <div class="text-4xl md:text-5xl filter drop-shadow-lg group-hover/item:scale-110 transition-transform duration-300 pointer-events-none mx-auto md:mx-0">{item.icon}</div>
                                                        <span class={`hidden md:block text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-lg border bg-black/50 pointer-events-none ${getRarityStyles(item.rarity)}`}>{item.rarity}</span>
                                                    </div>
                                                    <h3 class="text-xs md:text-xl font-black italic text-white uppercase tracking-tighter mb-1 md:mb-2 leading-none group-hover/item:text-orange-300 transition-colors pointer-events-none line-clamp-1">{item.name}</h3>
                                                    <p class="hidden md:block text-white/30 text-xs font-medium mb-6 line-clamp-2 leading-relaxed pointer-events-none">{item.desc}</p>
                                                    <div class="mt-auto w-full flex flex-col md:flex-row justify-between items-center pt-4 md:pt-6 border-t border-white/5 gap-3 md:gap-0">
                                                        <span class="font-black text-white text-xs md:text-base pointer-events-none">{item.price}</span>
                                                        <button
                                                                class="add-to-cart-btn w-full md:w-10 h-8 md:h-10 bg-white text-black rounded-xl flex items-center justify-center hover:bg-orange-500 hover:text-white transition-all shadow-lg hover:scale-105 relative z-20 text-xs md:text-base font-black"
                                                                data-item={JSON.stringify(item)}
                                                        >
                                                            +
                                                        </button>
                                                    </div>
                                                </div>
                                        ))}
                                    </div>
                            ))}
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 mt-8">
                        <button onclick="changeSlide(-1)" class="w-10 h-10 flex items-center justify-center text-orange-400 hover:text-white hover:scale-125 transition-all duration-300 drop-shadow-[0_0_10px_rgba(249,115,22,0.5)]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                        </button>
                        <div class="flex items-center gap-2" id="slider-dots">
                            {classicChunks.map((_, index) => (
                                    <button class={`w-3 h-3 rounded-full transition-all duration-300 cursor-pointer ${index === 0 ? "bg-orange-500 shadow-[0_0_15px_rgba(249,115,22,0.8)] scale-125" : "bg-white/10 hover:bg-white/30"}`} onclick={`scrollToSlide(${index})`}></button>
                            ))}
                        </div>
                        <button onclick="changeSlide(1)" class="w-10 h-10 flex items-center justify-center text-orange-400 hover:text-white hover:scale-125 transition-all duration-300 drop-shadow-[0_0_10px_rgba(249,115,22,0.5)]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>

        {/* MODAL REMAINS SAME */}
        <div id="item-modal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
            <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeModal()"></div>
            <div class="relative w-[90%] max-w-2xl transform scale-95 transition-all duration-300 opacity-0 bg-[#0a0a0a] border border-white/10 rounded-[2.5rem] md:rounded-[3rem] overflow-hidden shadow-[0_0_100px_rgba(0,0,0,0.8)]" id="modal-content">
                <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-br from-blue-500/20 via-purple-500/10 to-transparent blur-[100px] -z-10 rounded-full animate-pulse"></div>
                <div class="relative z-10 p-8 md:p-12 flex flex-col items-center text-center">
                    <button onclick="closeModal()" class="absolute top-6 right-6 md:top-8 md:right-8 w-10 h-10 flex items-center justify-center bg-white/5 hover:bg-white/10 rounded-full text-white/50 hover:text-white transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                    <div class="mb-6 relative">
                        <div class="absolute inset-0 bg-blue-500/30 blur-[60px] rounded-full" id="modal-glow"></div>
                        <div class="text-7xl md:text-9xl filter drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]" id="modal-icon">📦</div>
                    </div>
                    <div class="mb-4">
                        <span id="modal-rarity" class="px-4 py-1.5 rounded-xl border bg-black/50 text-[10px] font-black uppercase tracking-[0.2em] backdrop-blur-md">COMMON</span>
                    </div>
                    <h2 id="modal-title" class="text-3xl md:text-5xl font-black italic text-white uppercase tracking-tighter mb-2">Item Name</h2>
                    <span id="modal-type" class="text-white/40 text-[10px] md:text-sm font-bold uppercase tracking-widest mb-6 block">Item Type</span>
                    <p id="modal-desc" class="text-white/60 text-sm md:text-lg font-medium leading-relaxed max-w-md mb-8">Opis...</p>
                    <div class="flex items-center gap-6 w-full justify-center border-t border-white/5 pt-8">
                        <div class="flex flex-col items-start">
                            <span class="text-[10px] font-black text-white/30 uppercase tracking-widest mb-1">Price</span>
                            <span id="modal-price" class="text-2xl md:text-3xl font-black italic text-white tracking-widest">0 TC</span>
                        </div>
                        <button id="modal-btn" class="flex-1 md:flex-none px-6 md:px-10 py-4 bg-white text-black font-black uppercase text-xs md:text-sm tracking-widest rounded-2xl hover:bg-blue-500 hover:text-white transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)]">Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script is:inline>
        // --- LOGIKA POZOSTAJE BEZ ZMIAN ---
        let currentSlide = 0;
        const getSlideCount = () => document.getElementById('classic-track')?.children.length || 0;
        window.changeSlide = (direction) => { const total = getSlideCount(); currentSlide = (currentSlide + direction + total) % total; updateCarousel(); };
        window.scrollToSlide = (index) => { currentSlide = index; updateCarousel(); };
        function updateCarousel(isInitial = false) {
            const track = document.getElementById('classic-track');
            const dots = document.getElementById('slider-dots')?.children;
            const container = document.getElementById('carousel-mask-container');

            if (track) {
                // ... (Twoja logika transformacji tracka pozostaje bez zmian)
                if (isInitial) {
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                } else {
                    // ... (logika maski)
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                }
            }

            if (dots) {
                Array.from(dots).forEach((dot, i) => {
                    if (i === currentSlide) {
                        // TUTAJ: Dodano shadow i scale-125, aby pasowało do Featured
                        dot.className = "w-3 h-3 rounded-full bg-orange-500 shadow-[0_0_15px_rgba(249,115,22,0.8)] transition-all duration-300 scale-125 cursor-pointer";
                    } else {
                        dot.className = "w-3 h-3 rounded-full bg-white/10 hover:bg-white/30 transition-all duration-300 cursor-pointer";
                    }
                });
            }
        }

        let currentSlideFeatured = 0;
        const getSlideCountFeatured = () => document.getElementById('featured-track')?.children.length || 0;
        window.changeSlideFeatured = (direction) => { const total = getSlideCountFeatured(); currentSlideFeatured = (currentSlideFeatured + direction + total) % total; updateCarouselFeatured(); };
        window.scrollToSlideFeatured = (index) => { currentSlideFeatured = index; updateCarouselFeatured(); };
        function updateCarouselFeatured(isInitial = false) {
            const track = document.getElementById('featured-track');
            const dots = document.getElementById('slider-dots-featured')?.children;
            const container = document.getElementById('featured-carousel-mask-container');
            if (track) {
                if (isInitial) { track.style.transform = `translateX(-${currentSlideFeatured * 100}%)`; } else {
                    if(container) { container.style.maskImage = "linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%)"; container.style.webkitMaskImage = container.style.maskImage; }
                    setTimeout(() => { track.style.transform = `translateX(-${currentSlideFeatured * 100}%)`; setTimeout(() => { if(container) { container.style.maskImage = "none"; container.style.webkitMaskImage = "none"; } }, 400); }, 10);
                }
            }
            if (dots) { Array.from(dots).forEach((dot, i) => { dot.className = i === currentSlideFeatured ? "w-3 h-3 rounded-full bg-blue-400 shadow-[0_0_10px_rgba(59,130,246,0.5)] transition-all duration-300 scale-125 cursor-pointer" : "w-3 h-3 rounded-full bg-white/10 hover:bg-white/30 transition-all duration-300 cursor-pointer"; }); }
        }
        updateCarousel(true); updateCarouselFeatured(true);
    </script>
    <script is:inline src="/scripts/shop-modal.js"></script>
</Layout>


