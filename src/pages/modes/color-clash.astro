---
import Layout from '../../layouts/Layout.astro';

const tools = [
    { name: 'Paint Brush', desc: 'Precyzja i intencja w każdym ruchu.', icon: '🖌️' },
    { name: 'Paint Cannon', desc: 'Zasięg i presja na dystans.', icon: '🔫' },
    { name: 'Paint Roller', desc: 'Momentum i błyskawiczna ekspansja.', icon: '🚜' },
    { name: 'Painting Boots', desc: 'Nagroda za nieustanny ruch.', icon: '👟' }
];

const maps = [
    { name: 'Neon City', type: 'Engineered Dominance', color: 'from-cyan-500' },
    { name: 'Volcanic Island', type: 'Raw Instability', color: 'from-orange-500' },
    { name: 'Frozen Realm', type: 'Suppressed Energy', color: 'from-blue-300' },
    { name: 'Rainbow Maze', type: 'Experimental Distortion', color: 'from-pink-500' }
];
---

<Layout title="Color Clash - Tryb Gry">
    <main class="max-w-6xl mx-auto px-8 pt-[140px] pb-24">

        <header class="mb-16 border-b border-white/10 pb-12">
            <div class="flex flex-col md:flex-row items-end justify-between gap-8">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-6">
                        <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-black text-pink-400 uppercase tracking-[0.3em]">
                            Spectacle-Driven Mode
                        </span>
                        <span class="text-white/20 text-[10px] font-black uppercase tracking-widest">v2.0 // CC-2026</span>
                    </div>
                    {/* Dodano pr-8 aby uniknąć ucinania litery "H" przez italic/tracking */}
                    <h1 class="text-7xl md:text-9xl font-[1000] italic text-white uppercase tracking-tighter leading-[0.8] pr-8 overflow-visible">
                        COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400">CLASH</span>
                    </h1>
                </div>

                <div class="bg-white/[0.02] border border-white/10 p-6 rounded-3xl backdrop-blur-md min-w-[240px]">
                    <div class="flex justify-between mb-4">
                        <span class="text-[9px] font-black text-white/30 uppercase tracking-widest">Match Duration</span>
                        <span class="text-white font-black italic text-xs uppercase">8-15 MIN</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-[9px] font-black text-white/30 uppercase tracking-widest">Players</span>
                        <span class="text-white font-black italic text-xs uppercase">UP TO 16</span>
                    </div>
                </div>
            </div>
        </header>

        <article class="mb-32 relative">
            <div class="absolute -left-8 top-0 bottom-0 w-1.5 bg-gradient-to-b from-pink-500 to-purple-600 rounded-full"></div>
            <div class="pl-4">
                <h2 class="text-3xl md:text-5xl font-[1000] italic text-white uppercase tracking-tighter leading-[1.1] max-w-4xl">
                    "Mapa zapamięta, kto był <span class="text-pink-500">najsilniejszy</span>. W Color Clash kolor to nie tylko kosmetyka – to Twoja broń i tożsamość."
                </h2>
                <div class="mt-6 flex items-center gap-4">
                    <p class="text-[10px] font-black text-white/20 uppercase tracking-[0.5em]">System Log // Velocity Vale Studios</p>
                </div>
            </div>
        </article>

        <section class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-32 items-center">
            <div class="lg:col-span-7">
                <h2 class="text-[10px] font-black text-cyan-400 uppercase tracking-[0.5em] mb-8">The Chromatic Reality</h2>
                <p class="text-3xl font-black italic text-white uppercase tracking-tighter mb-8 leading-tight">
                    W niedalekiej przyszłości kolor nie jest już tylko kosmetyką. To <span class="text-pink-400">energia</span>, <span class="text-purple-400">tożsamość</span> i <span class="text-cyan-400">broń</span>.
                </p>
                <p class="text-white/40 leading-relaxed text-lg italic">
                    Color Clash to sankcjonowane konflikty wokół stref bogatych w energię chromatyczną. Nie jesteś żołnierzem – jesteś pretendentem w publicznym widowisku, gdzie dominacja oznacza przetrwanie.
                </p>
            </div>
            <div class="lg:col-span-5">
                <div class="p-10 bg-gradient-to-br from-white/[0.05] to-transparent border border-white/10 rounded-[3rem] relative overflow-hidden group">
                    <div class="absolute -top-10 -right-10 text-9xl opacity-[0.03] group-hover:scale-110 transition-transform text-white">🎨</div>
                    <h3 class="text-xs font-[1000] text-white uppercase tracking-[0.3em] mb-6">Design Philosophy</h3>
                    <ul class="space-y-3">
                        {['Arcade-first', 'Spectacle-driven', 'Readable chaos', 'World-consistent'].map(item => (
                                <li class="flex items-center gap-3 text-[10px] font-black text-white/60 uppercase tracking-widest">
                                    <div class="w-1.5 h-1.5 bg-pink-500 rounded-full"></div> {item}
                                </li>
                        ))}
                    </ul>
                </div>
            </div>
        </section>

        <section class="mb-32">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="p-10 bg-white/[0.02] border border-white/5 rounded-[3rem] hover:border-pink-500/30 transition-all group">
                    <div class="text-4xl mb-6 group-hover:rotate-12 transition-transform">💥</div>
                    <h4 class="text-xl font-black text-white uppercase italic tracking-tighter mb-4">Paint as Power</h4>
                    <p class="text-white/30 text-sm leading-relaxed">Malowanie to kontrola. Każda pomalowana powierzchnia to przejęta energia, która karmi Twój wynik i blokuje przeciwników.</p>
                </div>
                <div class="p-10 bg-white/[0.02] border border-white/5 rounded-[3rem] hover:border-cyan-500/30 transition-all group">
                    <div class="text-4xl mb-6 group-hover:rotate-12 transition-transform">⚡</div>
                    <h4 class="text-xl font-black text-white uppercase italic tracking-tighter mb-4">Combo Flow</h4>
                    <p class="text-white/30 text-sm leading-relaxed">Utrzymuj rytm malowania bez eliminacji, aby wejść w stan Flow. Im dłużej trwa seria, tym potężniejszy staje się mnożnik punktów.</p>
                </div>
                <div class="p-10 bg-white/[0.02] border border-white/5 rounded-[3rem] hover:border-purple-500/30 transition-all group">
                    <div class="text-4xl mb-6 group-hover:rotate-12 transition-transform">🌀</div>
                    <h4 class="text-xl font-black text-white uppercase italic tracking-tighter mb-4">Chromatic Overload</h4>
                    <p class="text-white/30 text-sm leading-relaxed">Eliminacja to tylko przerwa. Rozpłyń się w cząsteczkach własnego koloru i wróć natychmiast do gry – momentum jest ważniejsze niż przetrwanie.</p>
                </div>
            </div>
        </section>

        <section class="mb-32">
            <div class="flex items-center gap-6 mb-12">
                <h3 class="text-[10px] font-[1000] text-white uppercase tracking-[1em] italic">Game Formats</h3>
                <div class="h-[1px] flex-grow bg-gradient-to-r from-white/10 to-transparent"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="p-10 bg-white/[0.02] border border-white/10 rounded-[3rem] hover:bg-white/[0.04] transition-all group">
                    <div class="flex justify-between items-start mb-6">
                        <div class="text-4xl group-hover:scale-110 transition-transform">👤</div>
                        <span class="px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-lg text-[8px] font-black text-cyan-400 uppercase tracking-widest">Solo</span>
                    </div>
                    <h4 class="text-2xl font-[1000] italic text-white uppercase tracking-tighter mb-4">Free-for-All</h4>
                    <p class="text-white/30 text-sm leading-relaxed italic">
                        Czysta rywalizacja. Każdy gracz walczy o własną sygnaturę chromatyczną. Nie ma sojuszy – tylko Ty, Twoje narzędzia i mapa, którą musisz zdominować.
                    </p>
                </div>

                <div class="p-10 bg-white/[0.02] border border-white/10 rounded-[3rem] hover:bg-white/[0.04] transition-all group">
                    <div class="flex justify-between items-start mb-6">
                        <div class="text-4xl group-hover:scale-110 transition-transform">👥</div>
                        <span class="px-3 py-1 bg-purple-500/10 border border-purple-500/20 rounded-lg text-[8px] font-black text-purple-400 uppercase tracking-widest">4vs4 / 8vs8</span>
                    </div>
                    <h4 class="text-2xl font-[1000] italic text-white uppercase tracking-tighter mb-4">Team Battle</h4>
                    <p class="text-white/30 text-sm leading-relaxed italic">
                        Strategiczna koordynacja. Drużyny współpracują, by łączyć plamy koloru w potężne strefy wpływów i wspólnie kontrolować kluczowe punkty mapy.
                    </p>
                </div>

                <div class="relative group p-10 bg-gradient-to-br from-pink-500/5 to-transparent border border-pink-500/20 rounded-[3rem] hover:border-pink-500/50 transition-all overflow-hidden">
                    <div class="absolute -top-10 -right-10 text-8xl opacity-10 group-hover:rotate-12 transition-transform">🔥</div>
                    <div class="flex justify-between items-start mb-6">
                        <div class="text-4xl group-hover:scale-110 transition-transform">⚠️</div>
                        <span class="px-3 py-1 bg-pink-500/20 border border-pink-500/30 rounded-lg text-[8px] font-black text-pink-400 uppercase tracking-widest animate-pulse">Extreme</span>
                    </div>
                    <h4 class="text-2xl font-[1000] italic text-white uppercase tracking-tighter mb-4">Chaos Mode</h4>
                    <p class="text-white/30 text-[11px] leading-relaxed italic mb-6">
                        Zasady przestają istnieć. Dynamiczne wydarzenia zmieniają przebieg meczu w sekundę.
                    </p>

                    <ul class="space-y-3">
                        <li class="flex items-center gap-3">
                            <div class="w-1.5 h-1.5 bg-pink-500 rounded-full shadow-[0_0_5px_#ec4899]"></div>
                            <span class="text-[9px] font-black text-white/60 uppercase tracking-widest"><span class="text-white">Rainbow Storm:</span> Reset mapy</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-1.5 h-1.5 bg-pink-500 rounded-full shadow-[0_0_5px_#ec4899]"></div>
                            <span class="text-[9px] font-black text-white/60 uppercase tracking-widest"><span class="text-white">Paint Explosion:</span> High-value zones</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-1.5 h-1.5 bg-pink-500 rounded-full shadow-[0_0_5px_#ec4899]"></div>
                            <span class="text-[9px] font-black text-white/60 uppercase tracking-widest"><span class="text-white">Power-ups:</span> Zwiększony spawn</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="mb-32">
            <div class="flex items-center gap-6 mb-16">
                <h3 class="text-xs font-[1000] text-white uppercase tracking-[1em] italic">Chromatic Regions</h3>
                <div class="h-[1px] flex-grow bg-gradient-to-r from-white/10 to-transparent"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="group relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[3.5rem] p-10 transition-all hover:border-cyan-500/50">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-cyan-500/10 blur-[80px] group-hover:bg-cyan-500/20 transition-all"></div>
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-8">
                            <div>
                                <span class="text-[10px] font-black text-cyan-400 uppercase tracking-widest mb-2 block">Region 01 // Megacity</span>
                                <h4 class="text-4xl font-[1000] italic text-white uppercase tracking-tighter">Neon City</h4>
                            </div>
                            <span class="text-3xl filter drop-shadow-[0_0_10px_rgba(34,211,238,0.5)]">🏙️</span>
                        </div>
                        <p class="text-white/40 text-sm italic leading-relaxed mb-8">
                            Serce technologii chromatycznej. Walka toczy się w wiecznym deszczu, pośród wieżowców i holograficznych billboardów. Tutaj liczy się <span class="text-white">dominacja i spektakl</span> na oczach całego świata.
                        </p>
                        <div class="flex flex-wrap gap-3">
                            <span class="px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-lg text-[8px] font-black text-cyan-400 uppercase tracking-widest">Constant Rain</span>
                            <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[8px] font-black text-white/40 uppercase tracking-widest">Verticality</span>
                        </div>
                    </div>
                </div>

                <div class="group relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[3.5rem] p-10 transition-all hover:border-orange-500/50">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-orange-500/10 blur-[80px] group-hover:bg-orange-500/20 transition-all"></div>
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-8">
                            <div>
                                <span class="text-[10px] font-black text-orange-500 uppercase tracking-widest mb-2 block">Region 02 // Core</span>
                                <h4 class="text-4xl font-[1000] italic text-white uppercase tracking-tighter">Volcanic Island</h4>
                            </div>
                            <span class="text-3xl filter drop-shadow-[0_0_10px_rgba(249,115,22,0.5)]">🌋</span>
                        </div>
                        <p class="text-white/40 text-sm italic leading-relaxed mb-8">
                            Surowa, niestabilna energia. Teren nasycony lawą, gdzie środowisko jest równie niebezpieczne co przeciwnicy. Wykorzystaj <span class="text-white">gejzery energii</span>, by zyskać przewagę w pionie.
                        </p>
                        <div class="flex flex-wrap gap-3">
                            <span class="px-3 py-1 bg-orange-500/10 border border-orange-500/20 rounded-lg text-[8px] font-black text-orange-500 uppercase tracking-widest">Lava Hazards</span>
                            <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[8px] font-black text-white/40 uppercase tracking-widest">High Risk</span>
                        </div>
                    </div>
                </div>

                <div class="group relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[3.5rem] p-10 transition-all hover:border-blue-300/50">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-blue-300/10 blur-[80px] group-hover:bg-blue-300/20 transition-all"></div>
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-8">
                            <div>
                                <span class="text-[10px] font-black text-blue-300 uppercase tracking-widest mb-2 block">Region 03 // Void</span>
                                <h4 class="text-4xl font-[1000] italic text-white uppercase tracking-tighter">Frozen Realm</h4>
                            </div>
                            <span class="text-3xl filter drop-shadow-[0_0_10px_rgba(147,197,253,0.5)]">❄️</span>
                        </div>
                        <p class="text-white/40 text-sm italic leading-relaxed mb-8">
                            Tłumiona energia pod warstwą lodu. Rozległa, otwarta przestrzeń wymuszająca <span class="text-white">walkę na dystans</span>. Powierzchnie o niskim tarciu drastycznie zmieniają mechanikę poruszania się.
                        </p>
                        <div class="flex flex-wrap gap-3">
                            <span class="px-3 py-1 bg-blue-300/10 border border-blue-300/20 rounded-lg text-[8px] font-black text-blue-300 uppercase tracking-widest">Ice Physics</span>
                            <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[8px] font-black text-white/40 uppercase tracking-widest">Open Field</span>
                        </div>
                    </div>
                </div>

                <div class="group relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[3.5rem] p-10 transition-all hover:border-pink-500/50">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-pink-500/10 blur-[80px] group-hover:bg-pink-500/20 transition-all"></div>
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-8">
                            <div>
                                <span class="text-[10px] font-black text-pink-500 uppercase tracking-widest mb-2 block">Region 04 // Experimental</span>
                                <h4 class="text-4xl font-[1000] italic text-white uppercase tracking-tighter">Rainbow Maze</h4>
                            </div>
                            <span class="text-3xl filter drop-shadow-[0_0_10px_rgba(236,72,153,0.5)]">🌀</span>
                        </div>
                        <p class="text-white/40 text-sm italic leading-relaxed mb-8">
                            Sztuczny, niestabilny labirynt. <span class="text-white">Dynamiczne ściany</span> i ukryte przejścia sprawiają, że orientacja jest trudniejsza niż sama walka. W samym sercu czeka Rainbow Crystal.
                        </p>
                        <div class="flex flex-wrap gap-3">
                            <span class="px-3 py-1 bg-pink-500/10 border border-pink-500/20 rounded-lg text-[8px] font-black text-pink-500 uppercase tracking-widest">Shifting Walls</span>
                            <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[8px] font-black text-white/40 uppercase tracking-widest">Hidden Routes</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>
</Layout>