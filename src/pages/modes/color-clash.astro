---
import Layout from '../../layouts/Layout.astro';
import data from '../../data/color_clash.json';

const { mechanics, gameModes, regions } = data;

const colors = {
    pink: {
        glow: "bg-pink-500/20",
        border: "group-hover:border-pink-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(236,72,153,0.3)]",
        text: "text-pink-400",
        gradient: "from-pink-500/20 to-purple-600/10"
    },
    cyan: {
        glow: "bg-cyan-500/20",
        border: "group-hover:border-cyan-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(34,211,238,0.3)]",
        text: "text-cyan-400",
        gradient: "from-cyan-500/20 to-blue-600/10"
    },
    purple: {
        glow: "bg-purple-500/20",
        border: "group-hover:border-purple-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(168,85,247,0.3)]",
        text: "text-purple-400",
        gradient: "from-purple-500/20 to-pink-600/10"
    },
    orange: {
        glow: "bg-orange-500/20",
        border: "group-hover:border-orange-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(249,115,22,0.3)]",
        text: "text-orange-400",
        gradient: "from-orange-500/20 to-red-600/10"
    },
    blue: {
        glow: "bg-blue-500/20",
        border: "group-hover:border-blue-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(59,130,246,0.3)]",
        text: "text-blue-400",
        gradient: "from-blue-500/20 to-cyan-600/10"
    }
};
---

<Layout title="Color Clash - Tryb Gry">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 pt-28 sm:pt-32 pb-24 md:pb-48 relative">

        {/* --- HEADER --- */}
        <header class="mb-24 md:mb-32 flex flex-col items-center md:items-start relative group">
            <div class="absolute -top-24 -left-24 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-purple-500/20 blur-[100px] md:blur-[150px] animate-pulse pointer-events-none -z-10"></div>
            <div class="absolute bottom-0 -right-24 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-cyan-500/20 blur-[100px] md:blur-[150px] animate-pulse pointer-events-none -z-10" style="animation-delay: 2s;"></div>

            <div class="inline-block px-4 py-1.5 bg-cyan-400/10 border border-cyan-400/20 rounded-full mb-6 animate-fade-in-up">
                <span class="text-[10px] font-black uppercase tracking-[0.4em] text-cyan-400 block leading-none">Spectacle-Driven Mode</span>
            </div>

            <h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-[120px] xl:text-[160px] font-black italic text-white uppercase tracking-tighter leading-[0.9] mb-8 md:mb-12">
                COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 drop-shadow-[0_0_30px_rgba(236,72,153,0.3)] pr-4 md:pr-10">CLASH</span>
            </h1>

            <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-6 w-full sm:w-auto">
                <button class="px-6 py-3 sm:px-8 sm:py-4 md:px-12 md:py-5 bg-white text-black font-black uppercase text-[10px] md:text-xs tracking-widest rounded-2xl hover:scale-110 hover:bg-pink-500 hover:text-white transition-all duration-500 shadow-[0_20px_40px_rgba(255,255,255,0.2)]">
                    Zagraj Teraz
                </button>
                <a href="/#modes" class="px-6 py-3 sm:px-8 sm:py-4 md:px-10 md:py-5 bg-white/5 border border-white/10 text-white font-black uppercase text-[10px] md:text-xs tracking-[0.3em] rounded-2xl backdrop-blur-xl hover:bg-white/10 hover:border-cyan-400/40 transition-all duration-300 hover:scale-105 flex items-center justify-center group/btn">
                    Inne Tryby
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 ml-2 group-hover/btn:translate-x-1 transition-transform text-cyan-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                    </svg>
                </a>
            </div>
        </header>

        {/* --- MECHANICS --- */}
        <section class="mb-24 md:mb-48 relative">
            <div class="absolute top-1/2 left-0 -translate-y-1/2 w-96 h-96 bg-pink-500/10 blur-[120px] animate-pulse pointer-events-none -z-10"></div>

            <div class="mb-10 md:mb-16 flex flex-col items-center md:items-start text-center md:text-left">
                <div class="inline-block px-4 py-1.5 bg-pink-400/10 border border-pink-400/20 rounded-full mb-4">
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-pink-400 block leading-none">Core Systems</span>
                </div>
                <h4 class="text-4xl md:text-6xl lg:text-7xl font-black italic text-white uppercase tracking-tighter leading-[0.9]">
                    Jak to <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4 md:pr-10 drop-shadow-[0_0_30px_rgba(236,72,153,0.3)]">Działa</span>
                </h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
                {mechanics.map((item) => (
                        <div class="group relative flex cursor-pointer transition-transform duration-500 ease-out hover:scale-[1.03] transform-gpu" onclick={`openModal('mechanics', '${item.id}')`}>
                            <div class={`absolute -inset-4 ${colors[item.color].glow} blur-[80px] opacity-0 group-hover:opacity-100 transition-all duration-700 pointer-events-none`}></div>

                            <div class={`relative flex flex-col w-full bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2.5rem] md:rounded-[4rem] p-6 md:p-10 transition-all duration-700 ${colors[item.color].border} ${colors[item.color].shadow}`}>

                                <div class="flex-grow flex flex-col items-center text-center">
                                    <div class={`w-14 h-14 md:w-24 md:h-24 mb-6 md:mb-8 bg-gradient-to-br ${colors[item.color].gradient} border border-white/10 rounded-2xl md:rounded-[2rem] flex items-center justify-center text-2xl md:text-5xl shadow-2xl transition-all duration-500 ease-out group-hover:rotate-12 group-hover:scale-110 group-hover:border-white/30 group-hover:shadow-[0_0_30px_rgba(255,255,255,0.1)]`}>
                                        <span class="group-hover:animate-pulse">{item.icon}</span>
                                    </div>

                                    <h5 class="text-2xl md:text-3xl font-black italic text-white uppercase tracking-tighter mb-4">{item.title}</h5>

                                    <div class="min-h-[80px] flex items-center">
                                        <p class="text-white/60 text-sm md:text-base leading-relaxed font-medium italic border-l-4 border-white/10 pl-4 line-clamp-3">
                                            {item.shortDesc}
                                        </p>
                                    </div>
                                </div>

                                <div class="mt-8 pt-6 border-t border-white/5">
                                    <div class={`text-[10px] font-black uppercase tracking-widest ${colors[item.color].text} opacity-50 group-hover:opacity-100 transition-all duration-300`}>
                                        Technical Specs →
                                    </div>
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </section>

        {/* --- GAME MODES --- */}
        <section class="mb-24 md:mb-48 relative">
            <div class="absolute top-1/2 right-0 -translate-y-1/2 w-96 h-96 bg-purple-500/10 blur-[120px] animate-pulse pointer-events-none -z-10" style="animation-delay: 2s;"></div>

            <div class="mb-10 md:mb-16 flex flex-col items-center md:items-end text-center md:text-right">
                <div class="inline-block px-4 py-1.5 bg-purple-400/10 border border-purple-400/20 rounded-full mb-4">
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-purple-400 block leading-none">Choose Arena</span>
                </div>
                <h4 class="text-4xl md:text-6xl lg:text-7xl font-black italic text-white uppercase tracking-tighter leading-[0.9]">
                    Tryby <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4 md:pr-10 drop-shadow-[0_0_30px_rgba(236,72,153,0.3)]">Starcia</span>
                </h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
                {gameModes.map((mode) => (
                        <div class="group relative flex cursor-pointer transition-transform duration-500 ease-out hover:scale-[1.03] transform-gpu" onclick={`openModal('gameModes', '${mode.id}')`}>
                            <div class={`absolute -inset-2 ${colors[mode.color].glow} blur-[80px] opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none`}></div>

                            <div class={`relative flex flex-col w-full bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2.5rem] md:rounded-[4rem] p-6 md:p-10 transition-all duration-700 ${colors[mode.color].border} ${colors[mode.color].shadow}`}>

                                <div class="flex justify-between items-start mb-6 md:mb-10">
                                    <div class={`w-14 h-14 md:w-24 md:h-24 rounded-2xl md:rounded-[2rem] border border-white/10 bg-white/5 flex items-center justify-center text-2xl md:text-5xl shadow-2xl transition-all duration-500 ease-out group-hover:rotate-12 group-hover:scale-110 group-hover:border-white/30 group-hover:shadow-[0_0_30px_rgba(255,255,255,0.1)]`}>
                                        <span class="group-hover:animate-pulse">{mode.icon}</span>
                                    </div>
                                    <span class={`text-[8px] md:text-[11px] font-black uppercase tracking-[0.3em] py-2 px-4 md:py-3 md:px-6 rounded-xl border border-white/10 shadow-2xl ${colors[mode.color].text} bg-white/5`}>
                                        {mode.tag}
                                    </span>
                                </div>

                                <div class="flex-grow">
                                    <h5 class="text-2xl md:text-3xl font-black italic text-white uppercase tracking-tighter mb-4">{mode.title}</h5>
                                    <div class="min-h-[60px]">
                                        <p class="text-white/60 text-sm md:text-base leading-relaxed font-medium italic border-l-4 border-white/10 pl-4 line-clamp-3">{mode.shortDesc}</p>
                                    </div>
                                </div>

                                <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between opacity-30 group-hover:opacity-100 transition-opacity duration-300">
                                    <span class="text-[10px] font-black uppercase tracking-widest">Meta & Rules</span>
                                    <span>→</span>
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </section>

        {/* --- REGIONS GRID (2 kolumny na desktopie) --- */}
        <section class="mb-24 md:mb-48 relative">
            <div class="absolute top-1/4 left-0 w-96 h-96 bg-cyan-500/10 blur-[120px] animate-pulse pointer-events-none -z-10"></div>
            <div class="absolute bottom-1/4 right-0 w-96 h-96 bg-purple-500/10 blur-[120px] animate-pulse pointer-events-none -z-10" style="animation-delay: 2s;"></div>

            <div class="mb-10 md:mb-16 flex flex-col items-center md:items-start text-center md:text-left">
                <div class="inline-block px-4 py-1.5 bg-cyan-400/10 border border-cyan-400/20 rounded-full mb-4">
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-cyan-400 block leading-none">World Atlas</span>
                </div>
                <h4 class="text-4xl md:text-6xl lg:text-7xl font-black italic text-white uppercase tracking-tighter leading-[0.9]">
                    Chromatic <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4 md:pr-10 drop-shadow-[0_0_30px_rgba(236,72,153,0.3)]">Regions</span>
                </h4>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-stretch">
                {regions.map((region) => (
                        <div class="group relative flex cursor-pointer transition-transform duration-500 ease-out hover:scale-[1.03] transform-gpu" onclick={`openModal('regions', '${region.id}')`}>
                            <div class={`absolute -inset-6 bg-gradient-to-br ${colors[region.color].gradient} blur-[80px] opacity-0 group-hover:opacity-40 transition-all duration-700 pointer-events-none`}></div>

                            <div class={`relative flex flex-col w-full bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2.5rem] md:rounded-[4rem] p-6 md:p-14 transition-all duration-700 ${colors[region.color].border} ${colors[region.color].shadow}`}>

                                <div class="flex flex-col items-center mb-10 md:mb-12 relative">
                                    <div class="absolute top-0 right-0 flex flex-col items-end gap-2">
                                        <div class="bg-white text-black px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-xl">
                                            {region.subtitle.split('//')[0]}
                                        </div>
                                        <div class="flex items-center gap-2 mr-2">
                                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></span>
                                            <span class="text-[8px] font-black text-white/40 uppercase tracking-widest">Available</span>
                                        </div>
                                    </div>

                                    <div class={`w-24 h-24 md:w-44 md:h-44 bg-gradient-to-br ${colors[region.color].gradient} border border-white/10 rounded-2xl md:rounded-[3rem] flex items-center justify-center text-4xl md:text-7xl shadow-2xl transition-all duration-500 ease-out group-hover:rotate-6 group-hover:scale-105 group-hover:border-white/30 group-hover:shadow-[0_0_30px_rgba(255,255,255,0.1)]`}>
                                        <span class="group-hover:animate-pulse">{region.icon}</span>
                                    </div>
                                </div>

                                <div class="flex flex-col flex-grow items-center text-center">
                                    <h4 class="text-3xl md:text-5xl lg:text-6xl font-black italic text-white uppercase tracking-tighter mb-4 md:mb-6 leading-none">
                                        {region.title.split(' ')[0]} <span class={`${colors[region.color].text}`}>{region.title.split(' ')[1] || ''}</span>
                                    </h4>

                                    <div class="min-h-[70px] flex items-center justify-center">
                                        <p class="text-white/60 text-sm md:text-lg font-medium italic border-l-4 border-white/10 px-4 md:px-6 line-clamp-2 leading-relaxed">
                                            {region.shortDesc}
                                        </p>
                                    </div>
                                </div>

                                <button class="mt-8 md:mt-10 w-full py-4 md:py-5 bg-white/5 border border-white/10 rounded-2xl font-black uppercase text-[10px] tracking-[0.2em] text-white/50 hover:bg-white hover:text-black transition-all duration-500">
                                    Eksploruj Dane Regionu
                                </button>
                            </div>
                        </div>
                ))}
            </div>
        </section>

    </div>

    {/* ======================== MODAL ======================== */}
    {/* Overlay */}
    <div id="info-modal" class="fixed inset-0 z-[200] opacity-0 pointer-events-none transition-opacity duration-500">
        <div class="absolute inset-0 bg-[#050505]/80 backdrop-blur-xl" onclick="closeModal()"></div>

        {/* --- MOBILE: bottom sheet (tylko <md) --- */}
        <div id="modal-mobile" class="md:hidden absolute bottom-0 left-0 right-0 translate-y-full transition-transform duration-500 ease-out">
            {/* Ambient glow */}
            <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-80 h-40 bg-pink-500/20 blur-[80px] pointer-events-none" id="mob-glow"></div>

            <div id="modal-inner-mobile" class="relative bg-gradient-to-br from-white/[0.07] to-white/[0.02] backdrop-blur-3xl border-t border-x border-white/10 rounded-t-[2.5rem] overflow-hidden shadow-[0_-20px_60px_rgba(0,0,0,0.6)]">
                {/* Linia gradientowa u góry */}
                <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/40 to-transparent"></div>

                {/* Uchwyt do przeciągania */}
                <div class="flex justify-center pt-3 pb-1">
                    <div class="w-10 h-1 bg-white/20 rounded-full"></div>
                </div>

                {/* Header */}
                <div class="flex items-center justify-between px-5 pt-2 pb-4">
                    <div class="px-3 py-1 bg-cyan-400/10 border border-cyan-400/20 rounded-full">
                        <span id="mob-tag" class="text-[8px] font-black text-cyan-400 uppercase tracking-[0.25em] block leading-none">Info</span>
                    </div>
                    <button onclick="closeModal()" class="w-8 h-8 flex items-center justify-center bg-white/5 border border-white/10 text-white/50 rounded-xl active:scale-90 transition-all duration-200">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                {/* Content — scrollable */}
                <div class="overflow-y-auto max-h-[65vh] px-5 pb-8 flex flex-col gap-5">

                    {/* Ikona + Tytuł w rzędzie */}
                    <div class="flex items-center gap-4">
                        <div id="mob-icon-box" class="shrink-0 w-14 h-14 bg-gradient-to-br from-pink-500/20 to-purple-600/10 border border-white/10 rounded-2xl flex items-center justify-center text-2xl shadow-xl">
                            <span id="mob-icon">🎨</span>
                        </div>
                        <div>
                            <h2 id="mob-title" class="text-2xl font-black italic text-white uppercase tracking-tighter leading-none mb-1">Tytuł</h2>
                            <p id="mob-subtitle" class="text-pink-400 font-black text-[9px] uppercase tracking-[0.2em]">Kategoria</p>
                        </div>
                    </div>

                    {/* Opis */}
                    <p id="mob-desc" class="text-white/60 text-sm leading-relaxed font-medium italic border-l-4 border-white/10 pl-4">Opis...</p>

                    {/* Media */}
                    <div id="mob-media" class="w-full aspect-video rounded-2xl overflow-hidden border border-white/10 bg-black/40 hidden"></div>

                    {/* Tech specs */}
                    <div id="mob-specs" class="grid grid-cols-2 gap-2 pt-4 border-t border-white/5"></div>
                </div>
            </div>
        </div>

        {/* --- DESKTOP: wycentrowana karta (md+) --- */}
        <div id="modal-desktop" class="hidden md:flex absolute inset-0 items-center justify-center p-6 lg:p-8">
            <div id="modal-card-desktop" class="relative w-full max-w-2xl scale-95 transition-transform duration-500 ease-out">
                {/* Ambient glow */}
                <div class="absolute -top-24 -left-24 w-96 h-96 bg-gradient-to-br from-pink-500/20 via-purple-500/10 to-transparent blur-[100px] opacity-0 transition-all duration-700 pointer-events-none" id="desk-glow-1"></div>
                <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-gradient-to-br from-cyan-500/20 via-blue-500/10 to-transparent blur-[100px] opacity-0 transition-all duration-700 pointer-events-none" id="desk-glow-2"></div>

                <div id="modal-inner-desktop" class="relative bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2.5rem] lg:rounded-[3.5rem] shadow-[0_0_80px_rgba(0,0,0,0.5)] overflow-hidden transition-all duration-700">
                    {/* Linia gradientowa u góry */}
                    <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/40 to-transparent"></div>

                    {/* Header */}
                    <div class="flex items-center justify-between px-8 pt-8 pb-6 border-b border-white/5">
                        <div class="px-4 py-1.5 bg-cyan-400/10 border border-cyan-400/20 rounded-full">
                            <span id="desk-tag" class="text-[10px] font-black text-cyan-400 uppercase tracking-[0.3em] block leading-none">Info // System</span>
                        </div>
                        <button onclick="closeModal()" class="w-9 h-9 flex items-center justify-center bg-white/5 border border-white/10 text-white/50 rounded-xl hover:bg-white/10 hover:text-white hover:border-white/20 transition-all duration-300">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>

                    {/* Body */}
                    <div class="p-8 flex flex-col gap-8">
                        {/* Ikona + Tytuł */}
                        <div class="flex items-start gap-6">
                            <div id="desk-icon-box" class="shrink-0 w-20 h-20 bg-gradient-to-br from-pink-500/20 to-purple-600/10 border border-white/10 rounded-[1.5rem] flex items-center justify-center text-4xl shadow-2xl">
                                <span id="desk-icon">🎨</span>
                            </div>
                            <div class="flex flex-col justify-center">
                                <h2 id="desk-title" class="text-4xl lg:text-5xl font-black italic text-white uppercase tracking-tighter leading-none mb-2">Tytuł</h2>
                                <p id="desk-subtitle" class="text-pink-400 font-black text-xs uppercase tracking-[0.3em]">Kategoria // ID</p>
                            </div>
                        </div>

                        {/* Media */}
                        <div id="desk-media" class="w-full aspect-video rounded-2xl overflow-hidden border border-white/10 bg-black/40 hidden"></div>

                        {/* Opis */}
                        <p id="desk-desc" class="text-white/60 text-base leading-relaxed font-medium italic border-l-4 border-white/10 pl-6">Opis...</p>

                        {/* Tech specs */}
                        <div id="desk-specs" class="grid grid-cols-3 gap-3 pt-6 border-t border-white/5"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fade-in-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
</style>

<script is:inline define:vars={{ mechanics, gameModes, regions }}>
    const colorMap = {
        pink:   { gradient: 'from-pink-500/20 to-purple-600/10', text: 'text-pink-400', border: 'border-pink-500/30', glow: 'bg-pink-500/25' },
        cyan:   { gradient: 'from-cyan-500/20 to-blue-600/10',   text: 'text-cyan-400', border: 'border-cyan-500/30', glow: 'bg-cyan-500/25' },
        purple: { gradient: 'from-purple-500/20 to-pink-600/10', text: 'text-purple-400', border: 'border-purple-500/30', glow: 'bg-purple-500/25' },
        orange: { gradient: 'from-orange-500/20 to-red-600/10',  text: 'text-orange-400', border: 'border-orange-500/30', glow: 'bg-orange-500/25' },
        blue:   { gradient: 'from-blue-500/20 to-cyan-600/10',   text: 'text-blue-400', border: 'border-blue-500/30', glow: 'bg-blue-500/25' }
    };

    const categoryLabels = { mechanics: 'Mechanika', gameModes: 'Tryb Gry', regions: 'Region' };

    function buildSpecsHTML(item, c) {
        if (!item.technical) return '';
        return Object.entries(item.technical).map(([key, value]) => `
            <div class="flex flex-col gap-1 p-3 bg-white/5 border border-white/5 rounded-2xl">
                <span class="text-[8px] font-black text-white/30 uppercase tracking-[0.2em]">${key}</span>
                <span class="text-[10px] font-black ${c.text} italic uppercase tracking-tight leading-tight">${value}</span>
            </div>`).join('');
    }

    function buildMediaHTML(item) {
        if (!item.media?.url) return null;
        if (item.media.type === 'video')
            return `<video autoplay loop muted playsinline class="w-full h-full object-cover"><source src="${item.media.url}" type="video/mp4"></video>`;
        return `<img src="${item.media.url}" class="w-full h-full object-cover" alt="${item.title}" />`;
    }

    window.openModal = function(category, id) {
        const dataset = { mechanics, gameModes, regions }[category];
        const item = dataset.find(i => i.id === id);
        if (!item) return;

        const c = colorMap[item.color] || colorMap.cyan;
        const label = categoryLabels[category] || category;
        const tagText = label.toUpperCase() + ' // ' + item.id.toUpperCase().replace(/-/g, ' ');
        const mediaHTML = buildMediaHTML(item);
        const specsHTML = buildSpecsHTML(item, c);

        // --- Wypełnienie MOBILE ---
        document.getElementById('mob-tag').innerText = tagText;
        document.getElementById('mob-icon').innerText = item.icon;
        const mobIconBox = document.getElementById('mob-icon-box');
        mobIconBox.className = `shrink-0 w-14 h-14 bg-gradient-to-br ${c.gradient} border border-white/10 rounded-2xl flex items-center justify-center text-2xl shadow-xl`;
        document.getElementById('mob-title').innerText = item.title;
        const mobSub = document.getElementById('mob-subtitle');
        mobSub.innerText = label + ' // ' + item.title;
        mobSub.className = `${c.text} font-black text-[9px] uppercase tracking-[0.2em]`;
        document.getElementById('mob-desc').innerText = item.longDesc;
        const mobMedia = document.getElementById('mob-media');
        if (mediaHTML) { mobMedia.innerHTML = mediaHTML; mobMedia.classList.remove('hidden'); }
        else { mobMedia.innerHTML = ''; mobMedia.classList.add('hidden'); }
        document.getElementById('mob-specs').innerHTML = specsHTML;
        // Glow kolor mobile
        const mobGlow = document.getElementById('mob-glow');
        mobGlow.className = `absolute -top-20 left-1/2 -translate-x-1/2 w-80 h-40 ${c.glow} blur-[80px] pointer-events-none`;
        // Border mobile
        const innerMob = document.getElementById('modal-inner-mobile');
        innerMob.className = innerMob.className.replace(/border-[a-z]+-\d+\/\d+\s?/g, '');
        innerMob.classList.add(c.border);

        // --- Wypełnienie DESKTOP ---
        document.getElementById('desk-tag').innerText = tagText;
        document.getElementById('desk-icon').innerText = item.icon;
        const deskIconBox = document.getElementById('desk-icon-box');
        deskIconBox.className = `shrink-0 w-20 h-20 bg-gradient-to-br ${c.gradient} border border-white/10 rounded-[1.5rem] flex items-center justify-center text-4xl shadow-2xl`;
        document.getElementById('desk-title').innerText = item.title;
        const deskSub = document.getElementById('desk-subtitle');
        deskSub.innerText = label + ' // ' + item.title;
        deskSub.className = `${c.text} font-black text-xs uppercase tracking-[0.3em]`;
        document.getElementById('desk-desc').innerText = item.longDesc;
        const deskMedia = document.getElementById('desk-media');
        if (mediaHTML) { deskMedia.innerHTML = mediaHTML; deskMedia.classList.remove('hidden'); }
        else { deskMedia.innerHTML = ''; deskMedia.classList.add('hidden'); }
        document.getElementById('desk-specs').innerHTML = specsHTML;
        // Glow desktop
        const deskG1 = document.getElementById('desk-glow-1');
        const deskG2 = document.getElementById('desk-glow-2');
        deskG1.className = `absolute -top-24 -left-24 w-96 h-96 bg-gradient-to-br ${c.gradient} blur-[100px] opacity-60 transition-all duration-700 pointer-events-none`;
        deskG2.className = `absolute -bottom-24 -right-24 w-96 h-96 bg-gradient-to-br ${c.gradient} blur-[100px] opacity-40 transition-all duration-700 pointer-events-none`;
        // Border desktop
        const innerDesk = document.getElementById('modal-inner-desktop');
        innerDesk.className = innerDesk.className.replace(/border-[a-z]+-\d+\/\d+/g, 'border-white/10');
        innerDesk.classList.add(c.border);

        // --- Pokaż overlay ---
        const modal = document.getElementById('info-modal');
        modal.classList.remove('opacity-0', 'pointer-events-none');

        // Mobile: wysuń z dołu
        const mobSheet = document.getElementById('modal-mobile');
        mobSheet.classList.remove('translate-y-full');
        mobSheet.classList.add('translate-y-0');

        // Desktop: scale in
        const deskCard = document.getElementById('modal-card-desktop');
        deskCard.classList.remove('scale-95');
        deskCard.classList.add('scale-100');

        document.body.style.overflow = 'hidden';
    };

    window.closeModal = function() {
        const modal = document.getElementById('info-modal');
        modal.classList.add('opacity-0', 'pointer-events-none');

        const mobSheet = document.getElementById('modal-mobile');
        mobSheet.classList.remove('translate-y-0');
        mobSheet.classList.add('translate-y-full');

        const deskCard = document.getElementById('modal-card-desktop');
        deskCard.classList.remove('scale-100');
        deskCard.classList.add('scale-95');

        document.body.style.overflow = '';
        modal.querySelectorAll('video').forEach(v => v.pause());
    };

    window.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>