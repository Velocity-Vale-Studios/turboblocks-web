---
import Layout from '../../layouts/Layout.astro';
import data from '../../data/color_clash.json';

const { mechanics, gameModes, regions } = data;

const colors = {
    pink: {
        glow: "bg-pink-500/20",
        border: "group-hover:border-pink-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(236,72,153,0.3)]",
        text: "text-pink-400",
        gradient: "from-pink-500/20 to-purple-600/10"
    },
    cyan: {
        glow: "bg-cyan-500/20",
        border: "group-hover:border-cyan-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(34,211,238,0.3)]",
        text: "text-cyan-400",
        gradient: "from-cyan-500/20 to-blue-600/10"
    },
    purple: {
        glow: "bg-purple-500/20",
        border: "group-hover:border-purple-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(168,85,247,0.3)]",
        text: "text-purple-400",
        gradient: "from-purple-500/20 to-pink-600/10"
    },
    orange: {
        glow: "bg-orange-500/20",
        border: "group-hover:border-orange-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(249,115,22,0.3)]",
        text: "text-orange-400",
        gradient: "from-orange-500/20 to-red-600/10"
    },
    blue: {
        glow: "bg-blue-500/20",
        border: "group-hover:border-blue-500/50",
        shadow: "group-hover:shadow-[0_0_50px_rgba(59,130,246,0.3)]",
        text: "text-blue-400",
        gradient: "from-blue-500/20 to-cyan-600/10"
    }
};
---

<Layout title="Color Clash - Tryb Gry">
    <main class="max-w-7xl mx-auto px-6 md:px-12 pt-32 pb-48 relative overflow-visible">

        {/* --- HEADER --- */}
        <header class="mb-32 flex flex-col items-center md:items-start relative group">
            <div class="absolute -top-32 -left-20 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-purple-500/20 blur-[150px] -z-10 animate-pulse"></div>

            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-6 drop-shadow-[0_0_10px_rgba(34,211,238,0.5)]">Spectacle-Driven Mode</h2>

            <h1 class="text-[clamp(4rem,12vw,10rem)] font-black italic text-white uppercase tracking-tighter leading-[0.85] mb-12">
                COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4 md:pr-10">CLASH</span>
            </h1>

            <div class="flex flex-wrap gap-6">
                <button class="px-12 py-5 bg-white text-black font-black uppercase text-[10px] tracking-widest rounded-2xl hover:scale-110 hover:bg-pink-500 hover:text-white transition-all duration-500 shadow-[0_0_30px_rgba(255,255,255,0.2)] hover:shadow-pink-500/50">
                    Zagraj Teraz
                </button>
            </div>
        </header>

        {/* --- MECHANICS: Każdy kafelek to 'elektrownia' --- */}
        <section class="mb-48">
            <div class="mb-16">
                <h3 class="text-[10px] font-black uppercase tracking-[0.5em] text-pink-400 mb-4">Core Systems</h3>
                <h4 class="text-5xl md:text-7xl font-black italic text-white uppercase tracking-tighter">Jak to <span class="text-pink-400">Działa</span></h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
                {mechanics.map((item) => (
                        <div class="group relative flex cursor-pointer" onclick={`openModal('mechanics', '${item.id}')`}>
                            <div class={`absolute -inset-4 ${colors[item.color].glow} blur-[60px] opacity-0 group-hover:opacity-100 transition-all duration-700`}></div>

                            <div class={`relative flex flex-col w-full bg-[#121212]/80 backdrop-blur-3xl border border-white/10 rounded-[3rem] p-10 transition-all duration-700 ${colors[item.color].border} ${colors[item.color].shadow} group-hover:-translate-y-4`}>

                                <div class="flex-grow flex flex-col items-center text-center">
                                    <div class={`w-24 h-24 mb-8 bg-gradient-to-br ${colors[item.color].gradient} border border-white/10 rounded-2xl flex items-center justify-center text-5xl shadow-2xl transition-transform duration-500 group-hover:rotate-12`}>
                                        {item.icon}
                                    </div>

                                    <h5 class="text-3xl font-black italic text-white uppercase tracking-tighter mb-4">{item.title}</h5>

                                    <div class="min-h-[80px] flex items-center">
                                        <p class="text-white/40 text-sm leading-relaxed italic border-l-2 border-white/10 pl-4 line-clamp-3">
                                            {item.shortDesc}
                                        </p>
                                    </div>
                                </div>

                                <div class="mt-8 pt-6 border-t border-white/5">
                                    <div class={`text-[10px] font-black uppercase tracking-widest ${colors[item.color].text} opacity-50 group-hover:opacity-100 transition-all`}>
                                        Technical Specs →
                                    </div>
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </section>

        {/* --- GAME MODES --- */}
        <section class="mb-48">
            <div class="mb-16 md:text-right">
                <h3 class="text-[10px] font-black uppercase tracking-[0.5em] text-purple-400 mb-4">Choose Arena</h3>
                <h4 class="text-5xl md:text-7xl font-black italic text-white uppercase tracking-tighter">Tryby <span class="text-purple-400">Starcia</span></h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
                {gameModes.map((mode) => (
                        <div class="group relative flex cursor-pointer" onclick={`openModal('gameModes', '${mode.id}')`}>
                            <div class={`absolute -inset-2 ${colors[mode.color].glow} blur-[40px] opacity-0 group-hover:opacity-100 transition-opacity`}></div>

                            <div class={`relative flex flex-col w-full bg-black/40 backdrop-blur-3xl border border-white/10 rounded-[2.5rem] p-10 transition-all duration-500 ${colors[mode.color].border}`}>

                                <div class="flex justify-between items-start mb-10">
                                    <div class="text-6xl group-hover:scale-110 transition-transform">{mode.icon}</div>
                                    {/* KOLOROWY BADGE */}
                                    <span class={`px-4 py-2 bg-white/5 border ${colors[mode.color].border.replace('group-hover:', '')} rounded-xl text-[10px] font-black ${colors[mode.color].text} uppercase tracking-widest`}>
                            {mode.tag}
                        </span>
                                </div>

                                <div class="flex-grow">
                                    <h5 class="text-3xl font-black italic text-white uppercase tracking-tighter mb-4">{mode.title}</h5>
                                    <div class="min-h-[60px]">
                                        <p class="text-white/40 text-sm leading-relaxed line-clamp-3">{mode.shortDesc}</p>
                                    </div>
                                </div>

                                <div class="mt-8 flex items-center justify-between opacity-30 group-hover:opacity-100 transition-opacity">
                                    <span class="text-[9px] font-black uppercase tracking-widest">Meta & Rules</span>
                                    <span>→</span>
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </section>

        {/* --- REGIONS GRID (2 kolumny na desktopie) --- */}
        <section class="mb-48">
            <div class="mb-16">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">World Atlas</h2>
                <h3 class="text-6xl md:text-8xl font-black italic text-white uppercase tracking-tighter">Chromatic <span class="text-cyan-400">Regions</span></h3>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
                {regions.map((region) => (
                        <div class="group relative flex cursor-pointer" onclick={`openModal('regions', '${region.id}')`}>
                            <div class={`absolute -inset-6 bg-gradient-to-br ${colors[region.color].gradient} blur-[80px] opacity-0 group-hover:opacity-40 transition-all duration-1000`}></div>

                            <div class={`relative flex flex-col w-full bg-[#121212]/90 backdrop-blur-3xl border border-white/5 rounded-[3.5rem] p-10 md:p-14 transition-all duration-700 hover:border-white/20 hover:-translate-y-2 ${colors[region.color].shadow}`}>

                                <div class="flex flex-col items-center mb-12 relative">
                                    <div class="absolute top-0 right-0 flex flex-col items-end gap-2">
                                        <div class="bg-white text-black px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-xl">
                                            {region.subtitle.split('//')[0]}
                                        </div>
                                        <div class="flex items-center gap-2 mr-2">
                                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                                            <span class="text-[8px] font-black text-white/40 uppercase tracking-widest">Available</span>
                                        </div>
                                    </div>

                                    <div class={`w-44 h-44 bg-gradient-to-br ${colors[region.color].gradient} border border-white/10 rounded-[3rem] flex items-center justify-center text-7xl shadow-2xl transition-transform duration-700 group-hover:rotate-6 group-hover:scale-105`}>
                                        {region.icon}
                                    </div>
                                </div>

                                <div class="flex flex-col flex-grow items-center text-center">
                                    <h4 class="text-5xl md:text-7xl font-black italic text-white uppercase tracking-tighter mb-6 leading-none">
                                        {region.title.split(' ')[0]} <span class={`${colors[region.color].text}`}>{region.title.split(' ')[1] || ''}</span>
                                    </h4>

                                    <div class="min-h-[70px] flex items-center justify-center">
                                        <p class="text-white/40 text-lg font-medium italic border-l-2 border-white/10 px-6 line-clamp-2">
                                            {region.shortDesc}
                                        </p>
                                    </div>
                                </div>

                                <button class="mt-10 w-full py-5 bg-white/5 border border-white/10 rounded-2xl font-black uppercase text-[10px] tracking-[0.2em] text-white/50 hover:bg-white hover:text-black transition-all duration-500">
                                    Eksploruj Dane Regionu
                                </button>
                            </div>
                        </div>
                ))}
            </div>
        </section>

    </main>

    <div id="info-modal" class="fixed inset-0 z-[200] flex items-center justify-center p-4 md:p-12 opacity-0 pointer-events-none transition-all duration-500">
        <div class="absolute inset-0 bg-[#050505]/90 backdrop-blur-2xl" onclick="closeModal()"></div>

        <div class="relative w-full max-w-6xl -m-6 md:-m-12 p-6 md:p-12 transform scale-90 transition-all duration-500" id="modal-card">
            <div class="absolute inset-0 bg-gradient-to-r from-pink-500/30 to-purple-600/30 blur-[80px] md:blur-[120px] rounded-[4rem] opacity-0 transition-opacity duration-700" id="modal-glow"></div>

            <div class="relative bg-gradient-to-br from-white/10 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2.5rem] md:rounded-[4rem] overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.5)]">
                <div class="flex flex-col lg:flex-row items-stretch min-h-[500px] lg:h-[700px]">

                    {/* LEWA STRONA: MEDIA */}
                    <div class="w-full lg:w-1/2 min-h-[300px] lg:h-full bg-black/40 relative group/media overflow-hidden border-b lg:border-b-0 lg:border-r border-white/10">
                        <div id="modal-media-container" class="w-full h-full flex items-center justify-center overflow-hidden">
                            {/* Wstrzykiwane przez JS */}
                        </div>
                        <div class="absolute inset-0 shadow-[inset_0_0_60px_rgba(0,0,0,0.8)] pointer-events-none"></div>
                    </div>

                    {/* PRAWA STRONA: TREŚĆ */}
                    <div class="w-full lg:w-1/2 p-8 md:p-14 flex flex-col relative bg-[#0a0a0a]/40">
                        <button onclick="closeModal()" class="absolute top-8 right-8 bg-white text-black px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-pink-500 hover:text-white transition-all duration-300 shadow-xl z-50">
                            ZAMKNIJ [X]
                        </button>

                        <div class="flex flex-col h-full">
                            <div class="flex items-center gap-4 mb-8">
                                <span id="modal-tag" class="text-orange-400 font-black text-[10px] uppercase tracking-[0.3em] drop-shadow-[0_0_10px_rgba(251,146,60,0.5)]">TECHNICAL // DOCS</span>
                                <div class="w-1.5 h-1.5 bg-white/20 rounded-full"></div>
                                <span class="text-white/40 font-black text-[8px] uppercase tracking-[0.3em]">System Active</span>
                            </div>

                            <div class="flex-grow">
                                <h2 id="modal-title" class="text-4xl md:text-7xl font-[1000] italic text-white uppercase tracking-tighter leading-[0.85] mb-8">
                                    TITLE
                                </h2>
                                <p id="modal-long-desc" class="text-white/60 text-base md:text-lg leading-relaxed font-medium italic border-l-4 border-white/10 pl-6 line-clamp-[8] lg:line-clamp-none">
                                    Description...
                                </p>
                            </div>

                            {/* Tu wylądują specyfikacje z JSON */}
                            <div id="modal-tech-specs" class="grid grid-cols-2 gap-6 mt-12 pt-8 border-t border-white/5">
                                {/* Wstrzykiwane przez JS */}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style is:global>
    body {
        background-color: #050505;
        color: white;
    }

    /* Dodajemy ziarnistość dla "życia" tła */
    body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image: url('https://grainy-gradients.vercel.app/noise.svg');
        opacity: 0.05;
        pointer-events: none;
        z-index: 50;
    }
</style>

<script is:inline define:vars={{ mechanics, gameModes, regions }}>
    // Funkcja otwierająca
    window.openModal = function(category, id) {
        const modal = document.getElementById('info-modal');
        const card = document.getElementById('modal-card');
        document.getElementById('modal-glow').classList.remove('opacity-0');
        document.getElementById('modal-glow').classList.add('opacity-100');

        // Wybieramy odpowiedni zestaw danych
        const dataset = { mechanics, gameModes, regions }[category];
        const item = dataset.find(i => i.id === id);

        if (!item) return;

        // 1. Wstrzykujemy tekst
        document.getElementById('modal-title').innerHTML = item.title;
        document.getElementById('modal-long-desc').innerText = item.longDesc;
        document.getElementById('modal-tag').innerText = category.toUpperCase() + " // SYSTEM ID: " + item.id;

        // 2. Obsługa Mediów (Wideo / Obraz)
        const mediaContainer = document.getElementById('modal-media-container');
        mediaContainer.innerHTML = ''; // Czyścimy poprzednie

        if (item.media?.type === 'video') {
            mediaContainer.innerHTML = `
                <video autoplay loop muted playsinline class="w-full h-full object-cover">
                    <source src="${item.media.url}" type="video/mp4">
                </video>`;
        } else if (item.media?.url) {
            mediaContainer.innerHTML = `
                <img src="${item.media.url}" class="w-full h-full object-cover shadow-2xl scale-110" alt="${item.title}" />`;
        } else {
            mediaContainer.innerHTML = `<span class="text-9xl opacity-20">${item.icon}</span>`;
        }

        // 3. Obsługa detali technicznych (jeśli istnieją w JSON)
        const specsContainer = document.getElementById('modal-tech-specs');
        specsContainer.innerHTML = '';

        if (item.technical) {
            Object.entries(item.technical).forEach(([key, value]) => {
                specsContainer.innerHTML += `
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-[10px] font-black text-white/20 uppercase tracking-widest">${key}</span>
                        <span class="text-xs font-bold text-white italic uppercase">${value}</span>
                    </div>`;
            });
        }

        // 4. Animacja wejścia
        modal.classList.remove('opacity-0', 'pointer-events-none');
        card.classList.remove('scale-95');
        card.classList.add('scale-100');
        document.body.style.overflow = 'hidden'; // Blokada scrolla strony
    }

    window.closeModal = function() {
        const modal = document.getElementById('info-modal');
        const card = document.getElementById('modal-card');

        modal.classList.add('opacity-0', 'pointer-events-none');
        card.classList.remove('scale-100');
        card.classList.add('scale-95');
        document.body.style.overflow = ''; // Przywrócenie scrolla

        // Zatrzymanie wideo po zamknięciu
        const video = modal.querySelector('video');
        if (video) video.pause();
    }

    // Obsługa ESC
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
    });
</script>