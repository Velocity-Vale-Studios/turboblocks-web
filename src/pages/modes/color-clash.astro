---
import Layout from '../../layouts/Layout.astro';


---

<Layout title="Color Clash - Tryb Gry">
    <main class="max-w-7xl mx-auto px-8 pt-[140px] pb-24">

        {/* HEADER SECTION - Matches Shop/Home style */}
        <div class="mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-20 -left-20 w-96 h-96 bg-pink-500/20 blur-[150px] -z-10 animate-pulse"></div>
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">Spectacle-Driven Mode</h2>
            <h1 class="text-7xl md:text-9xl font-black italic text-white uppercase tracking-tighter leading-none md:pr-12 mb-8">
                COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-400 pr-4">CLASH</span>
            </h1>

            <div class="flex flex-wrap justify-center md:justify-start gap-4">
                 <button class="px-8 py-4 bg-white text-black font-black uppercase text-xs tracking-widest rounded-2xl hover:bg-cyan-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_40px_rgba(34,211,238,0.5)]">
                    Zagraj Teraz
                </button>
                <div class="px-8 py-4 bg-white/5 border border-white/10 text-white/60 font-black uppercase text-xs tracking-widest rounded-2xl backdrop-blur-md flex items-center gap-3">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></span>
                    LIVE NOW
                </div>
            </div>
        </div>

        {/* HERO CARD - BIG DESCRIPTION */}
        <section class="mb-32">
            <div class="relative rounded-[3.5rem] p-12 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-pink-500/20 shadow-[0_0_60px_rgba(236,72,153,0.15)] group transition-all duration-700 hover:border-pink-500/40">
                <div class="absolute inset-0 bg-gradient-to-br from-pink-500/10 via-purple-500/5 to-transparent opacity-20 group-hover:opacity-40 transition-opacity duration-700"></div>

                <div class="relative z-10 flex flex-col md:flex-row gap-12 items-center">
                    <div class="flex-1">
                        <h2 class="text-3xl md:text-5xl font-black italic text-white uppercase tracking-tighter leading-tight mb-8">
                            "Mapa zapamięta, kto był <span class="text-pink-400">najsilniejszy</span>."
                        </h2>
                        <p class="text-white/50 text-lg font-medium leading-relaxed mb-8">
                            W Color Clash kolor to nie tylko kosmetyka – to Twoja broń, tożsamość i energia.
                            Sankcjonowane konflikty wokół stref bogatych w energię chromatyczną. Nie jesteś żołnierzem – jesteś pretendentem w publicznym widowisku.
                        </p>
                        <div class="flex items-center gap-4">
                             <div class="bg-black/30 px-6 py-3 rounded-xl border border-white/5">
                                <span class="text-[9px] font-black text-white/30 uppercase tracking-widest block mb-1">Players</span>
                                <span class="text-white font-black italic text-xl uppercase">UP TO 16</span>
                             </div>
                             <div class="bg-black/30 px-6 py-3 rounded-xl border border-white/5">
                                <span class="text-[9px] font-black text-white/30 uppercase tracking-widest block mb-1">Duration</span>
                                <span class="text-white font-black italic text-xl uppercase">8-15 MIN</span>
                             </div>
                        </div>
                    </div>
                     <div class="w-full md:w-1/3 aspect-square bg-gradient-to-br from-pink-500/20 to-purple-500/20 rounded-[2.5rem] border border-white/10 flex items-center justify-center relative overflow-hidden group/icon">
                        <div class="absolute inset-0 blur-3xl bg-pink-500/20 group-hover/icon:bg-pink-500/30 transition-all"></div>
                        <div class="text-9xl filter drop-shadow-[0_0_30px_rgba(236,72,153,0.5)] group-hover/icon:scale-110 transition-transform duration-500">🎨</div>
                    </div>
                </div>
            </div>
        </section>

        {/* MECHANICS GRID */}
        <section class="mb-32">
             <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">Core Mechanics</h2>
                <h3 class="text-5xl font-black italic text-white uppercase tracking-tighter">How to <span class="text-pink-400">Win</span></h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {[
                    { title: "Paint as Power", icon: "💥", desc: "Każda pomalowana powierzchnia to przejęta energia, która karmi Twój wynik.", color: "pink", shadow: "hover:shadow-[0_0_40px_rgba(236,72,153,0.15)]", border: "hover:border-pink-500/40" },
                    { title: "Combo Flow", icon: "⚡", desc: "Utrzymuj rytm malowania bez eliminacji, aby wejść w stan Flow i zwiększyć mnożnik.", color: "cyan", shadow: "hover:shadow-[0_0_40px_rgba(34,211,238,0.15)]", border: "hover:border-cyan-500/40" },
                    { title: "Chromatic Overload", icon: "🌀", desc: "Rozpłyń się w cząsteczkach własnego koloru. Momentum jest ważniejsze niż przetrwanie.", color: "purple", shadow: "hover:shadow-[0_0_40px_rgba(168,85,247,0.15)]", border: "hover:border-purple-500/40" }
                ].map(item => (
                    <div class={`group relative bg-white/[0.02] border border-white/10 backdrop-blur-md rounded-[2.5rem] p-8 hover:-translate-y-1 transition-all duration-500 ${item.border} ${item.shadow} overflow-hidden`}>
                         <div class={`absolute inset-0 bg-gradient-to-br from-${item.color}-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>

                         <div class="relative z-10">
                            <div class="text-5xl mb-6 filter drop-shadow-lg group-hover:scale-105 transition-all duration-300 transform origin-left">{item.icon}</div>
                            <h4 class="text-2xl font-black italic text-white uppercase tracking-tighter mb-4">{item.title}</h4>
                            <p class="text-white/40 text-sm font-medium leading-relaxed group-hover:text-white/60 transition-colors">{item.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        {/* GAME SCENARIOS */}
        <section class="mb-32">
             <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">Game Types</h2>
                <h3 class="text-5xl font-black italic text-white uppercase tracking-tighter">Choose your <span class="text-purple-400">Arena</span></h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {/* SOLO */}
                <div class="group relative rounded-[3rem] p-10 bg-white/[0.02] border border-white/10 backdrop-blur-md hover:border-cyan-500/40 hover:shadow-[0_0_40px_rgba(6,182,212,0.15)] hover:-translate-y-1 transition-all duration-500 overflow-hidden">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-cyan-500/10 blur-[80px] -z-10 group-hover:bg-cyan-500/20 transition-all duration-700"></div>

                    <div class="flex justify-between items-start mb-8 relative z-10">
                        <div class="text-4xl group-hover:scale-110 transition-all duration-300">👤</div>
                        <span class="px-3 py-1 bg-cyan-500/10 border border-cyan-500/20 rounded-lg text-[10px] font-black text-cyan-400 uppercase tracking-widest group-hover:bg-cyan-500/20 group-hover:text-cyan-300 transition-colors">Solo</span>
                    </div>
                    <h4 class="text-3xl font-black italic text-white uppercase tracking-tighter mb-4">Free-for-All</h4>
                    <p class="text-white/40 text-sm leading-relaxed font-medium group-hover:text-white/60 transition-colors">
                        Czysta rywalizacja. Tylko Ty, Twoje narzędzia i mapa. Zdominuj każdego przeciwnika.
                    </p>
                </div>

                {/* TEAM */}
                <div class="group relative rounded-[3rem] p-10 bg-white/[0.02] border border-white/10 backdrop-blur-md hover:border-purple-500/40 hover:shadow-[0_0_40px_rgba(168,85,247,0.15)] hover:-translate-y-1 transition-all duration-500 overflow-hidden">
                     <div class="absolute top-0 right-0 w-64 h-64 bg-purple-500/10 blur-[80px] -z-10 group-hover:bg-purple-500/20 transition-all duration-700"></div>

                    <div class="flex justify-between items-start mb-8 relative z-10">
                        <div class="text-4xl group-hover:scale-110 transition-all duration-300">👥</div>
                        <span class="px-3 py-1 bg-purple-500/10 border border-purple-500/20 rounded-lg text-[10px] font-black text-purple-400 uppercase tracking-widest group-hover:bg-purple-500/20 group-hover:text-purple-300 transition-colors">4vs4</span>
                    </div>
                    <h4 class="text-3xl font-black italic text-white uppercase tracking-tighter mb-4">Team Battle</h4>
                    <p class="text-white/40 text-sm leading-relaxed font-medium group-hover:text-white/60 transition-colors">
                        Strategiczna koordynacja. Łączcie plamy koloru w strefy wpływów i kontrolujcie mapę.
                    </p>
                </div>

                {/* CHAOS */}
                <div class="group relative rounded-[3rem] p-10 bg-white/[0.02] border border-white/10 backdrop-blur-md hover:border-pink-500/50 hover:shadow-[0_0_50px_rgba(236,72,153,0.2)] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                     <div class="absolute top-0 right-0 w-64 h-64 bg-pink-500/20 blur-[80px] -z-10 group-hover:opacity-100 opacity-50 transition-opacity"></div>

                    <div class="flex justify-between items-start mb-8 relative z-10">
                        <div class="text-4xl group-hover:scale-110 transition-all duration-500">⚠️</div>
                        <span class="px-3 py-1 bg-pink-500/20 border border-pink-500/30 rounded-lg text-[10px] font-black text-pink-400 uppercase tracking-widest group-hover:bg-pink-500 group-hover:text-white transition-colors shadow-[0_0_15px_rgba(236,72,153,0.3)]">Extreme</span>
                    </div>
                    <h4 class="text-3xl font-black italic text-white uppercase tracking-tighter mb-4">Chaos Mode</h4>
                    <p class="text-white/40 text-sm leading-relaxed font-medium mb-6 group-hover:text-white/70 transition-colors">
                        Zasady przestają istnieć. Dynamiczne eventy zmieniają przebieg meczu.
                    </p>
                    <ul class="space-y-2 relative z-10">
                        <li class="flex items-center gap-2 text-[10px] font-bold text-pink-300 uppercase tracking-wider group-hover:text-white transition-colors">
                            <span class="w-1.5 h-1.5 bg-pink-500 rounded-full shadow-[0_0_5px_#ec4899]"></span> Rainbow Storm
                        </li>
                         <li class="flex items-center gap-2 text-[10px] font-bold text-pink-300 uppercase tracking-wider group-hover:text-white transition-colors">
                            <span class="w-1.5 h-1.5 bg-pink-500 rounded-full shadow-[0_0_5px_#ec4899]"></span> Paint Explosion
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        {/* REGIONS */}
        <section class="mb-32">
             <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">World</h2>
                <h3 class="text-5xl font-black italic text-white uppercase tracking-tighter">Chromatic <span class="text-cyan-400">Regions</span></h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {[
                    { title: "Neon City", subtitle: "Region 01 // Megacity", icon: "🏙️", desc: "Walka w wiecznym deszczu, wśród neonów i wieżowców.", tags: ["Verticality", "Rain"], color: "cyan", shadow: "hover:shadow-[0_0_50px_rgba(6,182,212,0.15)]", border: "hover:border-cyan-400" },
                    { title: "Volcanic Island", subtitle: "Region 02 // Core", icon: "🌋", desc: "Surowa energia i lawa. Wykorzystaj gejzery by zyskać przewagę.", tags: ["Hazard", "Heat"], color: "orange", shadow: "hover:shadow-[0_0_50px_rgba(249,115,22,0.15)]", border: "hover:border-orange-400" },
                    { title: "Frozen Realm", subtitle: "Region 03 // Void", icon: "❄️", desc: "Tłumiona energia i lód. Powierzchnie o niskim tarciu.", tags: ["Ice Physics", "Open"], color: "blue", shadow: "hover:shadow-[0_0_50px_rgba(59,130,246,0.15)]", border: "hover:border-blue-400" },
                    { title: "Rainbow Maze", subtitle: "Region 04 // Experim.", icon: "🌀", desc: "Niestabilny labirynt z dynamicznymi ścianami.", tags: ["Shifting", "Maze"], color: "pink", shadow: "hover:shadow-[0_0_50px_rgba(236,72,153,0.15)]", border: "hover:border-pink-400" }
                ].map(map => (
                     <div class={`group relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[3.5rem] p-10 transition-all duration-500 ${map.border} ${map.shadow} hover:-translate-y-1`}>
                        <div class={`absolute -top-24 -right-24 w-80 h-80 bg-${map.color}-500/10 blur-[100px] group-hover:bg-${map.color}-500/20 transition-all duration-700 group-hover:scale-125`}></div>

                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-8">
                                <div>
                                    <span class={`text-[10px] font-black text-${map.color}-400 uppercase tracking-widest mb-2 block group-hover:text-${map.color}-300 transition-colors`}>{map.subtitle}</span>
                                    <h4 class="text-4xl font-black italic text-white uppercase tracking-tighter group-hover:translate-x-2 transition-transform">{map.title}</h4>
                                </div>
                                <span class={`text-4xl filter drop-shadow-[0_0_15px_rgba(255,255,255,0.1)] group-hover:scale-110 group-hover:rotate-6 transition-transform duration-300`}>{map.icon}</span>
                            </div>
                            <p class="text-white/40 text-sm font-medium leading-relaxed mb-8 max-w-md group-hover:text-white/70 transition-colors">
                                {map.desc}
                            </p>
                            <div class="flex flex-wrap gap-3">
                                {map.tags.map(tag => (
                                    <span class={`px-3 py-1 bg-${map.color}-500/10 border border-${map.color}-500/20 rounded-lg text-[9px] font-black text-${map.color}-400 uppercase tracking-widest transition-all duration-300 group-hover:bg-${map.color}-500 group-hover:text-white group-hover:border-${map.color}-400`}>
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

    </main>
</Layout>