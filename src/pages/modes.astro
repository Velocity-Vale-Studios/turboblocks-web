---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Game Modes">
    <div class="max-w-7xl mx-auto px-8 py-32">

        <div class="mb-24 flex flex-col items-center md:items-start text-center md:text-left">
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">Gotowy na starcie?</h2>
            <h1 class="text-7xl md:text-9xl font-black italic text-white uppercase tracking-tighter leading-none">
                AKTUALNY <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4">TRYB</span>
            </h1>
        </div>

        <section class="relative group">
            <div class="absolute -inset-4 bg-gradient-to-r from-pink-500/20 to-purple-600/20 blur-[100px] rounded-[4rem] opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>

            <div class="relative min-h-[500px] flex items-center bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-pink-500/30 rounded-[3.5rem] p-10 md:p-16 overflow-hidden shadow-[0_0_60px_rgba(236,72,153,0.2)] hover:shadow-[0_0_80px_rgba(236,72,153,0.3)] transition-all duration-500">
                <div class="flex flex-col lg:flex-row items-center gap-16 w-full">

                    <div class="relative shrink-0">
                        <div class="w-64 h-64 bg-gradient-to-br from-pink-500/20 to-purple-600/20 border border-pink-500/30 rounded-[3rem] flex items-center justify-center text-8xl shadow-[0_0_50px_rgba(236,72,153,0.3)] rotate-3 group-hover:rotate-6 transition-transform duration-700 backdrop-blur-md">
                            🎨
                            <div class="absolute -bottom-4 -right-4 bg-white text-black px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest shadow-[0_0_20px_rgba(255,255,255,0.3)]">
                                BETA
                            </div>
                        </div>
                    </div>

                    <div class="flex-grow">
                        <div class="flex items-center gap-4 mb-6">
                            <span class="text-orange-400 font-black text-xs uppercase tracking-[0.3em] drop-shadow-[0_0_10px_rgba(251,146,60,0.5)]">Wersja 1.21.1+</span>
                            <div class="w-1.5 h-1.5 bg-white/20 rounded-full"></div>
                            <span class="text-white/40 font-black text-xs uppercase tracking-[0.3em]">PVP / Minigame</span>
                        </div>

                        <h2 class="text-6xl md:text-8xl font-black italic text-white uppercase tracking-tighter leading-none mb-8">
                            COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4">CLASH</span>
                        </h2>

                        <p class="text-white/60 text-lg leading-relaxed max-w-2xl mb-12 font-medium italic border-l-4 border-white/10 pl-6">
                            Zamaluj arenę barwami swojej drużyny, eliminuj przeciwników i przejmij kontrolę nad strategicznymi punktami. Najbardziej dynamiczny tryb tego sezonu!
                        </p>

                        <div class="flex">
                            <a
                                    href="/modes/color-clash"
                                    class="flex items-center justify-center px-8 py-4 bg-white text-black font-black uppercase text-xs tracking-widest rounded-2xl hover:scale-105 hover:bg-pink-500 hover:text-white transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_40px_rgba(236,72,153,0.5)]"
                            >
                                Poznaj Tryb
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="my-32 flex items-center justify-center gap-8">
            <div class="h-[1px] w-32 bg-gradient-to-r from-transparent to-white/10"></div>
            <span class="text-[10px] font-black text-white/20 uppercase tracking-[0.8em]">Kolejne tryby wkrótce...</span>
            <div class="h-[1px] w-32 bg-gradient-to-l from-transparent to-white/10"></div>
        </div>

        <section class="grid grid-cols-1 lg:grid-cols-12 gap-10 opacity-70 hover:opacity-100 transition-opacity duration-700">
            <div class="lg:col-span-12 relative bg-gradient-to-br from-white/5 to-white/[0.01] backdrop-blur-3xl border border-cyan-500/20 rounded-[3.5rem] p-12 overflow-hidden group hover:border-cyan-500/40 hover:shadow-[0_0_60px_rgba(6,182,212,0.15)] transition-all duration-500">
                <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/5 to-transparent opacity-50"></div>

                <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-8">
                    <div class="flex items-center gap-10">
                        <div class="w-32 h-32 bg-cyan-500/10 border border-cyan-500/20 rounded-3xl flex items-center justify-center text-5xl grayscale group-hover:grayscale-0 transition-all duration-700 shadow-lg shadow-cyan-500/10">
                            🏎️
                        </div>
                        <div>
                            <div class="inline-block px-4 py-2 bg-cyan-400/10 border border-cyan-400/20 rounded-xl text-[10px] font-black text-cyan-400 uppercase tracking-widest mb-3 shadow-[0_0_15px_rgba(34,211,238,0.2)]">COMING SOON // FUTURE</div>
                            <h3 class="text-4xl font-black italic text-white uppercase tracking-tighter">ROCKY <span class="text-cyan-400 pr-2">RACEWAY</span></h3>
                            <p class="text-white/40 text-sm italic mt-2 font-medium">Ekstremalne wyścigi z fizyką klocków. Premiera wkrótce.</p>
                        </div>
                    </div>

                    <div class="flex items-center justify-center px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-white/20 font-black text-xs uppercase tracking-widest italic cursor-not-allowed w-fit">
                        Wkrótce...
                    </div>
                </div>
            </div>
        </section>

    </div>
</Layout>