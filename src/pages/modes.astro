---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Game Modes">
    <div class="max-w-7xl mx-auto px-8 pt-34 pb-24">

        <div class="text-center mb-20">
            <h1 class="text-7xl md:text-8xl font-[1000] italic text-white uppercase tracking-tighter leading-none mb-4">
                AKTUALNY <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-orange-500">TRYB</span>
            </h1>
            <p class="text-white/20 text-[10px] font-black uppercase tracking-[0.6em]">Gotowy na starcie?</p>
        </div>

        <section class="relative group">
            <div class="absolute -inset-4 bg-gradient-to-r from-pink-500/20 to-purple-600/20 blur-[100px] rounded-[4rem] opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>

            <div class="relative bg-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[3.5rem] p-10 md:p-16 overflow-hidden">
                <div class="flex flex-col lg:flex-row items-center gap-16">

                    <div class="relative shrink-0">
                        <div class="w-64 h-64 bg-gradient-to-br from-pink-500 to-purple-600 rounded-[3rem] flex items-center justify-center text-8xl shadow-[0_0_50px_rgba(236,72,153,0.3)] rotate-3 group-hover:rotate-6 transition-transform duration-700">
                            🎨
                            <div class="absolute -bottom-4 -right-4 bg-white text-black px-4 py-1.5 rounded-xl text-[10px] font-[1000] uppercase tracking-widest shadow-xl">
                                BETA
                            </div>
                        </div>
                    </div>

                    <div class="flex-grow">
                        <div class="flex items-center gap-4 mb-6">
                            <span class="text-orange-500 font-black text-[10px] uppercase tracking-[0.3em]">Wersja 1.21.1+</span>
                            <div class="w-1.5 h-1.5 bg-white/20 rounded-full"></div>
                            <span class="text-white/40 font-black text-[10px] uppercase tracking-[0.3em]">PVP / Minigame</span>
                        </div>

                        <h2 class="text-6xl md:text-8xl font-[1000] italic text-white uppercase tracking-tighter leading-none mb-8">
                            COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400">CLASH</span>
                        </h2>

                        <p class="text-white/40 text-lg leading-relaxed max-w-2xl mb-12 font-medium italic">
                            Zamaluj arenę barwami swojej drużyny, eliminuj przeciwników i przejmij kontrolę nad strategicznymi punktami. Najbardziej dynamiczny tryb tego sezonu!
                        </p>

                        <div class="flex">
                            <a
                                    href="/modes/color-clash"
                                    class="flex items-center justify-center h-14 px-12 bg-gradient-to-r from-orange-500 to-pink-500 text-white font-black uppercase text-[10px] tracking-widest rounded-2xl shadow-[0_15px_30px_rgba(249,115,22,0.3)] hover:scale-105 transition-all border border-transparent leading-none"
                            >
                                Poznaj Tryb
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="my-32 flex items-center justify-center gap-8">
            <div class="h-[1px] w-32 bg-gradient-to-r from-transparent to-white/10"></div>
            <span class="text-[10px] font-black text-white/20 uppercase tracking-[0.8em]">Kolejne tryby wkrótce...</span>
            <div class="h-[1px] w-32 bg-gradient-to-l from-transparent to-white/10"></div>
        </div>

        <section class="grid grid-cols-1 lg:grid-cols-12 gap-10 opacity-60 hover:opacity-100 transition-opacity duration-700">
            <div class="lg:col-span-12 relative bg-white/[0.01] border border-white/5 rounded-[3.5rem] p-12 overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/5 to-transparent"></div>

                <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-8">
                    <div class="flex items-center gap-10">
                        <div class="w-32 h-32 bg-cyan-500/10 border border-cyan-500/20 rounded-3xl flex items-center justify-center text-5xl grayscale group-hover:grayscale-0 transition-all duration-700">
                            🏎️
                        </div>
                        <div>
                            <div class="inline-block px-3 py-1 bg-cyan-400/10 border border-cyan-400/20 rounded-lg text-[8px] font-black text-cyan-400 uppercase tracking-widest mb-3">COMING SOON // FUTURE</div>
                            <h3 class="text-4xl font-[1000] italic text-white uppercase tracking-tighter">ROCKY <span class="text-cyan-400">RACEWAY</span></h3>
                            <p class="text-white/30 text-sm italic mt-2">Ekstremalne wyścigi z fizyką klocków. Premiera wkrótce.</p>
                        </div>
                    </div>

                    <div class="flex items-center justify-center h-14 px-10 bg-white/5 border border-white/10 rounded-2xl text-white/20 font-black text-[10px] uppercase tracking-widest italic leading-none">
                        Wkrótce...
                    </div>
                </div>
            </div>
        </section>

    </div>
</Layout>