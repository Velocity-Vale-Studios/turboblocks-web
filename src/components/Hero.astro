---
// src/components/Hero.astro
const serverIP = "play.turboblocks.eu";
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-10">
    <div class="absolute top-1/4 -left-20 w-[500px] h-[500px] bg-pink-500/20 blur-[150px] animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-20 w-[500px] h-[500px] bg-cyan-500/20 blur-[150px] animate-pulse" style="animation-delay: 2s;"></div>

    <div class="relative z-10 text-center px-6">
        <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-white/5 border border-white/10 backdrop-blur-md">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-cyan-400">Nowa Era: Color Clash</span>
        </div>

        <h1 class="text-8xl md:text-[160px] font-[1000] italic tracking-tighter leading-none uppercase flex flex-col md:block">
            <span class="text-white">TURBO</span>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400">BLOCKS</span>
        </h1>

        <div class="mt-12 flex flex-wrap justify-center gap-6">
            <button
                    id="copy-ip-btn"
                    class="relative px-12 py-5 bg-white text-black font-black uppercase text-xs tracking-widest rounded-2xl hover:bg-cyan-400 transition-all duration-500 hover:scale-105 shadow-[0_20px_40px_rgba(255,255,255,0.1)] group"
            >
                <span id="btn-text">Zagraj Teraz</span>
                <span id="copy-success" class="absolute -top-12 left-1/2 -translate-x-1/2 bg-green-500 text-white px-3 py-1 rounded-lg text-[10px] opacity-0 transition-opacity">Skopiowano IP!</span>
            </button>

            <a
                    href="/modes"
                    class="px-12 py-5 bg-white/5 border border-white/10 text-white font-black uppercase text-xs tracking-widest rounded-2xl backdrop-blur-xl hover:bg-white/10 transition-all flex items-center justify-center"
            >
                Zobacz Tryby
            </a>
        </div>
    </div>
</section>

<script define:vars={{ serverIP }}>
    const btn = document.getElementById('copy-ip-btn');
    const btnText = document.getElementById('btn-text');
    const successMsg = document.getElementById('copy-success');

    btn?.addEventListener('click', () => {
        // Kopiowanie do schowka
        navigator.clipboard.writeText(serverIP);

        // Efekt wizualny
        btnText.innerText = 'IP SKOPIOWANE!';
        successMsg.style.opacity = '1';
        btn.style.backgroundColor = '#22d3ee'; // cyan-400

        // Powrót do normy po 2 sekundach
        setTimeout(() => {
            btnText.innerText = 'Zagraj Teraz';
            successMsg.style.opacity = '0';
            btn.style.backgroundColor = '#ffffff';
        }, 2000);
    });
</script>