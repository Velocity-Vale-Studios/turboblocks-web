---
import { TeamSection } from './TeamSection';
---

<section class="max-w-7xl mx-auto px-8 py-24 relative">
    <div class="absolute top-1/4 left-0 w-96 h-96 bg-purple-500/10 blur-[120px] -z-10"></div>
    <div class="absolute bottom-1/4 right-0 w-96 h-96 bg-cyan-500/10 blur-[120px] -z-10"></div>

    <div class="mb-12 flex flex-col items-center md:items-start">
        <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">Color Clash Season</h2>
        <h3 class="text-6xl font-black italic text-white uppercase tracking-tighter">Meet the <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4">Creators</span></h3>
    </div>

    <TeamSection />

    <div class="mt-12 flex flex-wrap justify-center items-center gap-4">
        <!-- DISCORD -->
        <a href="https://discord.gg/vuG3EQtV4" target="_blank"
           class="w-12 h-12 flex items-center justify-center rounded-2xl bg-gradient-to-r from-indigo-500/10 to-purple-500/10 backdrop-blur-md border border-indigo-500/30 text-indigo-400 hover:bg-indigo-500/20 hover:border-indigo-500/50 hover:text-indigo-100 hover:shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:scale-110 transition-all duration-300 shadow-[0_0_15px_rgba(99,102,241,0.1)] group">
