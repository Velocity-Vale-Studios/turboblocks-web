// Desktop cart overlay — mounted globally in Layout.astro
---
---

<div id="cart-drawer" class="hidden lg:flex fixed top-28 right-4 md:right-8 z-[9000] flex-col pointer-events-none opacity-0 translate-x-4 transition-all duration-500 ease-out w-[400px] max-h-[calc(100vh-140px)]">

    <div class="w-full bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2rem] shadow-[0_0_60px_rgba(0,0,0,0.5)] overflow-hidden flex flex-col relative group">

        {/* Gradient line top */}
        <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-pink-500/30 to-transparent"></div>

        {/* Header */}
        <div class="px-6 py-5 flex justify-between items-center border-b border-white/5 shrink-0">
            <div>
                <div class="inline-block px-3 py-1 bg-pink-400/10 border border-pink-400/20 rounded-full mb-2">
                    <span class="text-[8px] font-black uppercase tracking-[0.4em] text-pink-400 block leading-none">Cart Preview</span>
                </div>
                <h2 class="text-xl font-black italic text-white uppercase tracking-tighter leading-none">
                    YOUR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-400 pr-1">CART</span>
                </h2>
            </div>
            <button
                onclick="toggleCart(false)"
                class="w-9 h-9 flex items-center justify-center bg-white/5 border border-white/10 text-white/40 rounded-xl hover:bg-white/10 hover:text-white hover:rotate-90 transition-all duration-300"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        {/* Items List */}
        <div id="cart-list" class="overflow-y-auto max-h-[340px] px-5 py-4 flex flex-col gap-2.5">
            <div class="h-full flex flex-col items-center justify-center text-center opacity-40 py-10">
                <span class="text-4xl mb-4 grayscale">🛒</span>
                <p class="text-white italic uppercase text-[10px] font-black tracking-widest">Cart Empty</p>
                <a href="/shop" class="mt-3 text-[9px] font-black text-cyan-400 uppercase tracking-widest hover:text-white transition-colors">Go to Shop →</a>
            </div>
        </div>

        {/* Footer: Total + Checkout */}
        <div class="px-6 py-5 border-t border-white/5 shrink-0 relative">
            <div class="absolute -top-16 -right-16 w-40 h-40 bg-gradient-to-br from-pink-500/10 to-purple-600/10 blur-[60px] rounded-full pointer-events-none"></div>

            <div class="relative z-10">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex flex-col gap-0.5">
                        <span class="text-[9px] font-black text-white/30 uppercase tracking-[0.2em]">Total</span>
                        <span id="cart-total" class="text-2xl font-black italic text-transparent bg-clip-text bg-gradient-to-r from-white to-pink-200 tracking-tighter">0 TC</span>
                    </div>
                    <span id="cart-item-count" class="text-[9px] font-black text-white/20 uppercase tracking-widest">0 items</span>
                </div>

                <a id="checkout-btn" href="/checkout" class="relative overflow-hidden w-full py-3.5 rounded-2xl bg-white text-black font-black uppercase tracking-[0.2em] text-[10px] shadow-[0_0_30px_rgba(255,255,255,0.1)] hover:shadow-[0_0_60px_rgba(236,72,153,0.4)] transition-all duration-300 active:scale-[0.97] flex items-center justify-center gap-3 border border-transparent hover:border-pink-500/30 group/btn no-underline">
                    <span class="relative z-10 group-hover/btn:text-pink-600 transition-colors">Checkout</span>
                    <span class="relative z-10 group-hover/btn:text-pink-600 group-hover/btn:translate-x-1 transition-all">→</span>
                    <div class="absolute inset-0 bg-gradient-to-r from-purple-100 to-pink-100 scale-x-0 group-hover/btn:scale-x-100 transition-transform duration-300 origin-left"></div>
                </a>
            </div>
        </div>
    </div>
</div>

<script is:inline>
    const CART_STORAGE_KEY = 'turbo_cart_v1';
    window.cart = JSON.parse(localStorage.getItem(CART_STORAGE_KEY) || '[]');

    const saveCart = (animate) => {
        localStorage.setItem(CART_STORAGE_KEY, JSON.stringify(window.cart));
        updateCartUI(animate);
    };

    let isCartExpanded = false;

    window.toggleCart = (forceState) => {
        const drawer = document.getElementById('cart-drawer');
        if (!drawer) return;
        isCartExpanded = (typeof forceState === 'boolean') ? forceState : !isCartExpanded;
        if (isCartExpanded) {
            drawer.classList.remove('opacity-0', 'pointer-events-none', 'translate-x-4');
            drawer.classList.add('opacity-100', 'pointer-events-auto', 'translate-x-0');
            updateCartUI(false);
        } else {
            drawer.classList.add('opacity-0', 'pointer-events-none', 'translate-x-4');
            drawer.classList.remove('opacity-100', 'pointer-events-auto', 'translate-x-0');
        }
    };

    window.addToCart = (item) => {
        window.cart.push(item);
        saveCart(true);
        if (window.innerWidth >= 1024) window.toggleCart(true);
    };

    window.removeFromCart = (index) => {
        window.cart.splice(index, 1);
        saveCart(false);
    };

    window.addEventListener('shop:add', (e) => {
        if (e.detail) window.addToCart(e.detail);
    });

    function getRarityPillClass(rarity) {
        switch(rarity) {
            case 'Legendary': return 'bg-yellow-500/15 border border-yellow-500/30 text-yellow-400';
            case 'Epic':      return 'bg-purple-500/15 border border-purple-500/30 text-purple-400';
            case 'Rare':      return 'bg-blue-500/15 border border-blue-500/30 text-blue-400';
            case 'Uncommon':  return 'bg-green-500/15 border border-green-500/30 text-green-400';
            default:          return 'bg-white/5 border border-white/10 text-white/50';
        }
    }

    function updateCartUI(animate) {
        const list = document.getElementById('cart-list');
        const totalDisplay = document.getElementById('cart-total');
        const countDisplay = document.getElementById('cart-item-count');
        const checkoutBtn = document.getElementById('checkout-btn');
        const navbarBadge = document.getElementById('navbar-cart-count');

        if (navbarBadge) {
            navbarBadge.innerText = window.cart.length;
            navbarBadge.style.opacity = window.cart.length > 0 ? '1' : '0';
            if (animate) {
                navbarBadge.classList.remove('animate-cart-pop');
                void navbarBadge.offsetWidth;
                navbarBadge.classList.add('animate-cart-pop');
            }
        }

        if (!list || !totalDisplay) return;

        if (countDisplay) {
            const n = window.cart.length;
            countDisplay.innerText = n === 0 ? '0 items' : n === 1 ? '1 item' : n + ' items';
        }

        if (window.cart.length === 0) {
            list.innerHTML = '<div class="h-full flex flex-col items-center justify-center text-center opacity-40 py-10"><span class="text-4xl mb-4 grayscale">🛒</span><p class="text-white italic uppercase text-[10px] font-black tracking-widest">Cart Empty</p><a href="/shop" class="mt-3 text-[9px] font-black text-cyan-400 uppercase tracking-widest hover:text-white transition-colors no-underline">Go to Shop →</a></div>';
            totalDisplay.innerText = '0 TC';
            if (checkoutBtn) { checkoutBtn.style.pointerEvents = 'none'; checkoutBtn.style.opacity = '0.3'; }
        } else {
            list.innerHTML = '';
            let total = 0;
            window.cart.forEach((item, index) => {
                const priceVal = parseInt(String(item.price).replace(/[^0-9]/g, '')) || 0;
                total += priceVal;
                const el = document.createElement('div');
                el.className = "flex items-center gap-3 bg-black/40 border border-white/5 p-3 rounded-[1.5rem] backdrop-blur-md transition-all hover:bg-white/5 hover:border-white/10 shrink-0";
                el.innerHTML = '<div class="w-11 h-11 bg-gradient-to-br from-white/10 to-transparent rounded-xl flex items-center justify-center text-lg border border-white/5 shrink-0">' + (item.icon||'📦') + '</div><div class="flex-grow overflow-hidden"><p class="text-[10px] font-black text-white uppercase italic tracking-tighter truncate pr-2">' + item.name + '</p><div class="flex items-center gap-2 mt-0.5"><span class="text-[9px] font-bold px-2 py-0.5 rounded-full ' + getRarityPillClass(item.rarity) + '">' + item.price + '</span><span class="text-[8px] text-white/20 font-bold uppercase">' + (item.rarity||'') + '</span></div></div><button onclick="removeFromCart(' + index + ')" class="w-7 h-7 rounded-full flex items-center justify-center text-white/20 hover:text-red-500 hover:bg-red-500/10 transition-all shrink-0"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>';
                list.appendChild(el);
            });
            totalDisplay.innerText = total + ' TC';
            if (checkoutBtn) { checkoutBtn.style.pointerEvents = ''; checkoutBtn.style.opacity = ''; }
        }
    }

    updateCartUI(false);
</script>

<style is:global>
    @keyframes cart-bounce {
        0% { transform: scale(1); }
        25% { transform: scale(1.5); background-color: #db2777; color: white; box-shadow: 0 0 10px rgba(219, 39, 119, 0.5); }
        40% { transform: scale(0.9); }
        60% { transform: scale(1.15); }
        100% { transform: scale(1); background-color: white; color: #db2777; box-shadow: none; }
    }
    .animate-cart-pop {
        animation: cart-bounce 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    }
</style>

