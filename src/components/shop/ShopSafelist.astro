---
/**
 * ShopSafelist — wymusza generowanie klas CSS przez UnoCSS.
 *
 * Klasy z shop.ts są wstawiane dynamicznie (interpolacja), więc UnoCSS
 * ich nie widzi. Ten komponent renderuje ukrytego <div> ze WSZYSTKIMI
 * klasami używanymi przez kolekcje sklepowe.
 *
 * ⚠️  Dodając nową kolekcję do shop.ts, wklej jej klasy tutaj!
 */
---

<div class="hidden" aria-hidden="true">
  {/* winter-festive */}
  <i class="from-blue-600 via-indigo-500 to-cyan-400 border-blue-500/30 shadow-[0_0_60px_rgba(59,130,246,0.25)] hover:shadow-[0_0_100px_rgba(59,130,246,0.4)] text-blue-400 bg-blue-500/20 shadow-[0_0_15px_rgba(59,130,246,0.3)] via-blue-500/30" />

  {/* solar-flare */}
  <i class="from-orange-500 via-red-500 to-yellow-500 border-orange-500/30 shadow-[0_0_60px_rgba(249,115,22,0.25)] hover:shadow-[0_0_100px_rgba(249,115,22,0.4)] text-orange-500 text-orange-400 bg-orange-500/20 shadow-[0_0_15px_rgba(249,115,22,0.3)] via-orange-500/30" />

  {/* neon-genesis */}
  <i class="from-cyan-500 via-blue-500 to-indigo-500 border-cyan-500/30 shadow-[0_0_60px_rgba(6,182,212,0.25)] hover:shadow-[0_0_100px_rgba(6,182,212,0.4)] text-cyan-500 text-cyan-400 bg-cyan-500/20 shadow-[0_0_15px_rgba(6,182,212,0.3)] via-cyan-500/30" />

  {/* chromatic-riot */}
  <i class="from-pink-500 via-purple-500 to-fuchsia-500 border-pink-500/30 shadow-[0_0_60px_rgba(236,72,153,0.25)] hover:shadow-[0_0_100px_rgba(236,72,153,0.4)] text-pink-500 text-pink-400 bg-pink-500/20 shadow-[0_0_15px_rgba(236,72,153,0.3)] via-pink-500/30" />

  {/* cryo-neon */}
  <i class="from-teal-400 via-cyan-300 to-blue-400 border-teal-400/30 shadow-[0_0_60px_rgba(45,212,191,0.25)] hover:shadow-[0_0_100px_rgba(45,212,191,0.4)] text-teal-400 text-teal-300 bg-teal-400/20 shadow-[0_0_15px_rgba(45,212,191,0.3)] via-teal-400/30" />

  {/* magma-flow */}
  <i class="from-red-600 via-orange-500 to-yellow-500 border-red-500/30 shadow-[0_0_60px_rgba(239,68,68,0.25)] hover:shadow-[0_0_100px_rgba(239,68,68,0.4)] text-red-500 text-red-400 bg-red-500/20 shadow-[0_0_15px_rgba(239,68,68,0.3)] via-red-500/30" />

  {/* prism-shift */}
  <i class="from-indigo-500 via-purple-500 to-pink-500 border-purple-500/30 shadow-[0_0_60px_rgba(168,85,247,0.25)] hover:shadow-[0_0_100px_rgba(168,85,247,0.4)] text-purple-400 bg-purple-500/20 shadow-[0_0_15px_rgba(168,85,247,0.3)] via-purple-500/30" />

  {/* system-override */}
  <i class="from-green-600 via-emerald-500 to-teal-500 border-green-500/30 shadow-[0_0_60px_rgba(16,185,129,0.25)] hover:shadow-[0_0_100px_rgba(16,185,129,0.4)] text-green-500 text-green-400 bg-green-500/20 shadow-[0_0_15px_rgba(16,185,129,0.3)] via-green-500/30" />

  {/* kinetic-surge */}
  <i class="from-yellow-400 via-amber-500 to-orange-500 border-yellow-400/30 shadow-[0_0_60px_rgba(250,204,21,0.25)] hover:shadow-[0_0_100px_rgba(250,204,21,0.4)] text-yellow-400 bg-yellow-400/20 shadow-[0_0_15px_rgba(250,204,21,0.3)] via-yellow-400/30" />

  {/* neon-hazard */}
  <i class="from-lime-400 via-green-500 to-emerald-600 border-lime-400/30 shadow-[0_0_60px_rgba(163,230,53,0.25)] hover:shadow-[0_0_100px_rgba(163,230,53,0.4)] text-lime-400 bg-lime-400/20 shadow-[0_0_15px_rgba(163,230,53,0.3)] via-lime-400/30" />

  {/* astral-void */}
  <i class="from-violet-600 via-fuchsia-700 to-slate-900 border-violet-500/30 shadow-[0_0_60px_rgba(139,92,246,0.25)] hover:shadow-[0_0_100px_rgba(139,92,246,0.4)] text-violet-400 bg-violet-500/20 shadow-[0_0_15px_rgba(139,92,246,0.3)] via-violet-500/30" />
</div>
