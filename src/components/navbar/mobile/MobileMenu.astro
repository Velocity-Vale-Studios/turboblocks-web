---
interface Props {
    config: any;
    currentPath: string;
}
const { config, currentPath } = Astro.props;

// Twoje bazowe parametry
const baseLink = "relative w-full py-4 px-6 flex items-center justify-center rounded-2xl transition-all duration-300 transform-gpu group";

// STAN AKTYWNY: Cyjanowy, powiększony
const activeLink = "bg-cyan-500/20 backdrop-blur-md text-cyan-400 ring-1 ring-inset ring-cyan-400/50 shadow-[0_0_20px_rgba(34,211,238,0.3)] scale-105";

// STAN NIEAKTYWNY: Teraz z cyjanowym ringiem na hoverze zamiast białego
const inactiveLink = "text-white/60 hover:text-white hover:bg-cyan-400/5 hover:scale-105 active:scale-95 hover:ring-1 hover:ring-cyan-400/30";
---

<div
        id="mobileMenu"
        class="absolute top-[calc(100%+1rem)] left-0 right-0 mx-auto w-[calc(100%-1.5rem)] p-3 rounded-[2.5rem] bg-white/[0.02] backdrop-blur-2xl border border-white/10 shadow-[0_25px_50px_rgba(0,0,0,0.5)] opacity-0 translate-y-[-15px] pointer-events-none transition-all duration-500 cubic-bezier(0.4, 0, 0.2, 1) z-[50]"
>
    <div class="absolute inset-0 rounded-[2.5rem] bg-gradient-to-b from-white/5 to-transparent pointer-events-none"></div>

    <nav class="relative z-10 flex flex-col gap-2.5 px-4 py-2">
        {config.links.map((link: any) => {
            const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));

            return (
                    <a
                            href={link.href}
                            class={`${baseLink} ${isActive ? activeLink : inactiveLink}`}
                    >
          <span class="text-[11px] sm:text-xs font-black uppercase tracking-[0.2em] relative z-10">
            {link.name}
          </span>

                        {!isActive && (
                                <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 ring-1 ring-inset ring-cyan-400/30 shadow-[inset_0_0_15px_rgba(34,211,238,0.1)]"></div>
                        )}
                    </a>
            )
        })}
    </nav>
</div>

<script>
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');

    menuBtn?.addEventListener('click', () => {
        const isOpen = menuBtn.classList.toggle('menu-open');

        if (isOpen) {
            mobileMenu?.classList.replace('opacity-0', 'opacity-100');
            mobileMenu?.classList.replace('translate-y-[-15px]', 'translate-y-0');
            mobileMenu?.classList.replace('pointer-events-none', 'pointer-events-auto');
        } else {
            mobileMenu?.classList.replace('opacity-100', 'opacity-0');
            mobileMenu?.classList.replace('translate-y-0', 'translate-y-[-15px]');
            mobileMenu?.classList.replace('pointer-events-auto', 'pointer-events-none');
        }
    });

    mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
            menuBtn?.classList.remove('menu-open');
            mobileMenu?.classList.add('opacity-0', 'translate-y-[-15px]', 'pointer-events-none');
        });
    });
</script>