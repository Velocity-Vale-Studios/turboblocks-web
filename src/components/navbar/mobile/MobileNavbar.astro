---
import MobileCopyIp from './MobileCopyIp.astro';
import Hamburger from './Hamburger.astro';
import MobileMenu from './MobileMenu.astro';
import DiscordBtn from '../shared/DiscordBtn.astro';
import CartTrigger from '../shared/CartTrigger.astro';

interface Props {
    config: any;
    currentPath: string;
}

const { config, currentPath } = Astro.props;
const purpleGradient = "bg-gradient-to-r from-pink-500 to-purple-600 text-white shadow-[0_0_20px_rgba(236,72,153,0.3)]";
---

<header class="lg:hidden fixed top-4 left-0 right-0 mx-auto w-[94%] z-50">
    <div class="relative flex items-center justify-between px-2.5 py-3 sm:py-4 rounded-[2rem] bg-white/[0.02] backdrop-blur-2xl border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">

        <div class="flex-1 flex items-center justify-start gap-1.5 sm:gap-2.5">
            <MobileCopyIp config={config} />
            <DiscordBtn />
        </div>

        <div class="flex-1 flex items-center justify-end gap-1.5 sm:gap-2.5">
            <a
                    href={config.shop.href}
                    class={`relative flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-2xl group ${purpleGradient} transition-all duration-300 hover:scale-110 active:scale-95 hover:shadow-[0_0_35px_rgba(236,72,153,0.7)] hover:ring-1 hover:ring-pink-400/50 transform-gpu`}
            >
                <svg class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                    <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </a>

            <CartTrigger />
            <Hamburger />
        </div>
    </div>

    <MobileMenu config={config} currentPath={currentPath} />
</header>