---
interface Props {
    config: any;
}
const { config } = Astro.props;
const animClasses = "transition-all duration-300 hover:scale-105 active:scale-95 transform-gpu";
---

<button
        id="copyIPMobile"
        data-ip={config.server.ip}
        class={`relative flex items-center justify-center w-[72px] sm:w-[82px] h-9 sm:h-10 bg-cyan-500/10 backdrop-blur-md rounded-2xl text-cyan-400 ring-1 ring-inset ring-cyan-400/30 hover:ring-cyan-400/60 hover:shadow-[0_0_25px_rgba(34,211,238,0.4)] overflow-hidden group ${animClasses}`}
>
    <div class="relative z-10 grid place-items-center w-full h-full">

        <div id="ipMobDefault" class="col-start-1 row-start-1 flex items-center justify-center transition-all duration-300 opacity-100 scale-100">
      <span class="text-[13px] sm:text-[14px] font-black uppercase leading-none tracking-tight translate-y-[-0.5px]">
        PLAY
      </span>
        </div>

        <div id="ipMobCopied" class="col-start-1 row-start-1 flex items-center justify-center transition-all duration-300 opacity-0 scale-50 text-white">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
        </div>

    </div>

    <div id="bgGradient" class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-blue-600 opacity-0 transition-opacity duration-300"></div>
</button>

<script>
    const copyBtn = document.getElementById('copyIPMobile');
    const textDefault = document.getElementById('ipMobDefault');
    const textCopied = document.getElementById('ipMobCopied');
    const bgGradient = document.getElementById('bgGradient');

    copyBtn?.addEventListener('click', () => {
        const ip = copyBtn.getAttribute('data-ip') || 'play.turboblocks.eu';
        navigator.clipboard.writeText(ip);

        bgGradient?.classList.replace('opacity-0', 'opacity-100');
        copyBtn.classList.add('shadow-[0_0_30px_rgba(34,211,238,0.6)]');

        textDefault?.classList.replace('opacity-100', 'opacity-0');
        textDefault?.classList.replace('scale-100', 'scale-50');

        textCopied?.classList.replace('opacity-0', 'opacity-100');
        textCopied?.classList.replace('scale-50', 'scale-110');

        setTimeout(() => {
            bgGradient?.classList.replace('opacity-100', 'opacity-0');
            copyBtn.classList.remove('shadow-[0_0_30px_rgba(34,211,238,0.6)]');

            textDefault?.classList.replace('opacity-0', 'opacity-100');
            textDefault?.classList.replace('scale-50', 'scale-100');

            textCopied?.classList.replace('opacity-100', 'opacity-0');
            textCopied?.classList.replace('scale-110', 'scale-50');
        }, 1500);
    });
</script>