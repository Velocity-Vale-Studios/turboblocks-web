---
const purpleGradient = "bg-gradient-to-r from-pink-500 to-purple-600 text-white shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_35px_rgba(236,72,153,0.7)] hover:ring-1 hover:ring-pink-400/50";
---

<button
        id="menuBtn"
        class={`relative flex flex-col items-center justify-center w-9 h-9 sm:w-10 sm:h-10 gap-1.5 rounded-2xl transition-all duration-300 hover:scale-110 hover:rotate-3 active:scale-90 transform-gpu z-[70] ${purpleGradient}`}
>
    <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
    <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
    <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
</button>

<style>
    :global(.menu-open) span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    :global(.menu-open) span:nth-child(2) { opacity: 0; transform: scale(0); }
    :global(.menu-open) span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
</style>