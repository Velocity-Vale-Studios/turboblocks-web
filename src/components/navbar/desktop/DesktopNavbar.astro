---
import DesktopCopyIP from './DesktopCopyIP.astro';
import DesktopNavLinks from './DesktopNavLinks.astro';
import DiscordBtn from '../shared/DiscordBtn.astro';
import CartTrigger from '../shared/CartTrigger.astro';

interface Props {
    config: any;
    currentPath: string;
}

const { config, currentPath } = Astro.props;

const animClasses = "transition-all duration-300 hover:scale-105 active:scale-95 transform-gpu";
const purpleGradient = "bg-gradient-to-r from-pink-500 to-purple-600 text-white shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_30px_rgba(236,72,153,0.6)]";
---

<header class="hidden lg:block fixed top-4 left-0 right-0 mx-auto w-[94%] max-w-7xl z-50 bg-white/[0.02] backdrop-blur-2xl border border-white/10 py-4 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
    <div class="relative w-full px-2 sm:px-4 flex justify-between items-center">

        <div class="flex items-center gap-1.5 sm:gap-4">
            <DesktopCopyIP config={config} />
            <DiscordBtn config={config} />
        </div>

        <DesktopNavLinks config={config} currentPath={currentPath} />

        <div class="flex items-center gap-1.5 sm:gap-4">
            <a href={config.shop.href} class={`relative flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 lg:w-auto lg:px-6 rounded-2xl group ${purpleGradient} ${animClasses}`}>
                <svg class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                <span class="hidden lg:block font-bold font-sans text-xs tracking-[0.2em] ml-3">{config.shop.name}</span>
            </a>

            <CartTrigger />
        </div>

    </div>
</header>