---
import DesktopNavbar from './desktop/DesktopNavbar.astro';
import MobileNavbar from './mobile/MobileNavbar.astro';
import { navConfig } from '../../data/navigation';

// Usunięty ewentualny ukośnik na końcu, żeby aktywne linki zawsze działały poprawnie
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="contents">
    <div class="hidden lg:block">
        <DesktopNavbar config={navConfig} currentPath={currentPath} />
    </div>

    <div class="lg:hidden">
        <MobileNavbar config={navConfig} currentPath={currentPath} />
    </div>
</nav>