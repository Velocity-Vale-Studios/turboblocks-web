---
// src/components/landing/Hero/Hero.astro
import heroData from '/src/data/hero.json';

const { badge, titleFirst, titleSecond, description, serverIP, ctaPrimary } = heroData;
---

<section class="relative min-h-[60vh] md:min-h-[90vh] flex items-center justify-center overflow-hidden pt-24 pb-10 md:pt-10 md:pb-0">

    <div class="absolute top-1/4 -left-10 w-[200px] h-[200px] sm:w-[300px] sm:h-[300px] md:w-[500px] md:h-[500px] bg-pink-500/20 blur-[60px] md:blur-[150px] animate-pulse pointer-events-none"></div>
    <div class="absolute bottom-1/4 -right-10 w-[200px] h-[200px] sm:w-[300px] sm:h-[300px] md:w-[500px] md:h-[500px] bg-cyan-500/20 blur-[60px] md:blur-[150px] animate-pulse pointer-events-none" style="animation-delay: 2s;"></div>

    <div class="relative z-10 text-center px-4 md:px-6 max-w-7xl mx-auto">

        <div class="inline-block px-3 py-1 md:px-4 md:py-1.5 mb-4 md:mb-8 rounded-full bg-cyan-400/10 backdrop-blur-md ring-1 ring-cyan-400/30 shadow-[0_0_15px_rgba(34,211,238,0.2)] animate-fade-in-up">
            <span class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.3em] md:tracking-[0.4em] text-cyan-400 block leading-none">
                {badge}
            </span>
        </div>

        <h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-[120px] xl:text-[160px] font-black italic tracking-tighter leading-[0.9] uppercase flex flex-col md:block items-center mb-4 md:mb-8">
            <span class="text-white drop-shadow-[0_0_20px_rgba(255,255,255,0.1)] md:drop-shadow-[0_0_30px_rgba(255,255,255,0.1)]">
                {titleFirst}
            </span>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 drop-shadow-[0_0_20px_rgba(236,72,153,0.3)] md:drop-shadow-[0_0_30px_rgba(236,72,153,0.3)] md:pr-4">
                {titleSecond}
            </span>
        </h1>

        <p class="text-white/50 text-sm md:text-xl font-medium tracking-wide max-w-lg md:max-w-2xl mx-auto mb-8 md:mb-12 leading-relaxed px-2">
            {description}
        </p>

        <div class="flex flex-col items-center gap-6 w-full">
            <button
                    id="copy-ip-btn"
                    class="relative w-full sm:w-[400px] px-8 py-4 md:py-5 bg-white text-black font-black uppercase text-sm md:text-base tracking-[0.2em] rounded-2xl hover:bg-cyan-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-[0_0_30px_rgba(255,255,255,0.2)] hover:shadow-[0_0_50px_rgba(34,211,238,0.5)] group cursor-pointer"
            >
                <span id="btn-text">{ctaPrimary}</span>
                <span id="copy-success" class="absolute -top-12 left-1/2 -translate-x-1/2 w-max bg-cyan-500 text-white px-4 py-1.5 rounded-xl text-xs font-bold opacity-0 transition-opacity shadow-[0_0_20px_rgba(34,211,238,0.4)] pointer-events-none">
                    IP SKOPIOWANE!
                </span>
            </button>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-3 md:gap-4 w-full sm:w-auto">
                <a
                        href="#modes"
                        class="w-full sm:w-auto px-10 py-3 md:py-4 bg-white/5 border border-white/10 text-white font-black uppercase text-[10px] tracking-[0.3em] rounded-xl backdrop-blur-xl hover:bg-white/10 hover:border-cyan-400/40 transition-all duration-300 hover:scale-105 flex items-center justify-center group"
                >
                    POZNAJ TRYBY
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-y-1 transition-transform text-cyan-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
                    </svg>
                </a>

                <a
                        href="#team"
                        class="w-full sm:w-auto px-10 py-3 md:py-4 bg-white/5 border border-white/10 text-white font-black uppercase text-[10px] tracking-[0.3em] rounded-xl backdrop-blur-xl hover:bg-white/10 hover:border-pink-400/40 transition-all duration-300 hover:scale-105 flex items-center justify-center group"
                >
                    POZNAJ TEAM
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-y-1 transition-transform text-pink-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>

<script define:vars={{ serverIP, ctaPrimary }}>
    const btn = document.getElementById('copy-ip-btn');
    const btnText = document.getElementById('btn-text');
    const successMsg = document.getElementById('copy-success');

    btn?.addEventListener('click', () => {
        navigator.clipboard.writeText(serverIP);

        if(btnText) btnText.innerText = 'SKOPIOWANO ADRES!';
        if(successMsg) successMsg.style.opacity = '1';
        if(btn) {
            btn.style.backgroundColor = '#22d3ee';
            btn.style.color = '#ffffff';
        }

        setTimeout(() => {
            if(btnText) btnText.innerText = ctaPrimary;
            if(successMsg) successMsg.style.opacity = '0';
            if(btn) {
                btn.style.backgroundColor = '#ffffff';
                btn.style.color = '#000000';
            }
        }, 2000);
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelector(this.getAttribute('href')).scrollIntoView({
                behavior: 'smooth'
            });
        });
    });
</script>

<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fade-in-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
    /* Płynne przewijanie na poziomie całej strony */
    html {
        scroll-behavior: smooth;
    }
</style>