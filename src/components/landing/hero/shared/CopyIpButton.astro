---
interface Props {
    ip: string;
    label: string; // Zostawiam w typach, żeby nie wywaliło błędu w głównym pliku, ale go nie używamy!
}
const { ip } = Astro.props;
const animClasses = "transition-all duration-300 hover:scale-105 active:scale-95 transform-gpu";
---

<button
        id="heroCopyBtn"
        data-ip={ip}
        class={`relative flex items-center justify-center px-8 py-4 md:px-12 md:py-5 bg-cyan-500/10 backdrop-blur-md rounded-2xl text-cyan-400 font-bold font-sans text-base md:text-xl tracking-widest uppercase ring-1 ring-inset ring-cyan-400/30 hover:ring-cyan-400/60 hover:bg-cyan-500/20 hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] overflow-hidden group ${animClasses}`}
>
    <div class="relative z-10 grid place-items-center w-full">
        <span id="heroTextDefault" class="col-start-1 row-start-1 transition-all duration-300 opacity-100 scale-100">
            {ip}
        </span>

        <span id="heroTextCopied" class="col-start-1 row-start-1 transition-all duration-300 opacity-0 scale-90 text-white absolute font-black italic">
            COPIED!
        </span>
    </div>
</button>

<script>
    const heroBtn = document.getElementById('heroCopyBtn');
    const heroTextDefault = document.getElementById('heroTextDefault');
    const heroTextCopied = document.getElementById('heroTextCopied');

    const defaultColors = ["bg-cyan-500/10", "text-cyan-400"];
    const activeColors = ["bg-gradient-to-r", "from-cyan-500", "to-blue-600", "text-white", "shadow-[0_0_30px_rgba(34,211,238,0.6)]"];

    heroBtn?.addEventListener('click', () => {
        const ip = heroBtn.getAttribute('data-ip') || '';
        navigator.clipboard.writeText(ip);

        heroBtn.classList.remove(...defaultColors);
        heroBtn.classList.add(...activeColors);

        heroTextDefault?.classList.replace('opacity-100', 'opacity-0');
        heroTextDefault?.classList.add('scale-90');
        heroTextCopied?.classList.replace('opacity-0', 'opacity-100');
        heroTextCopied?.classList.replace('scale-90', 'scale-100');

        setTimeout(() => {
            heroBtn.classList.remove(...activeColors);
            heroBtn.classList.add(...defaultColors);
            heroTextDefault?.classList.replace('opacity-0', 'opacity-100');
            heroTextDefault?.classList.remove('scale-90');
            heroTextCopied?.classList.replace('opacity-100', 'opacity-0');
            heroTextCopied?.classList.replace('scale-100', 'scale-90');
        }, 1500);
    });
</script>