---
interface Props {
    badge: string;
    titleNormal: string;
    titleGradient: string;
    align?: 'left' | 'center';
}

const { badge, titleNormal, titleGradient, align = 'left' } = Astro.props;
const isCenter = align === 'center';
---

<div class={`mb-12 flex flex-col ${isCenter ? 'items-center text-center' : 'items-center md:items-start text-center md:text-left'}`}>
    <div class="inline-block px-4 py-1.5 bg-cyan-400/10 border border-cyan-400/20 rounded-full mb-4 animate-fade-in-up">
    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-cyan-400 block leading-none">
      {badge}
    </span>
    </div>

    <h3 class="text-4xl md:text-6xl lg:text-7xl font-black italic text-white uppercase tracking-tighter leading-[0.9]">
        {titleNormal}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 pr-4 md:pr-10 drop-shadow-[0_0_30px_rgba(236,72,153,0.3)]">
      {titleGradient}
    </span>
    </h3>
</div>