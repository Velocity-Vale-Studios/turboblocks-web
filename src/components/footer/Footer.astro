---
const currentYear = new Date().getFullYear();
---

<footer class="relative mt-20 pb-12 overflow-hidden">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-[400px] bg-gradient-to-t from-purple-500/10 via-cyan-500/5 to-transparent blur-[120px] -z-10"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-white/10 rounded-[2rem] md:rounded-[3rem] p-6 sm:p-8 md:p-16 shadow-[0_0_60px_rgba(0,0,0,0.5)] relative overflow-hidden group">

            {/* Dekoracyjny pasek na górze */}
            <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 relative z-10">

                <div class="lg:col-span-5 space-y-6">
                    <h2 class="text-3xl font-black italic uppercase tracking-tighter text-white leading-none">
                        <span class="text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.1)]">TURBO</span><span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400 drop-shadow-[0_0_15px_rgba(236,72,153,0.3)] pr-2">BLOCKS</span>
                    </h2>
                    <p class="text-white/40 text-sm leading-relaxed max-w-sm font-medium">
                        Top-tier minigames with a <span class="text-cyan-400 drop-shadow-[0_0_5px_rgba(34,211,238,0.3)]">neon-futuristic</span> vibe.
                        Crafted with passion by Velocity Vale Studios for the most demanding players.
                    </p>

                    <div class="flex items-center gap-3 px-4 py-2 bg-white/5 rounded-2xl w-fit border border-white/5 shadow-[0_0_15px_rgba(0,0,0,0.2)] hover:border-green-500/20 transition-colors duration-500">
                        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-white/60">Server Status: <span class="text-green-400">Online</span></span>
                    </div>
                </div>

                <div class="lg:col-span-3 space-y-6">
                    <h4 class="text-[10px] font-black uppercase tracking-[0.5em] text-pink-500 drop-shadow-[0_0_10px_rgba(236,72,153,0.3)]">Navigation</h4>
                    <ul class="space-y-4">
                        <li><a href="/terms" class="text-sm font-bold text-white/40 hover:text-white hover:translate-x-2 transition-all inline-block">Terms of Service</a></li>
                        <li><a href="/privacy" class="text-sm font-bold text-white/40 hover:text-white hover:translate-x-2 transition-all inline-block">Privacy Policy</a></li>
                        <li><a href="/help" class="text-sm font-bold text-white/40 hover:text-white hover:translate-x-2 transition-all inline-block">Help Center</a></li>
                    </ul>
                </div>

                <div class="lg:col-span-4 space-y-6">
                    <h4 class="text-[10px] font-black uppercase tracking-[0.5em] text-cyan-400 drop-shadow-[0_0_10px_rgba(34,211,238,0.3)]">Legal</h4>
                    <p class="text-[10px] leading-relaxed text-white/20 uppercase font-bold tracking-tighter">
                        TurboBlocks is not an official Minecraft product. We are not approved by or associated with Mojang AB.
                        All trademarks belong to their respective owners.
                    </p>
                    <div class="pt-4 border-t border-white/5">
                        <p class="text-[10px] font-black text-white/40 uppercase tracking-widest">
                            &copy; {currentYear} <span class="text-white hover:text-cyan-400 transition-colors cursor-default">Velocity Vale Studios</span>
                        </p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mt-8 flex flex-col md:flex-row justify-between items-center px-2 sm:px-4 md:px-8 gap-4 opacity-30 hover:opacity-100 transition-opacity duration-700">
            <div class="flex gap-6">
                <span class="text-[9px] font-bold text-white uppercase tracking-[0.3em]">Built with Astro & Qwik</span>
            </div>
            <div class="text-[9px] font-bold text-white uppercase tracking-[0.3em]">
                Color Clash Season One // v1.0.0
            </div>
        </div>
    </div>
</footer>