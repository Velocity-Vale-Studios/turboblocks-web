---
// src/components/GameModes.astro
const modes = [
    {
        name: 'Color Clash',
        tag: 'LIVE NOW',
        desc: 'Strategiczna walka o terytorium. Maluj mapę, przejmuj punkty i zdominuj arenę w najbardziej kolorowym trybie sezonu.',
        icon: '🎨',
        gradient: 'from-pink-500/20 via-purple-500/10',
        borderColorClass: 'border-pink-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(236,72,153,0.2)] hover:shadow-[0_0_80px_rgba(236,72,153,0.1)]',
        accent: 'text-pink-400',
        status: 'active',
        btnText: 'O trybie',
        url: '/modes/color-clash'
    },
    {
        name: 'Rocky Raceway',
        tag: 'COMING SOON',
        desc: 'Ekstremalne wyścigi na karkołomnych torach. Fizyka pojazdów, której nie zapomnisz.',
        icon: '🏎️',
        gradient: 'from-cyan-500/10 via-blue-900/5',
        borderColorClass: 'border-cyan-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(6,182,212,0.2)] hover:shadow-[0_0_80px_rgba(6,182,212,0.1)]',
        accent: 'text-cyan-400',
        status: 'future',
        btnText: 'Wkrótce...'
    }
];
---

<section class="max-w-7xl mx-auto px-4 md:px-8 py-16 md:py-24 relative overflow-hidden">
    <div class="mb-10 md:mb-12 flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.5em] md:tracking-[0.8em] text-cyan-400 mb-2">Choose Your Path</h2>
        <h3 class="text-3xl sm:text-4xl md:text-6xl font-black italic text-white uppercase tracking-tighter leading-none">
            AVAILABLE <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400">MODES</span>
        </h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-10 items-stretch">
        {modes.map(mode => (
            /* Zoptymalizowany p-5 na mobile pod S23 */
                <div class={`group relative p-5 md:p-12 rounded-[2.5rem] md:rounded-[3.5rem] border backdrop-blur-3xl transition-all duration-700 overflow-hidden flex flex-col h-full bg-gradient-to-br from-white/5 to-white/[0.02] ${mode.borderColorClass} ${mode.glowClass}`}>

                    <div class={`absolute inset-0 bg-gradient-to-br ${mode.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-700`}></div>

                    <div class="relative z-10 flex flex-col h-full">
                        <div class="flex justify-between items-start mb-8 md:mb-12">
                            <div class={`w-14 h-14 md:w-20 md:h-20 rounded-2xl md:rounded-[2rem] border border-white/10 flex items-center justify-center text-2xl md:text-4xl shadow-lg shadow-white/5 ${
                                mode.status === 'active' ? 'bg-white/5' : 'bg-black/20 grayscale'
                            }`}>
                                {mode.icon}
                            </div>

                            <span class={`text-[7px] md:text-[10px] font-black uppercase tracking-[0.2em] md:tracking-[0.3em] py-1.5 px-3 md:py-2 md:px-5 rounded-full border border-white/10 shadow-[0_0_15px_rgba(0,0,0,0.2)] ${
                                mode.status === 'active' ? 'bg-pink-500/10 text-pink-400' : 'bg-white/5 text-white/20'
                            }`}>
                            {mode.tag}
                        </span>
                        </div>

                        <h4 class={`text-2xl md:text-5xl font-black italic uppercase tracking-tighter mb-4 md:mb-6 ${
                            mode.status === 'active' ? 'text-white' : 'text-white/40'
                        }`}>
                            {mode.name}
                        </h4>

                        <p class="text-white/60 text-xs md:text-lg font-medium italic border-l-2 md:border-l-4 border-white/10 pl-4 md:pl-6 leading-relaxed mb-8 md:mb-12">
                            {mode.desc}
                        </p>

                        <div class="mt-auto flex flex-wrap items-center gap-3">
                            {mode.status === 'active' ? (
                                    <>
                                        <a href={mode.url} class="flex-1 sm:flex-none text-center px-5 py-3 bg-white text-black font-black uppercase text-[10px] md:text-xs tracking-widest rounded-xl md:rounded-2xl hover:scale-105 hover:bg-pink-500 hover:text-white transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.2)]">
                                            {mode.btnText}
                                        </a>
                                        <div class="flex items-center justify-center px-4 py-3 bg-white/5 border border-white/10 rounded-xl md:rounded-2xl backdrop-blur-md">
                                            <div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse mr-2 shadow-[0_0_10px_#22c55e]"></div>
                                            <span class="text-white/60 font-black text-[8px] md:text-[10px] uppercase tracking-widest whitespace-nowrap">124 ONLINE</span>
                                        </div>
                                    </>
                            ) : (
                                    <div class="flex items-center justify-center px-5 py-3 bg-white/5 border border-white/10 rounded-xl md:rounded-2xl text-white/20 font-black uppercase text-[10px] md:text-xs tracking-widest italic cursor-not-allowed">
                                        {mode.btnText}
                                    </div>
                            )}
                        </div>
                    </div>

                    {mode.status === 'future' && (
                            <div class="absolute top-4 right-4 md:top-12 md:right-12 text-white/5 rotate-12">
                                <svg class="w-12 h-12 md:w-24 md:h-24" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1v-3a5 5 0 0 0-5-5zm-3 5a3 3 0 0 1 6 0v3H9V7zm3 11a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                                </svg>
                            </div>
                    )}
                </div>
        ))}
    </div>
</section>