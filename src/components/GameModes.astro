---
const modes = [
    {
        name: 'Color Clash',
        tag: 'LIVE NOW',
        desc: 'Strategiczna walka o terytorium. Maluj mapę, przejmuj punkty i zdominuj arenę w najbardziej kolorowym trybie sezonu.',
        icon: '🎨',
        gradient: 'from-pink-500/20 via-purple-500/10',
        accent: 'text-pink-400',
        status: 'active',
        btnText: 'Zagraj Teraz'
    },
    {
        name: 'Rocky Raceway',
        tag: 'COMING SOON',
        desc: 'Ekstremalne wyścigi na karkołomnych torach. Fizyka pojazdów, której nie zapomnisz.',
        icon: '🏎️',
        gradient: 'from-cyan-500/10 via-blue-900/5',
        accent: 'text-cyan-400',
        status: 'future',
        btnText: 'Wkrótce...'
    }
];
---

<section class="max-w-7xl mx-auto px-8 py-24 relative overflow-hidden">
    <div class="mb-16">
        <h3 class="text-6xl font-[1000] italic text-white uppercase tracking-tighter leading-none">
            AVAILABLE <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400">MODES</span>
        </h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch">
        {modes.map(mode => (
            /* h-full i flex-col pozwalają nam użyć mt-auto na dole */
                <div class={`group relative p-12 rounded-[3.5rem] border backdrop-blur-xl transition-all duration-700 overflow-hidden flex flex-col h-full ${
                    mode.status === 'active'
                        ? `bg-white/[0.03] border-white/10 hover:border-pink-500/50`
                        : 'bg-black/40 border-white/5 opacity-80'
                }`}>

                    <div class={`absolute inset-0 bg-gradient-to-br ${mode.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-700`}></div>

                    <div class="relative z-10 flex flex-col h-full">
                        <div class="flex justify-between items-start mb-12">
                            <div class={`w-20 h-20 rounded-[2rem] border border-white/10 flex items-center justify-center text-4xl ${
                                mode.status === 'active' ? 'bg-white/5' : 'bg-black/20 grayscale'
                            }`}>
                                {mode.icon}
                            </div>
                            <span class={`text-[10px] font-black uppercase tracking-[0.3em] py-2 px-5 rounded-full border border-white/10 ${
                                mode.status === 'active' ? 'bg-pink-500/10 text-pink-400' : 'bg-white/5 text-white/20'
                            }`}>
                            {mode.tag}
                        </span>
                        </div>

                        <h4 class={`text-5xl font-[1000] italic uppercase tracking-tighter mb-6 ${
                            mode.status === 'active' ? 'text-white' : 'text-white/40'
                        }`}>
                            {mode.name}
                        </h4>

                        <p class="text-white/30 text-base leading-relaxed mb-12 font-medium italic">
                            {mode.desc}
                        </p>

                        <div class="mt-auto flex flex-wrap items-center gap-4">
                            {mode.status === 'active' ? (
                                    <>
                                        <a href="/modes/color-clash" class="flex items-center justify-center h-14 px-10 bg-white text-black font-black uppercase text-[10px] tracking-widest rounded-2xl hover:bg-cyan-400 transition-all shadow-[0_10px_20px_rgba(255,255,255,0.1)]">
                                            {mode.btnText}
                                        </a>
                                        <div class="flex items-center justify-center h-14 px-6 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
                                            <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse mr-3"></div>
                                            <span class="text-white/60 font-black text-[10px] uppercase tracking-widest">124 ONLINE</span>
                                        </div>
                                    </>
                            ) : (
                                    <div class="flex items-center justify-center h-14 px-10 bg-white/5 border border-white/10 rounded-2xl text-white/20 font-black uppercase text-[10px] tracking-widest italic cursor-not-allowed w-fit">
                                        {mode.btnText}
                                    </div>
                            )}
                        </div>
                    </div>

                    {mode.status === 'future' && (
                            <div class="absolute top-12 right-12 text-white/5 rotate-12">
                                <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1v-3a5 5 0 0 0-5-5zm-3 5a3 3 0 0 1 6 0v3H9V7zm3 11a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                                </svg>
                            </div>
                    )}
                </div>
        ))}
    </div>
</section>