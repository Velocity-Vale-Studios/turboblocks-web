---
const rightLinks = [
  { name: 'HOME', href: '/' },
  { name: 'MODES', href: '/modes' },
  { name: 'INSIDES', href: '/blog' },
];

const currentPath = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/';
const cartItems = '';
const animClasses = "transition-all duration-300 hover:scale-105 active:scale-95 transform-gpu";
// Wspólny styl dla fioletowych elementów
const purpleGradient = "bg-gradient-to-r from-pink-500 to-purple-600 text-white shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_30px_rgba(236,72,153,0.6)]";

const baseLayoutClasses = `relative px-6 py-3 text-xs font-bold font-sans uppercase tracking-[0.2em] rounded-2xl ${animClasses} flex items-center justify-center`;
const inactiveLinkClasses = `text-white/60 ring-1 ring-inset ring-transparent hover:text-cyan-100 hover:bg-cyan-500/10 hover:ring-cyan-400/30 hover:shadow-[0_0_15px_rgba(34,211,238,0.2)] hover:backdrop-blur-md`;
const activeLinkClasses = `bg-gradient-to-r from-cyan-500/10 to-blue-500/10 text-cyan-100 ring-1 ring-inset ring-cyan-400/30 shadow-[0_0_20px_rgba(34,211,238,0.3)] backdrop-blur-md scale-105`;

const isCurrent = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
};
---

<style>
  .menu-open span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .menu-open span:nth-child(2) {
    opacity: 0;
  }
  .menu-open span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Frosted glass effect for mobile menu - same as navbar */
  #mobileMenu {
    background: rgba(255, 255, 255, 0.02) !important;
    -webkit-backdrop-filter: blur(40px) !important;
    backdrop-filter: blur(40px) !important;
    isolation: isolate;
  }

  /* Enhancement layer - same style as navbar */
  #mobileMenu::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
    border-radius: inherit;
    pointer-events: none;
    z-index: -1;
  }

  /* Firefox fallback */
  @supports not (backdrop-filter: blur(1px)) {
    #mobileMenu {
      background: rgba(10, 10, 10, 0.9) !important;
    }
  }
</style>

<header class="fixed top-4 inset-x-0 mx-auto w-[95%] max-w-7xl z-50 bg-white/[0.02] backdrop-blur-2xl border border-white/10 h-20 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
  <div class="relative w-full px-4 md:px-8 flex justify-between items-center h-full">

    <div class="flex items-center gap-4">
      <button id="copyIP" class={`relative flex items-center gap-3 px-4 md:px-6 py-3 bg-gradient-to-r from-cyan-500/10 to-blue-500/10 backdrop-blur-md rounded-2xl text-cyan-400 font-bold font-sans text-xs tracking-widest ring-1 ring-inset ring-cyan-400/30 group ${animClasses} shadow-[0_0_20px_rgba(34,211,238,0.1)] hover:shadow-[0_0_30px_rgba(34,211,238,0.4)]`}>
        <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse group-hover:shadow-[0_0_10px_#22d3ee] block"></span>
        <span id="ipText" class="hidden lg:inline">PLAY.TURBOBLOCKS.EU</span>
        <span class="lg:hidden">IP</span>
      </button>

      <a href="https://discord.gg/vuG3EQtV4" target="_blank" class={`grid w-10 h-10 place-items-center rounded-2xl bg-gradient-to-r from-indigo-500/10 to-purple-500/10 backdrop-blur-md text-indigo-400 ring-1 ring-inset ring-indigo-500/30 group ${animClasses} shadow-[0_0_20px_rgba(129,140,248,0.1)] hover:shadow-[0_0_30px_rgba(129,140,248,0.4)]`}>
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.086 2.157 2.419 0 1.334-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.086 2.157 2.419 0 1.334-.946 2.419-2.157 2.419z"/>
        </svg>
      </a>
    </div>

    <div class="absolute left-1/2 -translate-x-1/2 hidden lg:flex items-center gap-4">
      <a href="/blog" class={`${baseLayoutClasses} ${isCurrent('/blog') ? activeLinkClasses : inactiveLinkClasses}`}>
        <span class="relative z-10">INSIDES</span>
      </a>

      <a href="/" class={`${baseLayoutClasses} ${isCurrent('/') ? activeLinkClasses : inactiveLinkClasses}`}>
        <span class="relative z-10">HOME</span>
      </a>

      <a href="/modes" class={`${baseLayoutClasses} ${isCurrent('/modes') ? activeLinkClasses : inactiveLinkClasses}`}>
        <span class="relative z-10">MODES</span>
      </a>
    </div>

    <div class="flex items-center gap-2">

      <a href="/shop" class={`hidden lg:flex items-center gap-3 px-6 py-3 rounded-2xl text-white text-xs font-bold font-sans tracking-widest ${purpleGradient} ${animClasses}`}>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        STORE
      </a>

      <a href="/shop" class={`lg:hidden flex items-center justify-center w-10 h-10 rounded-2xl ${purpleGradient} ${animClasses}`}>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
      </a>

      <button onclick="toggleCart()" class={`relative flex items-center justify-center w-10 h-10 rounded-2xl ${purpleGradient} ${animClasses}`}>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <span id="navbar-cart-count" class="opacity-0 absolute -top-1.5 -right-1.5 w-4 h-4 bg-white text-pink-600 text-[10px] font-bold rounded-full flex items-center justify-center shadow-sm">{cartItems}</span>
      </button>

      <button id="menuBtn" class={`lg:hidden flex flex-col gap-1.5 w-10 h-10 items-center justify-center rounded-2xl ${purpleGradient} ${animClasses}`}>
        <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
        <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
        <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
      </button>
    </div>
  </div>
</header>

<div id="mobileMenu" class="lg:hidden fixed top-[calc(1rem+5rem+1rem)] inset-x-0 mx-auto w-[95%] max-w-7xl z-50 rounded-[2rem] border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-300 origin-top transform scale-95 opacity-0 pointer-events-none">
  <div class="flex flex-col gap-4 px-6 md:px-10 py-8">
    {rightLinks.map(link => (
        <a href={link.href} class={`text-center py-4 px-8 text-xs font-bold font-sans uppercase tracking-[0.2em] rounded-2xl ${animClasses} flex items-center justify-center ${isCurrent(link.href) ? activeLinkClasses : inactiveLinkClasses}`}>
          {link.name}
        </a>
    ))}
  </div>
</div>

<script>
  // Logika kopiowania IP
  document.getElementById('copyIP')?.addEventListener('click', () => {
    const ip = "play.turboblocks.eu";
    navigator.clipboard.writeText(ip);
    const text = document.getElementById('ipText');
    if (text) {
      const old = text.innerText;
      text.innerText = "COPIED!";
      setTimeout(() => text.innerText = old, 1500);
    }
  });
</script>
<script>
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  menuBtn?.addEventListener('click', () => {
    // Toggle class for burger animation
    menuBtn.classList.toggle('menu-open');

    const isMenuOpen = menuBtn.classList.contains('menu-open');

    if (mobileMenu) {
      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
      } else {
        mobileMenu.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
      }
    }
  });
</script>
