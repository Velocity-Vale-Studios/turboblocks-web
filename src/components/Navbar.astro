---
const rightLinks = [
  { name: 'HOME', href: '/' },
  { name: 'MODES', href: '/modes' },
  { name: 'INSIDES', href: '/blog' },
];

const currentPath = new URL(Astro.request.url).pathname;
const cartItems = 3;
---

<header class="fixed top-4 left-1/2 -translate-x-1/2 w-[95%] max-w-7xl z-50 bg-white/[0.02] backdrop-blur-2xl border border-white/10 h-20 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
  <div class="w-full px-8 flex justify-between items-center h-full">

    <div class="flex items-center gap-4">
      <button
          id="copyIP"
          class="flex items-center gap-3 px-6 py-3 bg-gradient-to-r from-cyan-500/10 to-blue-500/10 backdrop-blur-md border border-cyan-400/30 rounded-2xl text-cyan-400 font-bold font-sans text-xs tracking-widest hover:bg-cyan-500/20 hover:border-cyan-400/50 hover:text-cyan-100 hover:shadow-[0_0_20px_rgba(34,211,238,0.3)] hover:scale-105 transition-all duration-300 group shadow-[0_0_15px_rgba(34,211,238,0.1)]"
      >
        <div class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse group-hover:shadow-[0_0_10px_#22d3ee]"></div>
        <span id="ipText">PLAY.TURBOBLOCKS.EU</span>
      </button>

      <a
          href="https://discord.gg/vuG3EQtV4"
          target="_blank"
          class="hidden sm:flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 backdrop-blur-md border border-indigo-500/30 rounded-2xl text-indigo-400 font-bold font-sans text-xs tracking-widest hover:bg-indigo-500/20 hover:border-indigo-500/50 hover:text-indigo-100 hover:shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:scale-105 transition-all duration-300 shadow-[0_0_15px_rgba(99,102,241,0.1)]"
      >
        DISCORD
      </a>
    </div>

    <nav class="hidden lg:flex items-center gap-4 ml-auto">
      {rightLinks.map(link => {
        const active = currentPath === link.href;
        return (
            <a
                href={link.href}
                class={`relative px-6 py-3 text-xs font-bold font-sans uppercase tracking-[0.2em] transition-all duration-300 rounded-2xl ${
                    active
                        ? 'bg-gradient-to-r from-cyan-500/10 to-blue-500/10 text-cyan-100 border border-cyan-400/30 shadow-[0_0_20px_rgba(34,211,238,0.3)] backdrop-blur-md scale-105'
                        : 'text-white/60 border border-transparent hover:text-cyan-100 hover:bg-cyan-500/10 hover:border-cyan-400/30 hover:shadow-[0_0_15px_rgba(34,211,238,0.2)] hover:backdrop-blur-md hover:scale-105'
                }`}
            >
              <span class="relative z-10">{link.name}</span>
            </a>
        );
      })}

      <a
          href="/shop"
          class="relative flex items-center gap-3 px-6 py-3 rounded-2xl bg-gradient-to-r from-pink-500 to-purple-600 text-white text-xs font-bold font-sans tracking-widest hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_30px_rgba(236,72,153,0.6)] group ml-4"
      >
        <svg class="w-4 h-4 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        STORE
      </a>

      <button
          onclick="toggleCart()"
          class="relative flex items-center justify-center w-10 h-10 rounded-2xl bg-gradient-to-r from-pink-500 to-purple-600 text-white hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_30px_rgba(236,72,153,0.6)] ml-2 group"
      >
        <div class="relative">
          <svg class="w-4 h-4 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span id="navbar-cart-count" class="absolute -top-2 -right-2 w-4 h-4 bg-white text-pink-600 text-[10px] font-bold font-sans rounded-full flex items-center justify-center opacity-0 transition-opacity shadow-sm">0</span>
        </div>
      </button>
    </nav>

    <button id="menuBtn" class="lg:hidden p-3 bg-white/5 rounded-xl text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>

  <div id="mobileMenu" class="hidden absolute top-24 left-0 right-0 bg-[#0a0a0a]/95 backdrop-blur-3xl border border-white/10 rounded-[2rem] p-8 mx-4 shadow-2xl">
    <div class="flex flex-col gap-6 text-center">
      {rightLinks.map(link => (
          <a href={link.href} class="text-xl font-black italic text-white/60 hover:text-cyan-400 transition-colors uppercase">
            {link.name}
          </a>
      ))}
      <a href="/shop" class="py-4 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl text-white font-black uppercase">
        STORE ({cartItems})
      </a>
    </div>
  </div>
</header>

<script>
  // IP Copy Logic
  const copyBtn = document.getElementById('copyIP');
  const ipText = document.getElementById('ipText');

  copyBtn?.addEventListener('click', () => {
    const ip = "play.turboblocks.eu";
    navigator.clipboard.writeText(ip);
    if (ipText) {
      ipText.innerText = "COPIED!";
      copyBtn.style.backgroundColor = "rgba(34, 211, 238, 0.4)";
      setTimeout(() => {
        ipText.innerText = ip.toUpperCase();
        copyBtn.style.backgroundColor = "";
      }, 1500);
    }
  });

  // Mobile Menu Logic
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
