---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Color Clash - Tryb Gry">
    <main class="max-w-7xl mx-auto px-6 md:px-8 pt-[140px] pb-24 overflow-visible">

        {/* HEADER SECTION */}
        <div class="mb-24 flex flex-col items-center md:items-start text-center md:text-left relative">
            <div class="absolute -top-20 -left-20 w-96 h-96 bg-pink-500/20 blur-[150px] -z-10 animate-pulse"></div>
            <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-4">Spectacle-Driven Mode</h2>
            <h1 class="text-7xl md:text-9xl font-black italic text-white uppercase tracking-tighter leading-none mb-8">
                COLOR <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-400 pr-6 md:pr-12">CLASH</span>
            </h1>

            <div class="flex flex-wrap justify-center md:justify-start gap-4">
                <button class="px-8 py-4 bg-white text-black font-black uppercase text-xs tracking-widest rounded-2xl hover:bg-pink-500 hover:text-white transition-all duration-300 hover:scale-110 active:scale-95 shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_40px_rgba(236,72,153,0.5)]">
                    Zagraj Teraz
                </button>
                <div class="px-8 py-4 bg-white/5 border border-white/10 text-white/60 font-black uppercase text-xs tracking-widest rounded-2xl backdrop-blur-md flex items-center gap-3">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></span>
                    LIVE NOW
                </div>
            </div>
        </div>

        {/* HERO CARD */}
        <section class="mb-32 relative">
            <div class="-m-6 md:-m-12 p-6 md:p-12">
                <div class="relative rounded-[3.5rem] p-10 md:p-16 overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-3xl border border-pink-500/20 shadow-[0_0_60px_rgba(236,72,153,0.15)] group transition-all duration-700 hover:border-pink-500/40">
                    <div class="absolute inset-0 bg-gradient-to-br from-pink-500/10 via-purple-500/5 to-transparent opacity-20 group-hover:opacity-40 transition-opacity duration-700"></div>

                    <div class="relative z-10 flex flex-col md:flex-row gap-12 items-center">
                        <div class="flex-1">
                            <h2 class="text-3xl md:text-5xl font-black italic text-white uppercase tracking-tighter leading-tight mb-8">
                                "Mapa zapamięta, kto był <span class="text-pink-400">najsilniejszy</span>."
                            </h2>
                            <p class="text-white/50 text-lg font-medium leading-relaxed mb-8 border-l-4 border-white/10 pl-6">
                                W Color Clash kolor to nie tylko kosmetyka – to Twoja broń, tożsamość i energia.
                            </p>
                            <div class="flex items-center gap-4">
                                <div class="bg-black/30 px-6 py-3 rounded-xl border border-white/5 backdrop-blur-md">
                                    <span class="text-[9px] font-black text-white/30 uppercase tracking-widest block mb-1">Players</span>
                                    <span class="text-white font-black italic text-xl uppercase tracking-tighter">UP TO 16</span>
                                </div>
                                <div class="bg-black/30 px-6 py-3 rounded-xl border border-white/5 backdrop-blur-md">
                                    <span class="text-[9px] font-black text-white/30 uppercase tracking-widest block mb-1">Duration</span>
                                    <span class="text-white font-black italic text-xl uppercase tracking-tighter">8-15 MIN</span>
                                </div>
                            </div>
                        </div>
                        <div class="w-full md:w-1/3 aspect-square bg-gradient-to-br from-pink-500/20 to-purple-500/20 rounded-[2.5rem] border border-white/10 flex items-center justify-center relative overflow-hidden group/icon">
                            <div class="absolute inset-0 blur-3xl bg-pink-500/20 group-hover/icon:bg-pink-500/30 transition-all"></div>
                            <div class="text-9xl filter drop-shadow-[0_0_30px_rgba(236,72,153,0.5)] group-hover/icon:scale-110 group-hover/icon:rotate-12 transition-all duration-700">🎨</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* MECHANICS GRID */}
        <section class="mb-32">
            <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">Core Mechanics</h2>
                <h3 class="text-5xl font-black italic text-white uppercase tracking-tighter">How to <span class="text-pink-400">Win</span></h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {[
                    { title: "Paint as Power", icon: "💥", desc: "Każda pomalowana powierzchnia to przejęta energia.", color: "pink", glow: "rgba(236,72,153,0.2)" },
                    { title: "Combo Flow", icon: "⚡", desc: "Utrzymuj rytm malowania bez eliminacji, aby wejść w stan Flow.", color: "cyan", glow: "rgba(34,211,238,0.2)" },
                    { title: "Overload", icon: "🌀", desc: "Momentum jest ważniejsze niż przetrwanie. Rozpłyń się w kolorze.", color: "purple", glow: "rgba(168,85,247,0.2)" }
                ].map(item => (
                        <div class={`group relative bg-white/[0.02] border border-white/10 backdrop-blur-md rounded-[2.5rem] p-10 hover:-translate-y-2 transition-all duration-500 hover:border-white/20 hover:shadow-[0_0_40px_${item.glow}] overflow-hidden`}>
                            <div class="relative z-10">
                                <div class="text-5xl mb-6 filter drop-shadow-lg group-hover:scale-110 group-hover:rotate-6 transition-all duration-300 transform origin-left">{item.icon}</div>
                                <h4 class="text-2xl font-black italic text-white uppercase tracking-tighter mb-4">{item.title}</h4>
                                <p class="text-white/40 text-sm font-medium leading-relaxed group-hover:text-white/60 transition-colors">{item.desc}</p>
                            </div>
                        </div>
                ))}
            </div>
        </section>

        {/* GAME TYPES */}
        <section class="mb-32">
            <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">Game Types</h2>
                <h3 class="text-5xl font-black italic text-white uppercase tracking-tighter">Choose your <span class="text-purple-400">Arena</span></h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {[
                    { icon: "👤", tag: "Solo", title: "Free-for-All", desc: "Czysta rywalizacja. Tylko Ty, Twoje narzędzia i mapa.", color: "cyan", glow: "rgba(6,182,212,0.15)" },
                    { icon: "👥", tag: "4vs4", title: "Team Battle", desc: "Strategiczna koordynacja. Łączcie plamy koloru.", color: "purple", glow: "rgba(168,85,247,0.15)" },
                    { icon: "⚠️", tag: "Extreme", title: "Chaos Mode", desc: "Zasady przestają istnieć. Dynamiczne eventy.", color: "pink", glow: "rgba(236,72,153,0.2)" }
                ].map(card => (
                        <div class={`group relative rounded-[3rem] p-10 bg-white/[0.02] border border-white/10 backdrop-blur-md hover:-translate-y-1 transition-all duration-500 overflow-hidden hover:shadow-[0_0_40px_${card.glow}] hover:border-${card.color}-500/40`}>
                            <div class={`absolute top-0 right-0 w-64 h-64 bg-${card.color}-500/10 blur-[80px] -z-10 group-hover:bg-${card.color}-500/20 transition-all duration-700`}></div>
                            <div class="flex justify-between items-start mb-8 relative z-10">
                                <div class="text-4xl group-hover:scale-110 transition-all duration-300">{card.icon}</div>
                                <span class={`px-3 py-1 bg-${card.color}-500/10 border border-${card.color}-500/20 rounded-lg text-[10px] font-black text-${card.color}-400 uppercase tracking-widest group-hover:bg-${card.color}-500 group-hover:text-white transition-colors`}>{card.tag}</span>
                            </div>
                            <h4 class="text-3xl font-black italic text-white uppercase tracking-tighter mb-4">{card.title}</h4>
                            <p class="text-white/40 text-sm leading-relaxed font-medium group-hover:text-white/60 transition-colors">{card.desc}</p>
                        </div>
                ))}
            </div>
        </section>

        {/* REGIONS (Wszystkie 4!) */}
        <section class="mb-32">
            <div class="mb-12 flex flex-col items-center md:items-start text-center md:text-left">
                <h2 class="text-[10px] font-black uppercase tracking-[0.8em] text-cyan-400 mb-2">World</h2>
                <h3 class="text-5xl font-black italic text-white uppercase tracking-tighter">Chromatic <span class="text-cyan-400">Regions</span></h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                {[
                    { title: "Neon City", subtitle: "Region 01 // Megacity", icon: "🏙️", color: "cyan", glow: "rgba(6,182,212,0.4)" },
                    { title: "Volcanic Island", subtitle: "Region 02 // Core", icon: "🌋", color: "orange", glow: "rgba(249,115,22,0.4)" },
                    { title: "Frozen Realm", subtitle: "Region 03 // Void", icon: "❄️", color: "blue", glow: "rgba(59,130,246,0.4)" },
                    { title: "Rainbow Maze", subtitle: "Region 04 // Experim.", icon: "🌀", color: "pink", glow: "rgba(236,72,153,0.4)" }
                ].map(map => (
                        <div class="group relative -m-6 p-6">
                            <div class="relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[3.5rem] p-10 transition-all duration-500 hover:border-white/20 hover:shadow-[0_0_50px_rgba(255,255,255,0.05)]">
                                <div class={`absolute -top-24 -right-24 w-80 h-80 bg-${map.color}-500/10 blur-[100px] group-hover:bg-${map.color}-500/20 transition-all duration-700 group-hover:scale-125`}></div>

                                <div class="relative z-10">
                                    <div class="flex justify-between items-start mb-8">
                                        <div>
                                            <span class={`text-[10px] font-black text-${map.color}-400 uppercase tracking-widest mb-2 block`}>{map.subtitle}</span>
                                            <h4 class="text-4xl font-black italic text-white uppercase tracking-tighter group-hover:translate-x-3 transition-transform duration-500">{map.title}</h4>
                                        </div>
                                        <span class="text-4xl filter drop-shadow-[0_0_15px_rgba(255,255,255,0.1)] group-hover:scale-110 group-hover:rotate-12 transition-transform duration-500">{map.icon}</span>
                                    </div>
                                    <p class="text-white/40 text-sm font-medium leading-relaxed mb-8 max-w-md group-hover:text-white/60">
                                        Eksploruj unikalne warunki regionu {map.title}.
                                    </p>
                                    <button class={`w-full py-4 rounded-xl font-black uppercase text-[10px] tracking-widest transition-all duration-500 active:scale-95 border border-white/10 bg-white/5 hover:bg-white text-white/60 hover:text-black hover:shadow-[0_0_40px_${map.glow}] hover:scale-105`}>
                                        Eksploruj Region
                                    </button>
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </section>

    </main>
</Layout>