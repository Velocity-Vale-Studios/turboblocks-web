---
const rightLinks = [
  { name: 'HOME', href: '/' },
  { name: 'MODES', href: '/modes' },
  { name: 'INSIDES', href: '/blog' },
];

const currentPath = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/';
const cartItems = '';
const animClasses = "transition-all duration-300 hover:scale-105 active:scale-95 transform-gpu";
const purpleGradient = "bg-gradient-to-r from-pink-500 to-purple-600 text-white shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_30px_rgba(236,72,153,0.6)]";

// DEFINICJA WSPÓLNEJ WYSOKOŚCI I PADDINGU
const commonHeight = "h-9 sm:h-10";
const commonPadding = "px-4 sm:px-6";

const baseLayoutClasses = `relative ${commonHeight} ${commonPadding} text-xs font-bold font-sans uppercase tracking-[0.2em] rounded-2xl ${animClasses} flex items-center justify-center`;
const inactiveLinkClasses = `text-white/60 ring-1 ring-inset ring-transparent hover:text-cyan-100 hover:bg-cyan-500/10 hover:ring-cyan-400/30 hover:shadow-[0_0_15px_rgba(34,211,238,0.2)] hover:backdrop-blur-md`;
const activeLinkClasses = `bg-gradient-to-r from-cyan-500/10 to-blue-500/10 text-cyan-100 ring-1 ring-inset ring-cyan-400/30 shadow-[0_0_20px_rgba(34,211,238,0.3)] backdrop-blur-md scale-105`;

const isCurrent = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
};
---

<style>
  /* Animacja burgera w X */
  .menu-open span:nth-child(1) {
    transform: rotate(45deg);
    position: absolute; /* Nakładamy na siebie */
  }
  .menu-open span:nth-child(2) {
    opacity: 0;
    transform: scale(0);
  }
  .menu-open span:nth-child(3) {
    transform: rotate(-45deg);
    position: absolute; /* Nakładamy na siebie */
  }

  /* Reszta Twoich stylów zostaje bez zmian */
  #mobileMenu {
    background: rgba(255, 255, 255, 0.02) !important;
    backdrop-filter: blur(40px) !important;
  }
  #mobileMenu::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
    border-radius: inherit;
    pointer-events: none;
    z-index: -1;
  }

  @supports not (backdrop-filter: blur(1px)) {
    #mobileMenu { background: rgba(10, 10, 10, 0.9) !important; }
  }
</style>

<header class="fixed top-4 left-0 right-0 mx-auto w-[94%] max-w-7xl z-50 bg-white/[0.02] backdrop-blur-2xl border border-white/10 py-4 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
  <div class="relative w-full px-2 sm:px-4 flex justify-between items-center">

    <div class="flex items-center gap-1.5 sm:gap-4">
      <button id="copyIP" class={`relative flex items-center justify-center lg:gap-3 p-0 px-4 lg:px-6 h-9 sm:h-10 lg:w-auto bg-cyan-500/10 backdrop-blur-md rounded-2xl text-cyan-400 font-bold font-sans text-xs tracking-widest ring-1 ring-inset ring-cyan-400/30 overflow-hidden group ${animClasses}`}>
        <div class="relative z-10 grid place-items-center">
          <div class="hidden lg:grid place-items-center">
            <span id="ipTextDefault" class="col-start-1 row-start-1 transition-all duration-300 opacity-100 scale-100">PLAY.TURBOBLOCKS.EU</span>
            <span id="ipTextCopied" class="col-start-1 row-start-1 transition-all duration-300 opacity-0 scale-90 text-white absolute">COPIED!</span>
          </div>
          <div class="lg:hidden grid place-items-center">
            <span id="ipMobileDefault" class="col-start-1 row-start-1 transition-all duration-300 opacity-100 scale-100 text-[9px] leading-none">IP</span>
            <span id="ipMobileCopied" class="col-start-1 row-start-1 transition-all duration-300 opacity-0 scale-50 text-white text-base leading-none">✓</span>
          </div>
        </div>
      </button>

      <a href="https://discord.gg/vuG3EQtV4" target="_blank" class={`grid w-9 h-9 sm:w-10 sm:h-10 place-items-center rounded-2xl bg-gradient-to-r from-indigo-500/10 to-purple-500/10 backdrop-blur-md text-indigo-400 ring-1 ring-inset ring-indigo-500/30 group ${animClasses}`}>
        <svg class="w-4 h-4 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.086 2.157 2.419 0 1.334-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.086 2.157 2.419 0 1.334-.946 2.419-2.157 2.419z"/>
        </svg>
      </a>
    </div>

    <div class="absolute left-1/2 -translate-x-1/2 hidden lg:flex items-center gap-4">
      <a href="/src/pages/modes" class={`h-10 ${baseLayoutClasses} ${isCurrent('/modes') ? activeLinkClasses : inactiveLinkClasses}`}>MODES</a>
      <a href="/" class={`h-10 ${baseLayoutClasses} ${isCurrent('/') ? activeLinkClasses : inactiveLinkClasses}`}>HOME</a>
      <a href="/blog" class={`h-10 ${baseLayoutClasses} ${isCurrent('/blog') ? activeLinkClasses : inactiveLinkClasses}`}>INSIDES</a>
    </div>

    <div class="flex items-center gap-1.5 sm:gap-4">
      <a href="/shop" class={`relative flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 lg:w-auto lg:px-6 rounded-2xl ${purpleGradient} ${animClasses}`}>
        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <span class="hidden lg:block font-bold font-sans text-xs tracking-[0.2em] ml-3">SHOP</span>
      </a>

      <button onclick="toggleCart()" class={`relative flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-2xl ${purpleGradient} ${animClasses}`}>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </button>

      <button id="menuBtn" class={`lg:hidden relative flex flex-col gap-[6px] w-9 h-9 sm:w-10 sm:h-10 items-center justify-center rounded-2xl ${purpleGradient} ${animClasses}`}>
        <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
        <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
        <span class="w-5 h-0.5 bg-white rounded-full transition-all duration-300"></span>
      </button>
    </div>
  </div>
</header>

<div id="mobileMenu" class="lg:hidden fixed top-[calc(1rem+5rem+1rem)] inset-x-0 mx-auto w-[95%] max-w-7xl z-50 rounded-[2rem] border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-300 origin-top transform scale-95 opacity-0 pointer-events-none">
  <div class="flex flex-col gap-4 px-6 md:px-10 py-8">
    {rightLinks.map(link => (
        <a href={link.href} class={`text-center py-4 px-8 text-xs font-bold font-sans uppercase tracking-[0.2em] rounded-2xl ${animClasses} flex items-center justify-center ${isCurrent(link.href) ? activeLinkClasses : inactiveLinkClasses}`}>
          {link.name}
        </a>
    ))}
  </div>
</div>

<script>
  const copyBtn = document.getElementById('copyIP');
  const textDefault = document.getElementById('ipTextDefault');
  const textCopied = document.getElementById('ipTextCopied');
  const mobileDefault = document.getElementById('ipMobileDefault');
  const mobileCopied = document.getElementById('ipMobileCopied');

  const defaultColors = ["bg-cyan-500/10", "text-cyan-400"];
  const activeColors = ["bg-gradient-to-r", "from-cyan-500", "to-blue-600", "text-white", "shadow-[0_0_20px_rgba(34,211,238,0.5)]"];

  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText("play.turboblocks.eu");
    copyBtn.classList.remove(...defaultColors);
    copyBtn.classList.add(...activeColors);

    textDefault?.classList.replace('opacity-100', 'opacity-0');
    textDefault?.classList.add('scale-90');
    textCopied?.classList.replace('opacity-0', 'opacity-100');
    textCopied?.classList.replace('scale-90', 'scale-100');

    mobileDefault?.classList.replace('opacity-100', 'opacity-0');
    mobileCopied?.classList.replace('opacity-0', 'opacity-100');
    mobileCopied?.classList.replace('scale-50', 'scale-100');

    setTimeout(() => {
      copyBtn.classList.remove(...activeColors);
      copyBtn.classList.add(...defaultColors);
      textDefault?.classList.replace('opacity-0', 'opacity-100');
      textDefault?.classList.remove('scale-90');
      textCopied?.classList.replace('opacity-100', 'opacity-0');
      textCopied?.classList.replace('scale-100', 'scale-90');
      mobileDefault?.classList.replace('opacity-0', 'opacity-100');
      mobileCopied?.classList.replace('opacity-100', 'opacity-0');
      mobileCopied?.classList.replace('scale-100', 'scale-50');
    }, 1500);
  });
</script>

<script>
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn?.addEventListener('click', () => {
    menuBtn.classList.toggle('menu-open');
    const isMenuOpen = menuBtn.classList.contains('menu-open');
    if (mobileMenu) {
      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
      } else {
        mobileMenu.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
      }
    }
  });
</script>
