---
// src_old/components/GameModes.astro
const modes = [
    {
        name: 'Color Clash',
        tag: 'LIVE NOW',
        desc: 'Strategiczna walka o terytorium. Maluj mapę, przejmuj punkty i zdominuj arenę w najbardziej kolorowym trybie sezonu.',
        icon: '🎨',
        gradient: 'from-pink-500/20 via-purple-500/10',
        borderColorClass: 'border-pink-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(236,72,153,0.2)] hover:shadow-[0_0_80px_rgba(236,72,153,0.1)]',
        accent: 'text-pink-400',
        status: 'active',
        btnText: 'O trybie',
        url: '/modes/color-clash'
    },
    {
        name: 'Rocky Raceway',
        tag: 'COMING SOON',
        desc: 'Ekstremalne wyścigi na karkołomnych torach. Fizyka pojazdów, której nie zapomnisz.',
        icon: '🏎️',
        gradient: 'from-cyan-500/10 via-blue-900/5',
        borderColorClass: 'border-cyan-500/30',
        glowClass: 'shadow-[0_0_40px_rgba(6,182,212,0.2)] hover:shadow-[0_0_80px_rgba(6,182,212,0.1)]',
        accent: 'text-cyan-400',
        status: 'future',
        btnText: 'Wkrótce...'
    }
];
---

{/* Sekcja Modes - Zwiększony padding boczny i usunięte overflow-hidden z głównego kontenera */}
<section class="max-w-[1440px] mx-auto px-6 md:px-20 py-16 md:py-24 relative">
    <div class="mb-10 md:mb-16 flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.5em] md:tracking-[0.8em] text-cyan-400 mb-2">Choose Your Path</h2>
        <h3 class="text-3xl sm:text-4xl md:text-6xl font-black italic text-white uppercase tracking-tighter leading-none">
            AVAILABLE <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-400 pr-4 md:pr-10">MODES</span>
        </h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-stretch">
        {modes.map(mode => (
            /* BUFOR DLA GLOW: -m-10 p-10 sprawia, że poświata ma miejsce, żeby "wisieć" poza borderem */
                <div class="-m-4 md:-m-12 p-4 md:p-12">
                    <div class={`group relative p-6 md:p-14 rounded-[2.5rem] md:rounded-[4rem] border backdrop-blur-3xl transition-all duration-700 flex flex-col h-full bg-gradient-to-br from-white/5 to-white/[0.02] ${mode.borderColorClass} ${mode.glowClass}`}>

                        {/* Warstwa tła z overflow-hidden, żeby ikona zamka/tła nie wystawała, ale GLOW rodzica był bezpieczny */}
                        <div class="absolute inset-0 rounded-[2.5rem] md:rounded-[4rem] overflow-hidden pointer-events-none">
                            <div class={`absolute inset-0 bg-gradient-to-br ${mode.gradient} opacity-0 group-hover:opacity-20 transition-opacity duration-700`}></div>

                            {mode.status === 'future' && (
                                    <div class="absolute top-4 right-4 md:top-12 md:right-12 text-white/5 rotate-12">
                                        <svg class="w-16 h-16 md:w-32 md:h-32" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1v-3a5 5 0 0 0-5-5zm-3 5a3 3 0 0 1 6 0v3H9V7zm3 11a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                                        </svg>
                                    </div>
                            )}
                        </div>

                        <div class="relative z-10 flex flex-col h-full">
                            <div class="flex justify-between items-start mb-10 md:mb-14">
                                <div class={`w-14 h-14 md:w-24 md:h-24 rounded-2xl md:rounded-[2rem] border border-white/10 flex items-center justify-center text-2xl md:text-5xl shadow-2xl ${
                                    mode.status === 'active' ? 'bg-white/5' : 'bg-black/20 grayscale'
                                }`}>
                                    {mode.icon}
                                </div>

                                <span class={`text-[8px] md:text-[11px] font-black uppercase tracking-[0.3em] py-2 px-4 md:py-3 md:px-6 rounded-xl border border-white/10 shadow-2xl ${
                                    mode.status === 'active' ? 'bg-pink-500/10 text-pink-400' : 'bg-white/5 text-white/20'
                                }`}>
                                {mode.tag}
                            </span>
                            </div>

                            <h4 class={`text-3xl md:text-6xl font-black italic uppercase tracking-tighter mb-4 md:mb-8 leading-[0.85] ${
                                mode.status === 'active' ? 'text-white' : 'text-white/40'
                            }`}>
                                {mode.name}
                            </h4>

                            <p class="text-white/60 text-sm md:text-xl font-medium italic border-l-4 border-white/10 pl-6 md:pl-10 leading-relaxed mb-10 md:mb-16">
                                {mode.desc}
                            </p>

                            <div class="mt-auto flex flex-wrap items-center gap-4">
                                {mode.status === 'active' ? (
                                        <>
                                            <a href={mode.url} class="flex-1 sm:flex-none text-center px-8 py-4 bg-white text-black font-black uppercase text-[10px] md:text-xs tracking-widest rounded-2xl hover:scale-110 hover:bg-pink-500 hover:text-white transition-all duration-500 shadow-[0_20px_40px_rgba(255,255,255,0.2)]">
                                                {mode.btnText}
                                            </a>
                                            <div class="flex items-center justify-center px-5 py-4 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
                                                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse mr-3 shadow-[0_0_15px_#22c55e]"></div>
                                                <span class="text-white/60 font-black text-[10px] md:text-xs uppercase tracking-widest whitespace-nowrap">124 ONLINE</span>
                                            </div>
                                        </>
                                ) : (
                                        <div class="flex items-center justify-center px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-white/20 font-black uppercase text-[10px] md:text-xs tracking-widest italic cursor-not-allowed">
                                            {mode.btnText}
                                        </div>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
        ))}
    </div>
</section>