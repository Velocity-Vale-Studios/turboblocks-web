<div id="cart-drawer" class="fixed top-32 right-4 md:right-8 z-[9000] flex flex-col items-stretch gap-3 pointer-events-none opacity-0 transition-opacity duration-300 w-[calc(100%-2rem)] md:w-[420px] max-h-[calc(100vh-150px)]">

    {/* BUBBLE 1: HEADER */}
    <div class="w-full px-4 md:px-6 py-5 md:py-6 bg-white/[0.02] backdrop-blur-2xl border border-white/10 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex justify-between items-center shrink-0">
        <div>
            <h2 class="text-base md:text-lg font-black italic text-white uppercase tracking-tighter leading-none">
                MANAGE <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-purple-500">CART</span>
            </h2>
            <p class="text-[7px] md:text-[8px] font-bold text-white/30 uppercase tracking-[0.3em] mt-1 pl-0.5">Terminal ID: T-800</p>
        </div>

        <button
                onclick="toggleCart(false)"
                class="w-9 md:w-10 h-9 md:h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 hover:rotate-90 transition-all duration-300 group shadow-lg shrink-0"
        >
            ✕
        </button>
    </div>

    {/* BUBBLE 2: ITEMS LIST */}
    <div class="w-full bg-white/[0.02] backdrop-blur-2xl border border-white/10 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)] overflow-hidden flex flex-col">
        <div id="cart-list" class="overflow-y-auto max-h-[350px] md:max-h-[400px] px-4 md:px-6 py-5 md:py-6 flex flex-col gap-3 custom-scrollbar">
            <div class="h-full flex flex-col items-center justify-center text-center opacity-40">
                <span class="text-4xl mb-4 grayscale">🛒</span>
                <p class="text-white italic uppercase text-[10px] font-black tracking-widest">Inventory Empty</p>
            </div>
        </div>
    </div>

    {/* BUBBLE 3: CHECKOUT */}
    <div class="w-full px-4 md:px-6 py-5 md:py-6 bg-white/[0.02] backdrop-blur-2xl border border-pink-500/30 rounded-[2rem] shadow-[0_20px_50px_rgba(236,72,153,0.15)] shrink-0 relative group/total overflow-hidden">
        {/* Glow ambient */}
        <div class="absolute -top-20 -right-20 w-56 h-56 bg-gradient-to-br from-pink-500/30 to-purple-600/30 blur-[80px] rounded-full animate-pulse transition-all duration-700 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-pink-500/5 to-transparent pointer-events-none"></div>

        <div class="relative z-10">
            <div class="flex justify-between items-end mb-6">
                <div class="flex flex-col gap-1">
                    <span class="text-[8px] font-black text-white/40 uppercase tracking-[0.2em]">Total Value</span>
                    <span id="cart-total" class="text-4xl font-black italic text-transparent bg-clip-text bg-gradient-to-r from-white to-pink-200 tracking-tighter drop-shadow-[0_0_15px_rgba(236,72,153,0.3)]">0 TC</span>
                </div>
                <div class="text-right">
                    <span class="text-[8px] font-black text-white/20 uppercase tracking-[0.2em] block mb-1">Balance</span>
                    <span id="player-balance" class="text-xs font-bold text-cyan-400 drop-shadow-[0_0_5px_rgba(34,211,238,0.5)]">Loading...</span>
                </div>
            </div>

            <button id="checkout-btn" class="relative overflow-hidden w-full py-5 rounded-2xl bg-white text-black font-black uppercase tracking-[0.2em] text-[10px] shadow-[0_0_30px_rgba(255,255,255,0.1)] hover:shadow-[0_0_60px_rgba(236,72,153,0.5)] transition-all duration-300 active:scale-95 group/btn flex items-center justify-center gap-3 border border-transparent hover:border-pink-500/30">
                <span class="relative z-10 group-hover/btn:text-pink-600 transition-colors">CONFIRM ORDER</span>
                <span class="relative z-10 group-hover/btn:text-pink-600 group-hover/btn:translate-x-1 transition-all">→</span>

                {/* Button backgrounds */}
                <div class="absolute inset-0 bg-gradient-to-r from-purple-100 to-pink-100 scale-x-0 group-hover/btn:scale-x-100 transition-transform duration-300 origin-left"></div>
                <div class="absolute inset-0 bg-[url('/noise.png')] opacity-0 group-hover/btn:opacity-10 mix-blend-overlay"></div>
            </button>
        </div>
    </div>

</div>

<script is:inline>
    // --- STATE MANAGEMENT ---
    const CART_STORAGE_KEY = 'turbo_cart_v1';

    // Load state
    window.cart = JSON.parse(localStorage.getItem(CART_STORAGE_KEY) || '[]');
    window.playerBalance = 5000; // Simulated wallet

    // Function to save
    const saveCart = (animate = true) => {
        localStorage.setItem(CART_STORAGE_KEY, JSON.stringify(window.cart));
        updateCartUI(animate);
    };

    // --- DRAWER CONTROLS ---
    let isCartExpanded = false;

    window.toggleCart = (forceState = null) => {
        const drawer = document.getElementById('cart-drawer');
        if (!drawer) return;

        isCartExpanded = (typeof forceState === 'boolean') ? forceState : !isCartExpanded;

        if (isCartExpanded) {
            drawer.classList.remove('opacity-0', 'pointer-events-none');
            drawer.classList.add('opacity-100', 'pointer-events-auto');
            updateCartUI(false);
        } else {
            drawer.classList.add('opacity-0', 'pointer-events-none');
            drawer.classList.remove('opacity-100', 'pointer-events-auto');
        }
    };

    // --- ITEM ACTIONS ---
    window.addToCart = (item) => {
        window.cart.push(item);
        saveCart(true);
        window.toggleCart(true); // Auto-open on add

        // Optional: Play sound or visual cue
    };

    window.removeFromCart = (index) => {
        window.cart.splice(index, 1);
        saveCart(false);
    };

    // --- EVENT LISTENER FOR SHOP PAGES ---
    // This allows Shop.astro buttons to trigger this cart via custom event
    window.addEventListener('shop:add', (e) => {
        if (e.detail) {
            window.addToCart(e.detail);
        }
    });

    // --- UI RENDERER ---
    function updateCartUI(animate = true) {
        const list = document.querySelector('#cart-list');
        const totalDisplay = document.querySelector('#cart-total');
        const balanceDisplay = document.querySelector('#player-balance');
        const checkoutBtn = document.querySelector('#checkout-btn');
        const navbarBadge = document.querySelector('#navbar-cart-count');

        // Update Navbar Badge globally
        if (navbarBadge) {
            navbarBadge.innerText = window.cart.length;
            navbarBadge.style.opacity = window.cart.length > 0 ? '1' : '0';
            // Pop effect
            if (animate) {
                navbarBadge.classList.remove('animate-cart-pop');
                void navbarBadge.offsetWidth; // Trigger reflow
                navbarBadge.classList.add('animate-cart-pop');
            }
        }

        if (!list || !totalDisplay || !checkoutBtn) return; // Exit if drawer not mounted (unlikely)

        // Render List
        if (window.cart.length === 0) {
            list.innerHTML = `
                <div class="h-full flex flex-col items-center justify-center text-center opacity-40">
                    <span class="text-4xl mb-4 grayscale">🛒</span>
                    <p class="text-white italic uppercase text-[10px] font-black tracking-widest">Inventory Empty</p>
                </div>`;
        } else {
            list.innerHTML = '';
            let total = 0;

            window.cart.forEach((item, index) => {
                const priceVal = parseInt(String(item.price).replace(/[^0-9]/g, '')) || 0;
                total += priceVal;

                const itemEl = document.createElement('div');
                itemEl.className = "group relative flex items-center gap-4 bg-black/40 border border-white/5 p-3 pr-4 rounded-[1.5rem] backdrop-blur-md transition-all hover:bg-white/5 hover:border-white/10 hover:scale-[1.02] shrink-0";
                itemEl.innerHTML = `
                    <div class="w-14 h-14 bg-gradient-to-br from-white/10 to-transparent rounded-2xl flex items-center justify-center text-2xl shadow-inner border border-white/5">
                        ${item.icon || '📦'}
                    </div>
                    <div class="flex-grow overflow-hidden">
                        <p class="text-[10px] font-black text-white uppercase italic tracking-tighter truncate pr-4">${item.name}</p>
                        <p class="text-[9px] font-bold text-pink-400 uppercase mt-0.5 tracking-widest">${item.price}</p>
                    </div>
                    <button onclick="removeFromCart(${index})" class="w-8 h-8 rounded-full flex items-center justify-center text-white/20 hover:text-red-500 hover:bg-red-500/10 transition-all font-black text-[10px]">
                        ✕
                    </button>
                `;
                list.appendChild(itemEl);
            });

            // Update Totals
            totalDisplay.innerText = `${total} TC`;
            if (balanceDisplay) balanceDisplay.innerText = `${window.playerBalance} TC`;

            // Validate Purchase
            const canAfford = total <= window.playerBalance;
            const hasItems = window.cart.length > 0;

            if (!hasItems) {
                checkoutBtn.disabled = true;
                checkoutBtn.children[0].innerText = "CART EMPTY";
                checkoutBtn.className = "w-full py-4 rounded-2xl bg-white/5 text-white/20 font-black uppercase tracking-[0.2em] text-[10px] cursor-not-allowed flex items-center justify-center gap-3";
            } else if (!canAfford) {
                checkoutBtn.disabled = true;
                checkoutBtn.children[0].innerText = "INSUFFICIENT FUNDS";
                checkoutBtn.className = "w-full py-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-500 font-black uppercase tracking-[0.2em] text-[10px] cursor-not-allowed flex items-center justify-center gap-3";
            } else {
                checkoutBtn.disabled = false;
                // Re-apply active class styling
                checkoutBtn.className = "relative overflow-hidden w-full py-4 rounded-2xl bg-white text-black font-black uppercase tracking-[0.2em] text-[10px] shadow-[0_0_30px_rgba(255,255,255,0.1)] hover:shadow-[0_0_50px_rgba(236,72,153,0.4)] transition-all duration-300 active:scale-95 group/btn flex items-center justify-center gap-3 cursor-pointer";
                checkoutBtn.innerHTML = `
                    <span class="relative z-10 group-hover/btn:text-pink-500 transition-colors">CONFIRM ORDER</span>
                    <span class="relative z-10 group-hover/btn:text-pink-500 group-hover/btn:translate-x-1 transition-all">→</span>
                    <div class="absolute inset-0 bg-black scale-x-0 group-hover/btn:scale-x-100 transition-transform duration-300 origin-left"></div>
                `;
            }
        }
    }

    // Init Logic on Load
    updateCartUI(false);
</script>

<style is:global>
    @keyframes cart-bounce {
        0% { transform: scale(1); }
        25% { transform: scale(1.5); background-color: #db2777; color: white; box-shadow: 0 0 10px rgba(219, 39, 119, 0.5); }
        40% { transform: scale(0.9); }
        60% { transform: scale(1.15); }
        100% { transform: scale(1); background-color: white; color: #db2777; box-shadow: none; }
    }
    .animate-cart-pop {
        animation: cart-bounce 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    }

    /* Frosted glass effect for cart bubbles - optimized for mobile */
    #cart-drawer > div {
        background: rgba(255, 255, 255, 0.02) !important;
        -webkit-backdrop-filter: blur(40px) !important;
        backdrop-filter: blur(40px) !important;
        isolation: isolate;
        will-change: opacity;
        contain: layout style;
    }

    /* Enhancement layer for cart bubbles */
    #cart-drawer > div::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
        border-radius: inherit;
        pointer-events: none;
        z-index: -1;
    }

    /* GPU acceleration for drawer */
    #cart-drawer {
        will-change: opacity;
        transform: translateZ(0);
        -webkit-transform: translateZ(0);
    }

    /* Firefox fallback */
    @supports not (backdrop-filter: blur(1px)) {
        #cart-drawer > div {
            background: rgba(10, 10, 10, 0.9) !important;
        }
    }
</style>